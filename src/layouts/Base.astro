---
import { SITE, absUrl } from '../lib/data/site';
import { LOCALES, DEFAULT_LOCALE, localizePath, type Locale } from '../lib/i18n';
import Analytics from '../components/shared/Analytics.astro';
import CookieConsent from '../components/shared/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  /** Canonical path or absolute URL. Defaults to the current request URL. */
  canonical?: string;
  /** Social preview image (path or absolute URL). */
  ogImage?: string;
  ogType?: string;
  /** Set true on private/utility pages to keep them out of the index. */
  noindex?: boolean;
  /** Preload a critical (LCP) image, e.g. the homepage hero. */
  preloadImage?: string;
  /** Optional mobile variant; preloaded via media query for phones. */
  preloadImageMobile?: string;
  /** One or more JSON-LD objects injected into <head>. */
  schema?: Record<string, any> | Record<string, any>[];
  htmlClass?: string;
  bodyClass?: string;
}

const {
  title = `${SITE.name} — Discover the Best Things to Do in Rhodes`,
  description = SITE.description,
  canonical,
  ogImage = SITE.defaultOgImage,
  ogType = 'website',
  noindex = false,
  preloadImage,
  preloadImageMobile,
  schema,
  htmlClass = '',
  bodyClass = '',
} = Astro.props;

// Current locale (set by middleware) and the un-prefixed base path.
const locale: Locale = (Astro.locals as any).locale ?? DEFAULT_LOCALE;
const basePath = canonical ?? Astro.url.pathname;

// Canonical points to the localized URL; hreflang lists every language.
const canonicalUrl = absUrl(localizePath(basePath, locale));
const hreflangs = [
  ...LOCALES.map((l) => ({ lang: l, href: absUrl(localizePath(basePath, l)) })),
  { lang: 'x-default', href: absUrl(localizePath(basePath, DEFAULT_LOCALE)) },
];
const ogImageUrl = absUrl(ogImage);

// Always advertise the site-level WebSite + Organization graph, plus any page schema.
const baseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${SITE.url}/listings-map/?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: absUrl('/assets/img/logo.svg'),
    email: SITE.email,
    telephone: SITE.phone,
    ...(SITE.social.length ? { sameAs: SITE.social } : {}),
  },
];
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLd = [...baseSchema, ...pageSchema];
---
<!doctype html>
<html lang={locale} data-bs-theme="" class={htmlClass}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />
    {!noindex && hreflangs.map((h) => (
      <link rel="alternate" hreflang={h.lang} href={h.href} />
    ))}

    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.png" />

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    {jsonLd.map((node) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(node)} />
    ))}

    <!-- Google Analytics (GA4) + Consent Mode -->
    <Analytics />

    {preloadImage && (preloadImageMobile
      ? <>
          <link rel="preload" as="image" href={preloadImage} media="(min-width: 768px)" fetchpriority="high" />
          <link rel="preload" as="image" href={preloadImageMobile} media="(max-width: 767px)" fetchpriority="high" />
        </>
      : <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />)}

    <!-- Preload icon fonts to prevent late-swap layout shift (CLS) -->
    <link rel="preload" as="font" type="font/woff2" href="/assets/webfonts/fa-solid-900.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/assets/fonts/bootstrap-icons.woff2" crossorigin />

    <!-- Jost font: async (was a render-blocking @import inside style.css) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700;800&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700;800&display=swap" /></noscript>

    <!-- Critical CSS (render-blocking): layout + theme only -->
    <link href="/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/assets/css/style.css" rel="stylesheet" />

    <!-- Icon + animation CSS: async so the ~250KB doesn't block first paint
         (icon fonts are preloaded above, so icons appear as soon as it lands) -->
    <link rel="stylesheet" href="/assets/css/bootstrap-icons.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/fontawesome.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/animation.css" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="/assets/css/bootstrap-icons.css" />
      <link rel="stylesheet" href="/assets/css/fontawesome.css" />
      <link rel="stylesheet" href="/assets/css/animation.css" />
    </noscript>

    <!-- Non-critical plugin CSS — loaded async so it doesn't block first paint -->
    <link rel="stylesheet" href="/assets/css/owl.carousel.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/owl.theme.default.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/magnific-popup.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/select2.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/rangeSlider.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/dropzone.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="/assets/css/rome.css" media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href="/assets/css/owl.carousel.min.css" />
      <link rel="stylesheet" href="/assets/css/owl.theme.default.min.css" />
      <link rel="stylesheet" href="/assets/css/magnific-popup.css" />
      <link rel="stylesheet" href="/assets/css/select2.min.css" />
      <link rel="stylesheet" href="/assets/css/rangeSlider.min.css" />
    </noscript>
  </head>

  <body class={bodyClass}>

    <div id="main-wrapper">
      <main>
        <slot />
      </main>
    </div>

    <!-- Back to top -->
    <a href="#" class="btn-primary back-to-top" id="back2Top" aria-label="Back to top"><i class="bi bi-arrow-up"></i></a>

    <!-- Core jQuery + plugins used site-wide (deferred so they don't block paint) -->
    <script src="/assets/js/jquery.min.js" defer is:inline></script>
    <script src="/assets/js/popper.min.js" defer is:inline></script>
    <script src="/assets/js/bootstrap.min.js" defer is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/waypoints@4.0.1/lib/noframework.waypoints.min.js" defer is:inline></script>
    <script src="/assets/js/counterup.min.js" defer is:inline></script>
    <script src="/assets/js/select2.min.js" defer is:inline></script>
    <script src="/assets/js/owl.carousel.min.js" defer is:inline></script>
    <script src="/assets/js/jquery.magnific-popup.min.js" defer is:inline></script>
    <script src="/assets/js/addadult.js" defer is:inline></script>

    {/* Heavy plugins only where used: rome (datepicker), dropzone (uploads),
        rangeslider (price filter) — keeps ~590KB off public/content pages. */}
    {(Astro.url.pathname.includes('dashboard') || Astro.url.pathname.includes('booking') || Astro.url.pathname.includes('add-listing') || Astro.url.pathname.includes('listings')) && (
      <>
        <script src="/assets/js/dropzone.min.js" defer is:inline></script>
        <script src="/assets/js/rangeslider.js" defer is:inline></script>
        <script src="/assets/js/rome.js" defer is:inline></script>
      </>
    )}

    <script src="/assets/js/custom.js" defer is:inline></script>

    {Astro.url.pathname.includes('dashboard') && (
      <>
        <!-- Morris.js charts — dashboard pages only -->
        <script src="/assets/js/raphael/raphael.min.js" defer is:inline></script>
        <script src="/assets/js/morris.js/morris.min.js" defer is:inline></script>
        <script src="/assets/js/custom/dashboard.js" defer is:inline></script>
      </>
    )}

    <!-- Counter-up animation (null-safe; runs on every page) -->
    <script is:inline>
      try {
        const counters = document.querySelectorAll('.counter-value');
        const speed = 2500;
        counters.forEach((counter) => {
          const updateCount = () => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText;
            let inc = target / speed;
            if (inc < 1) inc = 1;
            if (count < target) {
              counter.innerText = Math.min(count + inc, target).toFixed(0);
              requestAnimationFrame(updateCount);
            } else {
              counter.innerText = target;
            }
          };
          updateCount();
        });
      } catch (err) {
        console.error('Error in counter script:', err);
      }
    </script>

    <!-- Back-to-top scroll handler (null-safe) -->
    <script is:inline>
      window.onscroll = function () { scrollFunction(); };
      function scrollFunction() {
        const mybutton = document.getElementById('back-to-top');
        if (mybutton !== null) {
          if (document.body.scrollTop > 500 || document.documentElement.scrollTop > 500) {
            mybutton.classList.add('block');
            mybutton.classList.remove('hidden');
          } else {
            mybutton.classList.add('hidden');
            mybutton.classList.remove('block');
          }
        }
      }
      function topFunction() {
        document.body.scrollTop = 0;
        document.documentElement.scrollTop = 0;
      }
    </script>

    <!-- A11y: label JS-generated carousel controls for screen readers / AI agents -->
    <script is:inline>
      function labelOwlControls() {
        document.querySelectorAll('.owl-dot').forEach(function (d, i) {
          if (!d.getAttribute('aria-label')) d.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        });
        document.querySelectorAll('.owl-prev').forEach(function (p) { p.setAttribute('aria-label', 'Previous'); });
        document.querySelectorAll('.owl-next').forEach(function (p) { p.setAttribute('aria-label', 'Next'); });
      }
      window.addEventListener('load', function () {
        setTimeout(labelOwlControls, 700);
        setTimeout(labelOwlControls, 1800);
      });
    </script>

    <!-- Cookie consent banner -->
    <CookieConsent />
  </body>
</html>
