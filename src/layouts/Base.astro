---
import { SITE, absUrl } from '../lib/data/site';
import Analytics from '../components/shared/Analytics.astro';
import CookieConsent from '../components/shared/CookieConsent.astro';

interface Props {
  title?: string;
  description?: string;
  /** Canonical path or absolute URL. Defaults to the current request URL. */
  canonical?: string;
  /** Social preview image (path or absolute URL). */
  ogImage?: string;
  ogType?: string;
  /** Set true on private/utility pages to keep them out of the index. */
  noindex?: boolean;
  /** One or more JSON-LD objects injected into <head>. */
  schema?: Record<string, any> | Record<string, any>[];
  htmlClass?: string;
  bodyClass?: string;
}

const {
  title = `${SITE.name} — Discover the Best Things to Do in Rhodes`,
  description = SITE.description,
  canonical,
  ogImage = SITE.defaultOgImage,
  ogType = 'website',
  noindex = false,
  schema,
  htmlClass = '',
  bodyClass = '',
} = Astro.props;

// Canonical: strip query/hash so paginated/filtered variants point to the clean URL.
const canonicalUrl = canonical
  ? absUrl(canonical)
  : absUrl(Astro.url.pathname);
const ogImageUrl = absUrl(ogImage);

// Always advertise the site-level WebSite + Organization graph, plus any page schema.
const baseSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: SITE.url,
    potentialAction: {
      '@type': 'SearchAction',
      target: `${SITE.url}/listings-map/?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: SITE.url,
    logo: absUrl('/assets/img/logo.svg'),
    email: SITE.email,
    telephone: SITE.phone,
    ...(SITE.social.length ? { sameAs: SITE.social } : {}),
  },
];
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const jsonLd = [...baseSchema, ...pageSchema];
---
<!doctype html>
<html lang="en" data-bs-theme="" class={htmlClass}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalUrl} />

    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/assets/img/favicon.png" />

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={SITE.locale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Structured data -->
    {jsonLd.map((node) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(node)} />
    ))}

    <!-- Google Analytics (GA4) + Consent Mode -->
    <Analytics />

    <!-- All Plugins -->
    <link href="/assets/css/animation.css" rel="stylesheet" />
    <link href="/assets/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/assets/css/dropzone.min.css" rel="stylesheet" />
    <link href="/assets/css/rome.css" rel="stylesheet" />
    <link href="/assets/css/owl.carousel.min.css" rel="stylesheet" />
    <link href="/assets/css/owl.theme.default.min.css" rel="stylesheet" />
    <link href="/assets/css/rangeSlider.min.css" rel="stylesheet" />
    <link href="/assets/css/select2.min.css" rel="stylesheet" />
    <link href="/assets/css/magnific-popup.css" rel="stylesheet" />
    <link href="/assets/css/prism.css" rel="stylesheet" />

    <!-- Icons CSS -->
    <link href="/assets/css/fontawesome.css" rel="stylesheet" />
    <link href="/assets/css/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@mdi/font/css/materialdesignicons.min.css" rel="stylesheet" />

    <!-- Custom CSS -->
    <link href="/assets/css/style.css" rel="stylesheet" />
  </head>

  <body class={bodyClass}>

    <div id="main-wrapper">
      <main>
        <slot />
      </main>
    </div>

    <!-- Back to top -->
    <a href="#" class="btn-primary back-to-top" id="back2Top"><i class="bi bi-arrow-up"></i></a>

    <!-- All jQuery + plugins (loaded as classic scripts from the copied theme) -->
    <script src="/assets/js/jquery.min.js" is:inline></script>
    <script src="/assets/js/popper.min.js" is:inline></script>
    <script src="/assets/js/bootstrap.min.js" is:inline></script>
    <script src="/assets/js/dropzone.min.js" is:inline></script>
    <script src="https://cdn.jsdelivr.net/npm/waypoints@4.0.1/lib/noframework.waypoints.min.js" is:inline></script>
    <script src="/assets/js/counterup.min.js" is:inline></script>
    <script src="/assets/js/rangeslider.js" is:inline></script>
    <script src="/assets/js/select2.min.js" is:inline></script>
    <script src="/assets/js/owl.carousel.min.js" is:inline></script>
    <script src="/assets/js/rome.js" is:inline></script>
    <script src="/assets/js/jquery.magnific-popup.min.js" is:inline></script>
    <script src="/assets/js/addadult.js" is:inline></script>
    <script src="/assets/js/custom.js" is:inline></script>

    <!-- Morris.js charts (dashboard-only; cheap to keep loaded globally) -->
    <script src="/assets/js/raphael/raphael.min.js" is:inline></script>
    <script src="/assets/js/morris.js/morris.min.js" is:inline></script>
    <script src="/assets/js/custom/dashboard.js" is:inline></script>

    <!-- Counter-up animation (null-safe; runs on every page) -->
    <script is:inline>
      try {
        const counters = document.querySelectorAll('.counter-value');
        const speed = 2500;
        counters.forEach((counter) => {
          const updateCount = () => {
            const target = +counter.getAttribute('data-target');
            const count = +counter.innerText;
            let inc = target / speed;
            if (inc < 1) inc = 1;
            if (count < target) {
              counter.innerText = Math.min(count + inc, target).toFixed(0);
              requestAnimationFrame(updateCount);
            } else {
              counter.innerText = target;
            }
          };
          updateCount();
        });
      } catch (err) {
        console.error('Error in counter script:', err);
      }
    </script>

    <!-- Back-to-top scroll handler (null-safe) -->
    <script is:inline>
      window.onscroll = function () { scrollFunction(); };
      function scrollFunction() {
        const mybutton = document.getElementById('back-to-top');
        if (mybutton !== null) {
          if (document.body.scrollTop > 500 || document.documentElement.scrollTop > 500) {
            mybutton.classList.add('block');
            mybutton.classList.remove('hidden');
          } else {
            mybutton.classList.add('hidden');
            mybutton.classList.remove('block');
          }
        }
      }
      function topFunction() {
        document.body.scrollTop = 0;
        document.documentElement.scrollTop = 0;
      }
    </script>

    <!-- Cookie consent banner -->
    <CookieConsent />
  </body>
</html>
