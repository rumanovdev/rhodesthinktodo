---
// Google Analytics 4 (GA4) with Consent Mode v2.
// Analytics storage defaults to "denied" until the visitor accepts cookies
// via the CookieConsent banner. Goes in <head>.
const GA_ID = 'G-CXN08G00SM';
---
<script is:inline define:vars={{ GA_ID }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() { dataLayer.push(arguments); }

  // Consent Mode v2 — denied by default (GDPR-friendly).
  gtag('consent', 'default', {
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    analytics_storage: 'denied',
    wait_for_update: 500,
  });

  // Honour a previously stored choice on repeat visits.
  try {
    if (localStorage.getItem('cookie-consent') === 'granted') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  } catch (e) {}

  gtag('js', new Date());
  gtag('config', GA_ID);

  // Load the GA library (~150KB) lazily, after the page is interactive, so it
  // never competes with LCP/critical resources.
  function loadGtag() {
    if (window.__gtagLoaded) return;
    window.__gtagLoaded = true;
    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);
  }
  if (document.readyState === 'complete') {
    setTimeout(loadGtag, 1200);
  } else {
    window.addEventListener('load', function () { setTimeout(loadGtag, 1200); });
  }
  // Also load on first interaction in case load fires late.
  ['scroll', 'click', 'keydown', 'touchstart'].forEach(function (e) {
    window.addEventListener(e, loadGtag, { once: true, passive: true });
  });
</script>
