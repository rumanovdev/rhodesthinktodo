---
interface Props { current?: string; }
const { current = 'overview' } = Astro.props;
const items = [
  { key: 'overview',  href: '/admin/',           icon: 'bi-speedometer2',  label: 'Overview' },
  { key: 'analytics', href: '/admin/analytics/', icon: 'bi-graph-up',      label: 'Analytics' },
  { key: 'users',     href: '/admin/users/',     icon: 'bi-people',        label: 'Users' },
  { key: 'listings',  href: '/admin/listings/',  icon: 'bi-ui-radios-grid',label: 'Listings' },
  { key: 'bookings',  href: '/admin/bookings/',  icon: 'bi-calendar2-check', label: 'Bookings' },
  { key: 'taxonomy',  href: '/admin/taxonomy/',  icon: 'bi-diagram-3',     label: 'Categories' },
  { key: 'areas',     href: '/admin/areas/',     icon: 'bi-geo-alt',       label: 'Areas' },
];
---
<div class="card rounded-3 shadow-sm p-3 mb-4">
  <div class="d-flex align-items-center gap-2 px-2 pb-3 border-bottom mb-2">
    <i class="bi bi-shield-lock text-primary fs-4"></i>
    <div>
      <h6 class="fw-semibold mb-0">Admin Panel</h6>
      <span class="text-sm text-muted">Rhodes Things To Do</span>
    </div>
  </div>
  <ul class="list-unstyled mb-0">
    {items.map((it) => (
      <li>
        <a href={it.href} class={`d-flex align-items-center gap-2 rounded-3 px-3 py-2 text-decoration-none ${current === it.key ? 'bg-primary text-white' : 'text-dark'}`}>
          <i class={`bi ${it.icon}`}></i>{it.label}
        </a>
      </li>
    ))}
    <li class="border-top mt-2 pt-2">
      <a href="/dashboard-user/" class="d-flex align-items-center gap-2 rounded-3 px-3 py-2 text-decoration-none text-muted">
        <i class="bi bi-arrow-left"></i>Back to site dashboard
      </a>
    </li>
  </ul>
</div>
