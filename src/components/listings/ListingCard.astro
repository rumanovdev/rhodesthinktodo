---
import type { ListingCard } from '../../lib/supabase/listings';
interface Props { item: ListingCard; }
const { item } = Astro.props;
---
<div class="fr-listing-cards listing-card5 lightshadow rounded-4 pb-0 h-100">
  <div class="fr-list-thumbs rounded-top-4">
    <a href={`/listing/${item.slug}/`}><img src={item.img} class="img-fluid rounded-top-4" alt={item.title} loading="lazy" /></a>
    {item.tag && (
      <div class="lis-wishlist"><span class="badge badge-xs bg-warning">Featured</span></div>
    )}
    <div class="position-absolute start-0 top-0 ms-3 mt-3">
      <span class={`badge badge-xs text-uppercase ${item.color === 'success' ? 'bg-success' : 'bg-primary'}`}>{item.btn}</span>
    </div>
  </div>
  <div class="fr-listing-content p-3">
    <div class="listingCats mb-1"><span class="text-md text-primary fw-medium">{item.name}</span></div>
    <h4 class="listingTitle"><a href={`/listing/${item.slug}/`} class="titleLink">{item.title}</a></h4>
    <div class="text-md text-muted mt-1"><i class="bi bi-geo-alt me-1"></i>{item.location || '—'}</div>
    <div class="d-flex align-items-center justify-content-between mt-3">
      <div class="text-sm"><i class="bi bi-star-fill text-warning me-1"></i>{item.rating} · {item.reviews}</div>
      <div class="text-sm text-muted">{item.dollar}</div>
    </div>
  </div>
</div>
