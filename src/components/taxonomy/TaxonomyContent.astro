---
import Base from '../../layouts/Base.astro';
import Navbar from '../nav/Navbar.astro';
import Footer from '../nav/Footer.astro';
import Subscribe from '../shared/Subscribe.astro';
import LoginModal from '../shared/LoginModal.astro';
import SearchOffcanvas from '../shared/SearchOffcanvas.astro';
import Preloader from '../shared/Preloader.astro';
import ListingCard from '../listings/ListingCard.astro';
import type { TaxonomyPageData } from '../../lib/supabase/taxonomy';

interface Props { page: TaxonomyPageData; }
const { page } = Astro.props;
const { res, meta, crumbs, schema, listings, total, tree, topAreas } = page;

const catSlug = res.category.slug;
const curSub = res.subcategory?.slug ?? null;
const curArea = res.area?.slug ?? null;

const motherNode = tree.find((n) => n.id === res.category.id);
const subs = motherNode?.subcategories ?? [];

// Chip URLs keep the "other" dimension fixed (canonical order cat/sub/area).
const subUrl = (subSlug: string | null) => '/' + [catSlug, subSlug, curArea].filter(Boolean).join('/') + '/';
const areaUrl = (aSlug: string | null) => '/' + [catSlug, curSub, aSlug].filter(Boolean).join('/') + '/';

const place = res.area ? res.area.name : 'Rhodes';
const thing = res.subcategory ? res.subcategory.name : res.category.name;

// Map markers: listings that have coordinates.
const mappable = listings.filter((l) => l.lat !== null && l.lng !== null);
const markers = mappable.map((l) => ({
  id: l.id,
  slug: l.slug,
  title: l.title,
  img: l.img,
  category: l.name,
  rating: l.rating,
  reviews: l.reviews,
  price: l.dollar,
  lat: l.lat,
  lng: l.lng,
}));
---
<Base title={meta.title} description={meta.description} canonical={meta.path} noindex={meta.noindex} schema={schema}>
  <Navbar headerClass="header header-light head-shadow" />
  <Preloader />

  <!-- Hero / heading -->
  <section class="pt-5 pb-4 gray-simple">
    <div class="container">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-2">
          {crumbs.map((c, i) => (
            i === crumbs.length - 1
              ? <li class="breadcrumb-item active" aria-current="page">{c.name}</li>
              : <li class="breadcrumb-item"><a href={c.href}>{c.name}</a></li>
          ))}
        </ol>
      </nav>
      <h1 class="fs-2 fw-semibold mb-2">{meta.h1}</h1>
      <p class="text-muted mb-0">
        {total > 0
          ? `${total} ${total === 1 ? 'place' : 'places'} · ${thing} in ${place}, Rhodes`
          : `We're still adding ${thing.toLowerCase()} in ${place}. Check back soon.`}
      </p>
    </div>
  </section>

  <!-- Faceted internal links -->
  <section class="pt-4 pb-0">
    <div class="container">
      {subs.length > 0 && (
        <div class="mb-3">
          <span class="text-sm text-muted d-block mb-2 text-uppercase fw-semibold">Browse by type</span>
          <div class="d-flex flex-wrap gap-2">
            <a href={'/' + [catSlug, null, curArea].filter(Boolean).join('/') + '/'}
               class={`badge rounded-pill px-3 py-2 ${!curSub ? 'bg-primary' : 'bg-light-primary text-primary'}`}>All {res.category.name}</a>
            {subs.map((s) => (
              <a href={subUrl(s.slug)} class={`badge rounded-pill px-3 py-2 ${curSub === s.slug ? 'bg-primary' : 'bg-light-primary text-primary'}`}>{s.name}</a>
            ))}
          </div>
        </div>
      )}
      {topAreas.length > 0 && (
        <div class="mb-2">
          <span class="text-sm text-muted d-block mb-2 text-uppercase fw-semibold">Browse by area</span>
          <div class="d-flex flex-wrap gap-2">
            <a href={'/' + [catSlug, curSub].filter(Boolean).join('/') + '/'}
               class={`badge rounded-pill px-3 py-2 ${!curArea ? 'bg-dark' : 'bg-light text-dark border'}`}>All of Rhodes</a>
            {topAreas.map((a) => (
              <a href={areaUrl(a.slug)} class={`badge rounded-pill px-3 py-2 ${curArea === a.slug ? 'bg-dark' : 'bg-light text-dark border'}`}>{a.name}</a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Listings + side map -->
  <section class="pt-4 pb-5">
    <div class="container">
      <div class="row g-4">

        <!-- Listings column -->
        <div class="col-lg-7 col-xl-8">
          {listings.length === 0 ? (
            <div class="text-center py-5">
              <p class="text-muted mb-3">No published listings here yet.</p>
              <a href={`/${catSlug}/`} class="btn btn-light rounded-pill me-2">All {res.category.name}</a>
              <a href="/listings-map/" class="btn btn-primary rounded-pill">Explore the map</a>
            </div>
          ) : (
            <div class="row g-4">
              {listings.map((item) => (
                <div class="col-12 col-md-6 taxo-listing" data-listing-id={item.id}><ListingCard item={item} /></div>
              ))}
            </div>
          )}
        </div>

        <!-- Map column (side, sticky) -->
        <div class="col-lg-5 col-xl-4">
          <div class="taxonomy-map-wrap">
            <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
            <div id="taxonomyMap" class="taxonomy-map rounded-4 overflow-hidden shadow-sm border" role="application" aria-label={`Map of ${meta.h1}`}></div>
            {mappable.length > 0 && (
              <p class="text-sm text-muted mt-2 mb-0"><i class="bi bi-geo-alt me-1"></i>{mappable.length} {mappable.length === 1 ? 'place' : 'places'} on the map</p>
            )}
          </div>
        </div>

      </div>
    </div>
  </section>

  <style is:global>
    .taxonomy-map-wrap { position: sticky; top: 90px; }
    .taxonomy-map { height: calc(100vh - 130px); min-height: 420px; width: 100%; position: relative; z-index: 0; background: #eef0f2; }
    @media (max-width: 991px) {
      .taxonomy-map-wrap { position: relative; top: 0; margin-bottom: 1.25rem; }
      .taxonomy-map { height: 360px; min-height: 0; }
    }
    /* Airbnb-style pill markers */
    .taxo-pin {
      position: absolute;
      transform: translate(-50%, -50%);
      background: #fff;
      color: #222;
      font-weight: 700;
      font-size: 12px;
      line-height: 1;
      padding: 7px 10px;
      border-radius: 999px;
      box-shadow: 0 1px 2px rgba(0,0,0,.18), 0 2px 8px rgba(0,0,0,.12);
      border: 1px solid rgba(0,0,0,.05);
      white-space: nowrap;
      cursor: pointer;
      user-select: none;
      transition: transform .12s ease, background-color .12s ease, color .12s ease, box-shadow .12s ease;
    }
    .taxo-pin:hover, .taxo-pin.is-active {
      background: #222;
      color: #fff;
      transform: translate(-50%, -50%) scale(1.06);
      box-shadow: 0 3px 12px rgba(0,0,0,.32);
      z-index: 650 !important;
    }
    .leaflet-marker-icon.taxo-pin-wrap { background: transparent; border: 0; }
    /* Card highlight when its marker is selected */
    .taxo-listing .fr-listing-cards { transition: box-shadow .15s ease, outline-color .15s ease; outline: 2px solid transparent; }
    .taxo-listing.is-active .fr-listing-cards { outline-color: var(--bs-primary, #e11d48); box-shadow: 0 10px 26px rgba(0,0,0,.14) !important; }
    /* Popup */
    .leaflet-popup-content-wrapper { border-radius: 14px; }
    .leaflet-popup-content { min-width: 190px; }
    .leaflet-popup-content .lm-popup-img { width: 100%; height: 104px; object-fit: cover; border-radius: 10px; margin-bottom: 8px; }
    .leaflet-popup-content .lm-popup-title { font-weight: 700; color: #1a1a1a; display: block; text-decoration: none; margin-bottom: 2px; }
    .leaflet-popup-content .lm-popup-meta { font-size: 12px; color: #666; }
  </style>

  <script type="application/json" id="taxonomy-map-data" set:html={JSON.stringify(markers)}></script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>
  <script is:inline>
    (function () {
      var dataEl = document.getElementById('taxonomy-map-data');
      var mapEl = document.getElementById('taxonomyMap');
      if (!dataEl || !mapEl || typeof L === 'undefined') return;
      var listings = [];
      try { listings = JSON.parse(dataEl.textContent || '[]'); } catch (e) { listings = []; }

      var map = L.map(mapEl, { zoomControl: true, scrollWheelZoom: false });
      // Clean, muted Airbnb-style base map (CARTO Positron) — no API key required.
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        maxZoom: 20,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
      }).addTo(map);

      var markers = {};
      var bounds = [];

      function pinLabel(l) {
        if (l.price) return l.price;
        if (l.rating) return '\u2605 ' + l.rating;
        return '\u2022';
      }

      listings.forEach(function (l) {
        if (l.lat == null || l.lng == null) return;
        var icon = L.divIcon({
          className: 'taxo-pin-wrap',
          iconSize: [0, 0],
          iconAnchor: [0, 0],
          html: '<div class="taxo-pin">' + esc(pinLabel(l)) + '</div>'
        });
        var m = L.marker([l.lat, l.lng], { icon: icon, riseOnHover: true }).addTo(map);
        var html = [
          l.img ? '<img src="' + esc(l.img) + '" class="lm-popup-img" alt="">' : '',
          '<a class="lm-popup-title" href="/listing/' + esc(l.slug) + '/">' + esc(l.title) + '</a>',
          '<div class="lm-popup-meta">' + esc(l.category || '') + ' \u00b7 ' + esc(l.price || '') + '</div>',
          '<div class="lm-popup-meta">\u2605 ' + esc(l.rating || '') + ' \u00b7 ' + esc(l.reviews || '') + ' Reviews</div>'
        ].join('');
        m.bindPopup(html, { autoPan: true });
        m.on('click', function () { activateCard(l.id, true); });
        m.on('popupclose', function () { activateCard(l.id, false); });
        markers[l.id] = m;
        bounds.push([l.lat, l.lng]);
      });

      if (bounds.length > 0) map.fitBounds(bounds, { padding: [50, 50], maxZoom: 15 });
      else map.setView([36.44, 28.22], 10);
      setTimeout(function () { map.invalidateSize(); }, 200);

      // Card <-> marker sync (Airbnb behaviour).
      function pinEl(id) {
        var m = markers[id];
        if (!m) return null;
        var el = m.getElement();
        return el ? el.querySelector('.taxo-pin') : null;
      }
      function setPinActive(id, on) {
        var p = pinEl(id);
        if (p) p.classList.toggle('is-active', on);
      }
      function activateCard(id, on) {
        var card = document.querySelector('.taxo-listing[data-listing-id="' + cssEsc(id) + '"]');
        if (card) {
          card.classList.toggle('is-active', on);
          if (on && card.scrollIntoView) card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        setPinActive(id, on);
      }
      document.querySelectorAll('.taxo-listing[data-listing-id]').forEach(function (card) {
        var id = card.getAttribute('data-listing-id');
        card.addEventListener('mouseenter', function () { setPinActive(id, true); });
        card.addEventListener('mouseleave', function () { if (!card.classList.contains('is-active')) setPinActive(id, false); });
      });

      function esc(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      }
      function cssEsc(s) { return String(s == null ? '' : s).replace(/["\\]/g, '\\$&'); }
    })();
  </script>

  <Subscribe />
  <Footer />
  <LoginModal />
  <SearchOffcanvas />
</Base>
