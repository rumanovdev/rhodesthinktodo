---
import { SITE } from '../../lib/data/site';
---
<footer class="footer skin-dark-footer">
    <div class="container-fluid">
        <div class="row">

            <div class="col-12 col-md-5 col-lg-12 col-xl-4">
                <div class="footer-widget pe-xl-4 mb-5">
                    <div class="footerLogo"><img src="/assets/img/rhodes-logo.svg" class="img-fluid" width="200" alt="Rhodes Things To Do"></div>
                    {/* Social media links temporarily removed until live profiles exist. */}
                </div>
            </div>

            <div class="col-6 col-md-4 offset-md-3 col-lg-3  offset-lg-0 col-xl-2">
                <div class="footer-widget mb-5 mb-md-5 mb-lg-0">
                    <h4 class="widget-title text-pri">Community</h4>
                    <ul class="footer-menu">
                        <li><a href="/about-us/">About Rhodes Things To Do</a></li>
                        <li><a href="/dashboard-add-listing/">Submit Listing</a></li>
                        <li><a href="/blog/">Blog</a></li>
                        <li><a href="/contact-us/">Contact</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <div class="footer-widget mb-5 mb-md-5 mb-lg-0">
                    <h4 class="widget-title">Getting Started</h4>
                    <ul class="footer-menu">
                        <li><a href="/help-center/">Help Center</a></li>
                        <li><a href="/faq/">FAQ</a></li>
                        <li><a href="/privacy-policy/">Privacy Policy</a></li>
                        <li><a href="/register/">Create an Account</a></li>
                        <li><a href="/login/">Sign In</a></li>
                        <li><a href="/blog/">Blog</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <div class="footer-widget">
                    <h4 class="widget-title">Rhodes Things To Do Business</h4>
                    <ul class="footer-menu">
                        <li><a href="/dashboard-add-listing/">List Your Business</a></li>
                        <li><a href="/dashboard-user/">Business Dashboard</a></li>
                        <li><a href="/contact-us/">Contact Sales</a></li>
                        <li><a href="/help-center/">Help Center</a></li>
                        <li><a href="/faq/">FAQ</a></li>
                    </ul>
                </div>
            </div>

            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <div class="footer-widget">
                    <h4 class="widget-title">Get In Touch</h4>
                    <div class="contactInfowrap">

                        <div class="singleinfo">
                            <div class="icons"><i class="bi bi-geo-alt-fill"></i></div>
                            <div class="caps">
                                <h5 class="title"><a href="https://www.google.com/maps/place/Rhodes" target="_blank" rel="noopener" class="text-reset">Rhodes, Greece</a></h5>
                                <p class="subs">Find Us</p>
                            </div>
                        </div>

                        <div class="singleinfo">
                            <div class="icons"><i class="bi bi-telephone-outbound"></i></div>
                            <div class="caps">
                                <h5 class="title"><a href={SITE.phoneHref} class="text-reset">{SITE.phone}</a></h5>
                                <p class="subs">Mon - Sat 10am - 6PM</p>
                            </div>
                        </div>

                        <div class="singleinfo">
                            <div class="icons"><i class="bi bi-envelope"></i></div>
                            <div class="caps">
                                <h5 class="title"><a href={`mailto:${SITE.email}`} class="text-reset">{SITE.email}</a></h5>
                                <p class="subs">Email Us</p>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>

        <!-- Copyright bar: full width, below everything -->
        <div class="footer-bottom border-top mt-4 pt-3 text-center">
            <p class="mb-0">© <script is:inline>document.write(new Date().getFullYear())</script> Rhodes Things To Do. All rights reserved.</p>
        </div>

    </div>

</footer>

<style is:global>
  /* Footer: solid black background, all text white, slightly larger font */
  footer.skin-dark-footer {
    background: #000 !important;
  }
  footer.skin-dark-footer,
  footer.skin-dark-footer p,
  footer.skin-dark-footer a,
  footer.skin-dark-footer h4,
  footer.skin-dark-footer h5,
  footer.skin-dark-footer .widget-title,
  footer.skin-dark-footer .footer-menu li a,
  footer.skin-dark-footer .subs,
  footer.skin-dark-footer .icons i {
    color: #fff !important;
  }
  footer.skin-dark-footer .widget-title {
    font-size: 1.25rem;
  }
  footer.skin-dark-footer .footer-menu li a,
  footer.skin-dark-footer .singleinfo .title a,
  footer.skin-dark-footer .footerText p {
    font-size: 1rem;
  }
  footer.skin-dark-footer .subs {
    font-size: 0.9rem;
    opacity: 0.85;
  }
  footer.skin-dark-footer .footer-menu li a:hover {
    opacity: 0.8;
  }
  footer.skin-dark-footer .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15) !important;
  }
  footer.skin-dark-footer .footer-bottom p {
    font-size: 0.95rem;
    opacity: 0.85;
  }
</style>
