---
interface Props {
  /** Full class list for the outer `<div class="header …">`. Defaults to navbar9 ("light + shadow"). */
  headerClass?: string;
  /** Path to the brand logo image. Defaults to the standard dark-on-light logo. */
  logo?: string;
  /** If true, tag the Add-Listing button with the `light` modifier (used by the dark/transparent variants). */
  addListingLight?: boolean;
}

const {
  headerClass = 'header header-light head-shadow',
  logo = '/assets/img/logo.svg',
  addListingLight = false,
} = Astro.props;

const user = Astro.locals?.user ?? null;
const supabase = Astro.locals?.supabase ?? null;
const isAdmin = Astro.locals?.isAdmin ?? false;

let userLabel: string | null = null;
let userAvatar: string | null = null;
if (user) {
  userLabel = (user.user_metadata?.full_name as string) || user.email?.split('@')[0] || 'Account';
  if (supabase) {
    // getMyProfile import is local to this file so the component stays self-contained.
    const { getMyProfile } = await import('../../lib/supabase/profiles');
    const profile = await getMyProfile(supabase, user.id);
    if (profile?.full_name) userLabel = profile.full_name;
    if (profile?.avatar_url) userAvatar = profile.avatar_url;
  }
}
---
<!-- Start Navigation -->
<div class={headerClass} data-sticky-element="">
  <div class="container-fluid">
    <nav id="navigation" class="navigation navigation-landscape">
      <div class="nav-header">
        <a class="nav-brand" href="/"><img src={logo} class="logo" alt="" /></a>
        <div class="nav-toggle"></div>
        <div class="mobile_nav">
          <ul>
            <li>
              {user ? (
                <a href="/dashboard-user/" class="d-flex align-items-center" aria-label="Go to dashboard">
                  {userAvatar
                    ? <img src={userAvatar} alt={userLabel ?? 'Account'} style="width:24px;height:24px;object-fit:cover;border-radius:50%;" />
                    : <i class="bi bi-person-circle"></i>}
                </a>
              ) : (
                <a href="#" class="d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#login" aria-label="Sign in"><i class="bi bi-person-circle"></i></a>
              )}
            </li>
            <li>
              <a href="#searchSlider" class="d-flex align-items-center" data-bs-toggle="offcanvas" role="button" aria-controls="searchSlider" aria-label="Search"><i class="bi bi-search"></i></a>
            </li>
          </ul>
        </div>
      </div>
      <div class="nav-menus-wrapper">
        <!-- Mobile-only logo inside the slide-in drawer -->
        <div class="mobile-menu-logo d-lg-none d-flex align-items-center justify-content-center py-3 border-bottom">
          <a class="d-inline-block" href="/"><img src="/assets/img/logo.svg" alt="Rhodes Things To Do" style="height: 32px;" /></a>
        </div>
        <ul class="nav-menu">
          <li class="parent-parent-menu-item"><a href="/" class="home-link">Home</a></li>

          <li class="parent-parent-menu-item"><a href="/listings-map/" class="home-link">Explore</a></li>

          <li class="parent-parent-menu-item"><a href="/about-us/" class="home-link">About Us</a></li>

          {/* User Dashboard submenu removed from the primary nav — the logged-in user reaches dashboard pages via the avatar dropdown (right-aligned) instead. */}

          {isAdmin && (
          <li class="parent-parent-menu-item"><a href="JavaScript:Void(0);" class="home-link">Pages<span class="submenu-indicator"></span></a>
            <ul class="nav-dropdown nav-submenu">
              <li class="parent-menu-item"><a href="JavaScript:Void(0);"><i class="bi bi-person-circle me-1"></i>My Account<span class="submenu-indicator"></span></a>
                <ul class="nav-dropdown nav-submenu">
                  <li><a href="/login/" class="sub-menu-item"><i class="bi bi-box-arrow-in-right me-1"></i>User Login</a></li>
                  <li><a href="/register/" class="sub-menu-item"><i class="bi bi-person-plus me-1"></i>Signup Page</a></li>
                  <li><a href="/forgot-password/" class="sub-menu-item"><i class="bi bi-question-circle me-1"></i>Forget Password</a></li>
                  <li><a href="/two-factor-auth/" class="sub-menu-item"><i class="bi bi-shield-check me-1"></i>Two Step verification</a></li>
                </ul>
              </li>
              {/* Shop submenu (Checkout / Invoice / Success Payment) hidden in MVP — booking-page handles the checkout flow. */}
              <li><a href="/author-profile/" class="sub-menu-item"><i class="bi bi-person-vcard me-1"></i>Author Profile</a></li>
              <li><a href="/booking-page/" class="sub-menu-item"><i class="bi bi-calendar2-check me-1"></i>Booking Page</a></li>
              <li><a href="/about-us/" class="sub-menu-item"><i class="bi bi-person-check me-1"></i>About Us</a></li>
              <li><a href="/blog/" class="sub-menu-item"><i class="bi bi-blockquote-left me-1"></i>Blog Page</a></li>
              <li><a href="/blog-detail/" class="sub-menu-item"><i class="bi bi-blockquote-left me-1"></i>Blog Detail</a></li>
              <li><a href="/contact-us/" class="sub-menu-item"><i class="bi bi-envelope-check me-1"></i>Contact Us</a></li>
              <li><a href="/pricing/" class="sub-menu-item"><i class="bi bi-coin me-1"></i>Pricing</a></li>
              <li><a href="/privacy-policy/" class="sub-menu-item"><i class="bi bi-shield-check me-1"></i>Privacy Policy</a></li>
              <li><a href="/help-center/" class="sub-menu-item"><i class="bi bi-patch-question me-1"></i>Help Center</a></li>
              <li><a href="/comingsoon/" class="sub-menu-item"><i class="bi bi-hourglass-top me-1"></i>Coming Soon</a></li>
              <li><a href="/faq/" class="sub-menu-item"><i class="bi bi-info-circle me-1"></i>FAQ's</a></li>
              <li><a href="/error/" class="sub-menu-item"><i class="bi bi-x-octagon me-1"></i>Error Page</a></li>
              <li><a href="/elements/" class="sub-menu-item"><i class="bi bi-gear me-1"></i>Elements</a></li>
            </ul>
          </li>
          )}

          <li><a class="mob-addlisting light" href="JavaScript:Void(0);"><i class="bi bi-geo-alt-fill me-1"></i>Add Listing</a></li>
        </ul>

        <ul class="nav-menu nav-menu-social align-to-right">
          {user ? (
            <>
              <li class="parent-parent-menu-item">
                <a href="JavaScript:Void(0);" class="home-link d-flex align-items-center">
                  {userAvatar
                    ? <img src={userAvatar} class="me-2" style="width:28px;height:28px;object-fit:cover;border-radius:50%;" alt={userLabel ?? 'Account'} />
                    : <i class="bi bi-person-circle fs-5 me-2"></i>}
                  <span class="navCl">{userLabel}</span><span class="submenu-indicator"></span>
                </a>
                <ul class="nav-dropdown nav-submenu">
                  <li><a href="/dashboard-user/" class="sub-menu-item"><i class="bi bi-speedometer me-1"></i>Dashboard</a></li>
                  <li><a href="/dashboard-my-profile/" class="sub-menu-item"><i class="bi bi-person-lines-fill me-1"></i>My Profile</a></li>
                  <li><a href="/dashboard-my-listings/" class="sub-menu-item"><i class="bi bi-ui-radios-grid me-1"></i>My Listings</a></li>
                  <li><a href="/dashboard-my-bookings/" class="sub-menu-item"><i class="bi bi-journal-check me-1"></i>My Bookings</a></li>
                  <li><a href="/dashboard-bookmarks/" class="sub-menu-item"><i class="bi bi-bookmark-star me-1"></i>Bookmarks</a></li>
                  <li>
                    <form action="/api/auth/signout" method="post" style="display:inline;">
                      <button type="submit" class="sub-menu-item bg-transparent border-0 text-start w-100" style="padding: inherit; color: inherit; font: inherit; cursor: pointer;"><i class="bi bi-box-arrow-right me-1"></i>Sign Out</button>
                    </form>
                  </li>
                </ul>
              </li>
              <li class={`list-buttons${addListingLight ? ' light' : ''}`}>
                <a href="/dashboard-add-listing/"><i class="bi bi-geo-alt fs-6 me-1"></i>Add Listing</a>
              </li>
            </>
          ) : (
            <>
              <li>
                <a href="#" class="d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#login"><i class="bi bi-person-circle fs-6 me-1"></i><span class="navCl">Sign In</span></a>
              </li>
              <li class={`list-buttons${addListingLight ? ' light' : ''}`}>
                <a href="/register/"><i class="bi bi-geo-alt fs-6 me-1"></i>Add Listing</a>
              </li>
            </>
          )}
        </ul>
      </div>
    </nav>
  </div>
</div>
<!-- End Navigation -->

<style is:global>
  @media (min-width: 1024px) {
    .navigation-landscape .nav-menus-wrapper {
      position: relative;
    }
    .navigation-landscape .nav-menus-wrapper > ul.nav-menu:not(.nav-menu-social) {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      float: none;
    }
    /* Bigger nav link text */
    .navigation-landscape .nav-menu > li > a.home-link,
    .navigation-landscape .nav-menu.nav-menu-social > li > a {
      font-size: 19px;
    }
  }

  /* On the transparent (homepage) header the theme renders nav links at 50%
     white (grey). Force full white for the menu links and the Sign In link.
     Inner pages use the light header, so this selector never affects them;
     the scrolled state of this variant has a dark background, so white stays readable. */
  .header.header-transparent .nav-menu > li > a.home-link,
  .header.header-transparent .nav-menu.nav-menu-social > li > a {
    color: var(--bs-white) !important;
  }
  /* Add Listing button stays red even when the navbar is in its initial
     (non-scrolled) "light" state on transparent/dark hero variants. */
  .nav-menu.nav-menu-social > li.list-buttons.light a,
  .nav-menu.nav-menu-social > li.list-buttons.light a:hover,
  .nav-menu.nav-menu-social > li.list-buttons.light a:focus {
    background: var(--bs-primary) !important;
    color: var(--bs-white) !important;
  }
</style>

<script is:inline>
  (function () {
    const currentPath = window.location.pathname.replace(/\/$/, '');
    document.querySelectorAll('.sub-menu-item').forEach((item) => {
      let itemPath;
      try {
        itemPath = new URL(item.href).pathname.replace(/\/$/, '');
      } catch {
        return; // href is "JavaScript:Void(0);" or similar — skip.
      }
      if (itemPath !== currentPath) return;
      item.classList.add('active');
      let parentMenu = item.closest('.parent-menu-item');
      while (parentMenu && !parentMenu.classList.contains('processed')) {
        const parentLink = parentMenu.querySelector('a');
        if (parentLink) parentLink.classList.add('active');
        parentMenu.classList.add('processed');
        parentMenu = parentMenu.closest('.parent-parent-menu-item');
      }
      const topLevelMenu = item.closest('.parent-parent-menu-item');
      if (topLevelMenu) {
        const topLevelLink = topLevelMenu.querySelector('.home-link');
        if (topLevelLink) topLevelLink.classList.add('active');
      }
    });
  })();
</script>
