---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/nav/Navbar.astro';
import Footer from '../../components/nav/Footer.astro';
import Subscribe from '../../components/shared/Subscribe.astro';
import LoginModal from '../../components/shared/LoginModal.astro';
import SearchOffcanvas from '../../components/shared/SearchOffcanvas.astro';
import Preloader from '../../components/shared/Preloader.astro';
import { events } from '../../lib/data/context';

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}
---
<Base noindex title="Single Listing - Rhodes Things To Do">
  <Navbar headerClass="header header-light" />

  <Preloader />

  <div class="clearfix"></div>

  <section class="py-5">
    <div class="container">
      <div class="row align-items-center justify-content-between mb-4">
        <div class="col">
          <h2 class="fw-semibold mb-1">Single Listings</h2>
          <p class="text-muted mb-0">Browse the events below and click through to see details.</p>
        </div>
      </div>

      <div class="row">
        {events.map((event: any) => (
          <div class="col-lg-4 col-md-6 mb-4">
            <div class="card h-100">
              {event.img && <img src={event.img} class="card-img-top" alt={event.title} />}
              <div class="card-body">
                {event.name && (
                  <span class={event.color}>{event.name}</span>
                )}
                <h5 class="card-title mt-2">
                  <a href={`/listing/${event.slug || slugify(event.title)}/`}>
                    {event.title}
                  </a>
                </h5>
                {event.time && <p class="card-text text-muted mb-1"><i class="bi bi-clock me-2"></i>{event.time}</p>}
                {(event.date || event.month) && (
                  <p class="card-text text-muted mb-0"><i class="bi bi-calendar me-2"></i>{event.date} {event.month}</p>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Subscribe />
  <LoginModal />
  <SearchOffcanvas />
  <Footer />
</Base>
