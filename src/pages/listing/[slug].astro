---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/nav/Navbar.astro';
import Footer from '../../components/nav/Footer.astro';
import Subscribe from '../../components/shared/Subscribe.astro';
import LoginModal from '../../components/shared/LoginModal.astro';
import SearchOffcanvas from '../../components/shared/SearchOffcanvas.astro';
import Preloader from '../../components/shared/Preloader.astro';
import { gallerys3 } from '../../lib/data/context';
import { getListingBySlug, getPublishedListings, slugify } from '../../lib/supabase/listings';
import { getListingTaxonomy } from '../../lib/supabase/taxonomy';
import { absUrl } from '../../lib/data/site';
export const prerender = false;

const { slug } = Astro.params as { slug: string };
const result = await getListingBySlug(Astro.locals.supabase, slug);
if (!result) {
  return new Response('Listing not found', { status: 404 });
}
const event = result.card;
const detail = result.raw;
const heroImg = event.img || '/assets/img/single-4.jpg';

// Similar listings — pull 4 most recent published ones excluding this one.
const similar = (await getPublishedListings(Astro.locals.supabase, { limit: 4 })).filter((l) => l.id !== event.id);
const listings2 = similar;

// Reviews for this listing.
const { data: reviewRows } = Astro.locals.supabase
  ? await Astro.locals.supabase
      .from('reviews')
      .select('id, rating, body, created_at, profiles:user_id(id, full_name, avatar_url)')
      .eq('listing_id', event.id)
      .order('created_at', { ascending: false })
  : { data: [] };

// Owner of this listing — used in the sidebar "Added By" card.
const owner = (detail as any).profiles ?? null;
const ownerName = owner?.full_name || 'Listing Owner';
const ownerAvatar = owner?.avatar_url || event.img1 || '/assets/img/team-1.jpg';
const reviewsList = (reviewRows ?? []).map((r: any) => ({
  id: r.id,
  name: r.profiles?.full_name || 'Anonymous',
  avatar: r.profiles?.avatar_url || '/assets/img/team-6.jpg',
  rating: r.rating,
  body: r.body,
  date: r.created_at ? new Date(r.created_at).toLocaleDateString() : '',
  iso: r.created_at || null,
}));

// --- SEO: title, description, structured data -----------------------------
const areaLabel = event.city || 'Rhodes';
const categoryLabel = event.name || 'Listing';
// Avoid "in Rhodes, Rhodes" when the listing has no specific area/city.
const placeInRhodes = areaLabel === 'Rhodes' ? 'Rhodes' : `${areaLabel}, Rhodes`;
const seoTitle = `${event.title} — ${categoryLabel} in ${placeInRhodes} | Rhodes Things To Do`;
const seoDescription = (event.desc && String(event.desc).trim())
  ? String(event.desc).replace(/\s+/g, ' ').trim().slice(0, 160)
  : `${event.title} — ${categoryLabel} in ${placeInRhodes}. See details, photos, location and reviews on Rhodes Things To Do.`;

// Map the listing category to the most specific Schema.org business type.
const TYPE_MAP: Record<string, string> = {
  restaurant: 'Restaurant',
  restaurants: 'Restaurant',
  'restaurants & tavernas': 'Restaurant',
  'restaurants & food': 'Restaurant',
  food: 'Restaurant',
  hotel: 'Hotel',
  hotels: 'Hotel',
  'hotels & stays': 'Hotel',
  accommodation: 'LodgingBusiness',
  accommodations: 'LodgingBusiness',
  spa: 'DaySpa',
  'spa & wellness': 'DaySpa',
  bar: 'BarOrPub',
  bars: 'BarOrPub',
  'bars & nightlife': 'BarOrPub',
  nightlife: 'BarOrPub',
  shopping: 'Store',
  store: 'Store',
  activities: 'TouristAttraction',
  tours: 'TouristAttraction',
  attraction: 'TouristAttraction',
  'things to do': 'TouristAttraction',
  beaches: 'Beach',
  transport: 'LocalBusiness',
  services: 'LocalBusiness',
};
const schemaType = TYPE_MAP[String(categoryLabel).toLowerCase()] || 'LocalBusiness';

const ratings = reviewsList.map((r) => Number(r.rating)).filter((n) => n > 0);
const avgRating = ratings.length
  ? Math.round((ratings.reduce((a, b) => a + b, 0) / ratings.length) * 10) / 10
  : null;

const listingUrl = absUrl(`/listing/${event.slug}/`);
const businessSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': schemaType,
  name: event.title,
  url: listingUrl,
  ...(event.desc ? { description: String(event.desc).replace(/\s+/g, ' ').trim() } : {}),
  ...(event.img ? { image: absUrl(event.img) } : {}),
  ...(event.number ? { telephone: event.number } : {}),
  address: {
    '@type': 'PostalAddress',
    ...(event.address ? { streetAddress: event.address } : {}),
    addressLocality: event.city || 'Rhodes',
    addressRegion: 'South Aegean',
    addressCountry: 'GR',
  },
  ...(event.lat != null && event.lng != null
    ? { geo: { '@type': 'GeoCoordinates', latitude: event.lat, longitude: event.lng } }
    : {}),
};
if (avgRating && ratings.length) {
  businessSchema.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: avgRating,
    reviewCount: ratings.length,
    bestRating: 5,
    worstRating: 1,
  };
  businessSchema.review = reviewsList
    .filter((r) => Number(r.rating) > 0)
    .slice(0, 10)
    .map((r) => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: r.name },
      reviewRating: { '@type': 'Rating', ratingValue: r.rating, bestRating: 5, worstRating: 1 },
      ...(r.iso ? { datePublished: new Date(r.iso).toISOString().slice(0, 10) } : {}),
      ...(r.body ? { reviewBody: r.body } : {}),
    }));
}
// Taxonomy links for breadcrumbs + chips (main category, subcategories, area, tags).
const tax = await getListingTaxonomy(Astro.locals.supabase, detail);
const motherCat = tax.mother;
const catHref = motherCat ? `/${motherCat.slug}/` : '/listings-grid/';
const areaHref = motherCat && tax.area ? `/${motherCat.slug}/${tax.area.slug}/` : null;

const crumbLinks = [
  { name: 'Home', href: '/' },
  motherCat ? { name: motherCat.name, href: catHref } : { name: 'Listings', href: '/listings-grid/' },
  ...(areaHref && tax.area ? [{ name: tax.area.name, href: areaHref }] : []),
  { name: event.title, href: `/listing/${event.slug}/` },
];
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbLinks.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.name,
    item: absUrl(c.href),
  })),
};
---
<Base
  title={seoTitle}
  description={seoDescription}
  canonical={`/listing/${event.slug}/`}
  ogImage={event.img || undefined}
  ogType="business.business"
  schema={[businessSchema, breadcrumbSchema]}
>
  <Navbar headerClass="header header-light" />

<Preloader />

<div class="clearfix"></div>

<!-- Property Detail Start -->
<section class="bg-cover position-relative ht-500 py-0" style={`background:url(${heroImg})no-repeat;`} data-overlay="4">
	<div class="container h-100">

		<!-- Components/Listings/Single-Listings/listing/gallery7.html -->
		<!-- Gallery Pert -->
		<div class="row align-items-start">
		    <div class="col-xl-12 col-lg-12 col-md-12 col-12">
		        <div class="mainlistingInfo">
		            <div class="d-flex align-items-end justify-content-between flex-wrap gap-3">
		                <div class="firstColumn">
		                    <div class="listingFirstinfo d-flex align-items-center justify-content-start gap-3 flex-wrap">
		                        
		                        <div class="listingCaptioninfo">
		                            <div class="propertyTitlename d-flex align-items-center gap-2 mb-1"><h2 class="fw-semibold text-light mb-0">
		                                {event.title || 'Christmas Monday'}
		                            </h2><span class="verified mt-1"><img src="/assets/img/tick.svg" class="img-fluid" width="22" alt="Verified Listing"></span></div>
		                            <div class="listingsbasicInfo">
		                                <div class="d-flex align-items-center justify-content-start flex-wrap gap-2">
		                                    <div class="flexItem me-2"><span class="text-md fw-medium text-light"><i class="fa-solid fa-location-dot me-2"></i>{event.location || event.city || 'Rhodes, Greece'}</span></div>
		                                    <div class="flexItem me-2"><span class="text-md fw-medium text-light"><i class="bi bi-briefcase me-2"></i>{event.name}</span></div>
		                                    <div class="flexItem">
		                                        <div class="d-flex align-items-center justify-content-start gap-2">
		                                            <div class="d-flex align-items-center justify-content-start gap-1">
		                                                <i class="bi bi-star-fill text-warning text-sm"></i><i class="bi bi-star-fill text-warning text-sm"></i><i class="bi bi-star-fill text-warning text-sm"></i><i class="bi bi-star-fill text-warning text-sm"></i><i class="bi bi-star-half text-warning text-sm"></i>
		                                            </div>
		                                            <span class="text-md fw-medium text-light">({event.reviews})</span>
		                                        </div>
		                                    </div>
		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>
		                <div class="lastColumn">
		                    <div class="d-flex align-items-center justify-content-md-end flex-wrap gap-3">
		                        <div class="flexStart Priceinfo d-flex flex-column">
		                            <span class="fw-medium text-light">Price</span>
		                            <span class="fw-bold text-md text-light">{event.dollar}</span>
		                        </div>
		                        {event.number && (
		                            <div class="flexlastButton"><a href={`tel:${event.number}`} class="btn px-4 btn-whites text-primary fw-medium rounded-pill"><i class="bi bi-telephone me-2"></i>{event.number}</a></div>
		                        )}
		                    </div>
		                </div>
		            </div>
		        </div>
		    </div>
		</div>

	</div>
</section>
<!-- Property Detail End -->

<!-- Breadcrumb -->
<section class="py-2 border-bottom bg-white">
	<div class="container">
		<nav aria-label="breadcrumb">
			<ol class="breadcrumb mb-0">
				{crumbLinks.map((c, i) => (
					i === crumbLinks.length - 1
						? <li class="breadcrumb-item active" aria-current="page">{c.name}</li>
						: <li class="breadcrumb-item"><a href={c.href}>{c.name}</a></li>
				))}
			</ol>
		</nav>
	</div>
</section>


<!-- All Section Content -->
<section class="gray-simple pt-4 pt-xl-5">
	<div data-bs-spy="scroll" data-bs-target="#scrollphyNav" data-bs-smooth-scroll="true" class="scrollspy-example" tabindex="0">
		<div class="container">
			<div class="row align-items-start gx-xl-5 g-4">

				<!-- Detail Row -->
				<div class="col-xl-8 col-lg-8 col-md-12 col-sm-12">

					<!-- Components/Listings/Single-Listings/listing/description2.html -->
					<!-- Description -->
					<div class="listingSingleblock mb-4">
					    <div class="SingleblockHeader">
					        <a data-bs-toggle="collapse" data-parent="#description" data-bs-target="#description" aria-controls="description" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Description</h4></a>
					    </div>

					    <div id="description" class="panel-collapse collapse show">
					        <div class="card-body p-4 pt-2">
					            <p>{event.desc || 'No description provided yet.'}</p>
					        </div>
					    </div>
					</div>

					<!-- Tags -->
					<div class="listingSingleblock mb-4">
						<div class="SingleblockHeader">
							<a data-bs-toggle="collapse" data-parent="#tags" data-bs-target="#tags" aria-controls="tags" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Tags</h4></a>
						</div>

						<div id="tags" class="panel-collapse collapse show">
							<div class="card-body p-4 pt-2">

								<!-- Interior Amenities -->
								<div class="interioramenities-block">
									<div class="interioramenities-body">
										<div class="row align-items-start justify-content-start g-3">

											<div class="col-12">
											    <div class="d-flex flex-wrap gap-2">
											        {motherCat && (<a href={catHref} class="badge rounded-pill bg-light-primary text-primary px-3 py-2">{motherCat.name}</a>)}
											        {tax.subcategories.map((s) => (
											            <a href={`/${s.motherSlug}/${s.slug}/`} class="badge rounded-pill bg-light-primary text-primary px-3 py-2">{s.name}</a>
											        ))}
											        {areaHref && tax.area && (<a href={areaHref} class="badge rounded-pill bg-light text-dark border px-3 py-2"><i class="bi bi-geo-alt me-1"></i>{tax.area.name}</a>)}
											        {tax.tags.map((t) => (<span class="badge rounded-pill bg-light text-dark border px-3 py-2">{t.name}</span>))}
											        {!motherCat && tax.subcategories.length === 0 && tax.tags.length === 0 && !tax.area && (<span class="text-muted">No tags yet.</span>)}
											    </div>
											</div>

										</div>
									</div>
								</div>
							</div>
						</div>
					</div>

					<!-- Gallery -->
					<div class="listingSingleblock mb-4" id="Galleries">
						<div class="SingleblockHeader">
							<a data-bs-toggle="collapse" data-parent="#gallery" data-bs-target="#gallery" aria-controls="gallery" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Gallery</h4></a>
						</div>

						<div id="gallery" class="panel-collapse collapse show">
							<div class="card-body p-4 pt-2">
								<ul class="row align-items-center justify-content-center g-3 p-0">

									<!-- Components/Listings/Single-Listings/single-listing-03/gallery6.html -->
									{gallerys3.map((item) => (
									<li class="col-xl-4 col-lg-4 col-md-6 col-sm-6 col-6">
									    <a href={item.img} class="mfp-gallery d-block"><img src={item.img} class="img-fluid rounded" alt="Gallery Img"></a>
									</li>
									))}

								</ul>
							</div>
						</div>
					</div>

					{event.lat !== null && event.lng !== null && (
						<div class="listingSingleblock mb-4" id="maps">
							<div class="SingleblockHeader">
								<a data-bs-toggle="collapse" data-parent="#map" data-bs-target="#map" aria-controls="map" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Location</h4></a>
							</div>
							<div id="map" class="panel-collapse collapse show">
								<div class="card-body p-4 pt-2">
									<div class="map-container rounded-3 overflow-hidden">
										<iframe
											src={`https://www.openstreetmap.org/export/embed.html?bbox=${Number(event.lng) - 0.01}%2C${Number(event.lat) - 0.01}%2C${Number(event.lng) + 0.01}%2C${Number(event.lat) + 0.01}&layer=mapnik&marker=${event.lat}%2C${event.lng}`}
											class="full-width"
											height="360"
											style="border:0;"
											loading="lazy"
											title={`Map for ${event.title}`}
										></iframe>
										<div class="text-md mt-2">
											<a href={`https://www.openstreetmap.org/?mlat=${event.lat}&mlon=${event.lng}&zoom=16`} target="_blank" rel="noopener" class="text-primary fw-medium">Open in OpenStreetMap</a>
											<span class="text-muted"> · {event.address || ''} {event.city ? `, ${event.city}` : ''}</span>
										</div>
									</div>
								</div>
							</div>
						</div>
					)}


					<!-- Reviews -->
					<div class="listingSingleblock mb-4" id="reviews">
						<div class="SingleblockHeader">
							<a data-bs-toggle="collapse" data-parent="#review" data-bs-target="#review" aria-controls="review" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Reviews</h4></a>
						</div>

						<div id="review" class="panel-collapse collapse show">
							<div class="card-body p-4 pt-2">
								<div class="allreviewsWrapper">
									<div class="reviewsTitle d-flex flex-column mb-3"><h5>{reviewsList.length === 0 ? 'No reviews yet' : `${reviewsList.length} Review${reviewsList.length === 1 ? '' : 's'}`}</h5></div>
									<div class="allreviewsLists mb-4">
										{reviewsList.map((r) => (
											<div class="singlereviews d-flex align-items-start justify-content-between flex-sm-wrap flex-wrap gap-3 mb-3">
												<div class="reviewerThumb">
													<div class="square--60 circle overflow-hidden"><img src={r.avatar} class="img-fluid circle" alt={r.name} /></div>
												</div>
												<div class="reviewerMessage">
													<div class="d-flex align-items-start justify-content-between gap-3 mb-3">
														<div class="reviewerInfo">
															<h6 class="mb-0">{r.name}</h6>
															<p class="text-md mb-0">Posted on {r.date}</p>
														</div>
														<div class="reviewsFlexlast">
															<div class="d-flex align-items-center justify-content-start gap-1">
																{Array.from({ length: 5 }).map((_, i) => (
																	<span><i class={`fa-solid fa-star text-sm ${i < r.rating ? 'text-warning active' : 'text-muted disabled'}`}></i></span>
																))}
															</div>
														</div>
													</div>
													<div class="messageDescription">
														<p>{r.body}</p>
													</div>
												</div>
											</div>
										))}
									</div>

									<!-- Review form -->
									<div class="reviewssubmition">
										{Astro.locals.user ? (
											<form action="/api/reviews" method="post" class="formRow">
												<input type="hidden" name="listing_id" value={event.id} />
												<div class="row align-items-start gx-xl-3 gx-lg-3">
													<div class="col-md-6">
														<div class="form-group">
															<label class="form-label">Rating</label>
															<select name="rating" required class="select form-control border">
																<option value="">Select Rating</option>
																<option value="1">1 Star - Very Poor</option>
																<option value="2">2 Star - Poor</option>
																<option value="3">3 Star - Medium</option>
																<option value="4">4 Star - Very Good</option>
																<option value="5" selected>5 Star - Excellent</option>
															</select>
														</div>
													</div>
													<div class="col-12">
														<div class="form-group">
															<textarea name="body" required minlength="10" class="form-control border" placeholder="Share your experience…" style="height: 120px"></textarea>
														</div>
													</div>
													<div class="col-12">
														<button type="submit" class="btn btn-primary fw-medium px-5">Submit Review</button>
													</div>
												</div>
											</form>
										) : (
											<div class="alert alert-light border">
												<a href={`/login/?next=${encodeURIComponent(`/listing/${event.slug}/`)}`} class="text-primary fw-medium">Sign in</a> to leave a review.
											</div>
										)}
									</div>

								</div>
							</div>
						</div>
					</div>

					<!-- Similar Items -->
					<div class="listingSingleblock">
						<div class="SingleblockHeader">
							<a data-bs-toggle="collapse" data-parent="#similar" data-bs-target="#similar" aria-controls="similar" href="#" aria-expanded="false" class="collapsed"><h4 class="listingcollapseTitle">Similar Lists</h4></a>
						</div>

						<div id="similar" class="panel-collapse collapse show">
							<div class="card-body p-4 pt-2">
								<div class="owl-carousel owl-theme similarSliders">

									<!-- Components/Home/home-3/listings2.html -->
									{listings2.slice(0, 8).map((item) => (
									<div class="singleItem">
									    <div class="listingitem-container">
									        <div class="singlelisting-item bg-light border-0">
									            <div class="listing-top-item">
									                <div class="position-absolute end-0 top-0 me-3 mt-3 z-2">
									                    <a href="#" class="bookmarkList" data-bs-toggle="tooltip" data-bs-title="Save Listing"><i class="bi bi-suit-heart m-0"></i></a>
									                </div>
									                <a href="#" class="topLink">
									                    <div class="position-absolute start-0 top-0 ms-3 mt-3 z-2">
									                        <div class="d-flex align-items-center justify-content-start gap-2">
									                            <span class={`badge badge-xs text-uppercase ${item.color}`}>{item.btn}</span>
									                            <span class="badge badge-xs badge-transparent">{item.dollar}</span>

									                            {item.tag && (
									                                <span class="badge badge-xs badge-transparent"><i class="bi bi-star mb-0 me-1"></i>Featured</span>
									                            )}

									                        </div>
									                    </div>
									                    <img src={item.img} class="img-fluid" alt="Listing Image">
									                </a>
									                <div class="opssListing position-absolute start-0 bottom-0 ms-3 mb-4 z-2">
									                    <div class="d-flex align-items-center justify-content-start gap-2">
									                        <div class="listing-details">
									                            <h4 class="listingTitle"><a href={`/listing/${slugify(item.title)}/`} class="titleLink">{item.title}<span class="verified"><i class="bi bi-patch-check-fill m-0"></i></span></a></h4>
									                            <div class="list-infos">
									                                <div class="d-flex align-items-center justify-content-start gap-3 mt-1">
									                                    <div class="list-distance text-light"><i class="bi bi-geo-alt mb-0 me-2"></i>{item.location}</div>
									                                    <div class="list-calls text-light hide-mob"><i class="bi bi-telephone mb-0 me-2"></i>{item.number}</div>
									                                </div>
									                            </div>
									                        </div>
									                    </div>
									                </div>
									            </div>
									            <div class="listing-footer-item border-0">
									                <div class="d-flex align-items-center justify-content-between gap-2">
									                    <div class="catdWraps">
									                        <div class="flex-start">
									                            <a href="#" class="d-flex align-items-center justify-content-start gap-2">
									                                <span class={item.span}><i class={item.icon}></i></span>
									                                <span class="catTitle">{item.name}</span>
									                            </a>
									                        </div>
									                    </div>
									                    <div class="listing-rates">
									                        <div class="d-flex align-items-center justify-content-start gap-2">
									                            <span class="d-flex align-items-center justify-content-start gap-1 text-sm">
									                                <i class="bi bi-star-fill mb-0 text-warning"></i><i class="bi bi-star-fill mb-0 text-warning"></i><i class="bi bi-star-fill mb-0 text-warning"></i><i class="bi bi-star-fill mb-0 text-warning"></i><i class="bi bi-star-half mb-0 text-warning"></i>
									                            </span>
									                            <span class="text-md text-muted-2 hide-mob">({(item as any).reviews})</span>
									                        </div>
									                    </div>
									                </div>
									            </div>
									        </div>
									    </div>
									</div>
									))}

								</div>
							</div>
						</div>
					</div>

				</div>

				<!-- Sidebar Detail -->
				<div class="col-xl-4 col-lg-4 col-md-12 col-sm-12">
					<div class="sidebarGroups d-flex flex-column gap-4">

						<!-- Author -->
						<div class="card">
							<div class="bg-cover card-header ht-150" style="background:url(/assets/img/avatar-bg.jpg)no-repeat;"></div>
							<div class="card-body mt-n3 p-0">
								<div class="avatarBox position-relative mb-4">
									<div class="square--100 circle bg-transparents mx-auto p-2 z-2"><img src={ownerAvatar} class="img-fluid circle" alt={ownerName} style="width:100%;height:100%;object-fit:cover;border-radius:50%;"></div>
									<div class="listingInfo text-center">
										<p class="text-md text-muted mb-0">Added By</p>
										<h6 class="mb-0">{ownerName}</h6>
									</div>
								</div>
								<div class="avatarInfo mb-2">

									<!-- Components/Listings/Single-Listings/single-listing-01/author.html -->
									{event.number && (
									<div class="py-3 px-3 border-top">
									    <div class="infoFlexio d-flex align-items-center justify-content-start gap-2">
									        <div class="square--40 rounded bg-light-primary"><i class="bi bi-telephone text-primary"></i></div>
									        <div class="infoDetails">
									            <p class="text-muted lh-base mb-0">Phone</p>
									            <p class="text-dark lh-base fw-medium fs-6 mb-0"><a href={`tel:${event.number}`} class="text-reset">{event.number}</a></p>
									        </div>
									    </div>
									</div>
									)}
									{event.address && (
									<div class="py-3 px-3 border-top">
									    <div class="infoFlexio d-flex align-items-center justify-content-start gap-2">
									        <div class="square--40 rounded bg-light-primary"><i class="bi bi-geo-alt text-primary"></i></div>
									        <div class="infoDetails">
									            <p class="text-muted lh-base mb-0">Address</p>
									            <p class="text-dark lh-base fw-medium fs-6 mb-0">{event.address}{event.city ? `, ${event.city}` : ''}</p>
									        </div>
									    </div>
									</div>
									)}
									<div class="py-3 px-3 border-top">
									    <div class="infoFlexio d-flex align-items-center justify-content-start gap-2">
									        <div class="square--40 rounded bg-light-primary"><i class="bi bi-tag text-primary"></i></div>
									        <div class="infoDetails">
									            <p class="text-muted lh-base mb-0">Category</p>
									            <p class="text-dark lh-base fw-medium fs-6 mb-0">{motherCat ? (<a href={catHref} class="text-reset">{motherCat.name}</a>) : event.name}</p>
									        </div>
									    </div>
									</div>

								</div>
							</div>
							<div class="card-footer bg-white border-top">
								<div class="d-flex align-items-center justify-content-center gap-3">
									<div class="flexSocial"><a href="#" class="square--40 circle border"><i class="bi bi-facebook color--facebook"></i></a></div>
									<div class="flexSocial"><a href="#" class="square--40 circle border"><i class="bi bi-twitter color--twitter"></i></a></div>
									<div class="flexSocial"><a href="#" class="square--40 circle border"><i class="bi bi-instagram color--instagram"></i></a></div>
									<div class="flexSocial"><a href="#" class="square--40 circle border"><i class="bi bi-youtube color--pinterest"></i></a></div>
									<div class="flexSocial"><a href="#" class="square--40 circle border"><i class="bi bi-whatsapp color--whatsapp"></i></a></div>
								</div>
							</div>
						</div>


						{/* Booking + payment flow hidden until we wire up real payments. The card markup is kept in source for easy re-enable. */}
						{false && (
						<div class="card overflow-visible">
							<div class="card-header py-3">
								<div class="headerFirst"><h6><i class="bi bi-calendar-check me-2"></i>Booking Rooms</h6></div>
							</div>
							<div class="p-xl-4 p-3">
								<div class="contactForm position-relative">
									<div class="form-group">
										<input type="text" class="form-control fw-medium" id="input" placeholder="Choose A Date">
									</div>
									<div class="form-group">
										<div class="position-relative fw-medium">
											<select class="choosetime form-control">
												<option label="option"></option>
												<option value="lv">07:00 AM</option>
												<option value="la">07:30 AM</option>
												<option value="kc">08:00 AM</option>
												<option value="no">08:30 AM</option>
												<option value="kc">09:00 AM</option>
												<option value="lb">09:30 AM</option>
												<option value="cl">10:30 AM</option>
												<option value="cn">11:30 AM</option>
												<option value="cg">12:00 PM</option>
											</select>
										</div>
									</div>
									<div class="form-group">
										<div class="booking-form__input guests-input mixer-auto">
											<button name="guests-btn" id="guests-input-btn">1 Guest</button>
											<div class="guests-input__options" id="guests-input-options">
												<div>
													<span class="guests-input__ctrl minus" id="adults-subs-btn"><i class="fa-solid fa-minus"></i></span>
													<span class="guests-input__value"><span id="guests-count-adults">1</span>Adults</span>
													<span class="guests-input__ctrl plus" id="adults-add-btn"><i class="fa-solid fa-plus"></i></span>
												</div>
												<div>
													<span class="guests-input__ctrl minus" id="children-subs-btn"><i class="fa-solid fa-minus"></i></span>
													<span class="guests-input__value"><span id="guests-count-children">0</span>Children</span>
													<span class="guests-input__ctrl plus" id="children-add-btn"><i class="fa-solid fa-plus"></i></span>
												</div>
											</div>
										</div>
									</div>
									<div class="form-group">
										<a href={`/booking-page/?slug=${event.slug}`} class="btn btn-primary rounded-pill fw-medium w-100">Booking Request</a>
									</div>
								</div>
							</div>

						</div>
						)}
						<!-- Booking Form End -->

						<!-- Request Booking -->
						<div class="card">
							<div class="card-body p-4 text-center">
								<h6 class="fw-medium mb-2">Interested in this place?</h6>
								<p class="text-md text-muted mb-3">Send a booking request — no payment now, the host confirms.</p>
								{Astro.locals.user ? (
									<a href={`/booking-page/?slug=${event.slug}`} class="btn btn-primary rounded-pill w-100"><i class="bi bi-calendar2-check me-2"></i>Request Booking</a>
								) : (
									<a href={`/login/?next=${encodeURIComponent(`/booking-page/?slug=${event.slug}`)}`} class="btn btn-primary rounded-pill w-100"><i class="bi bi-calendar2-check me-2"></i>Sign in to Book</a>
								)}
							</div>
						</div>

						<!-- Share option -->
						<div class="card">

							<div class="card-body px-3">
								<div class="form-group mb-1">
									{Astro.locals.user ? (
											<form action={`/api/bookmarks/${event.id}`} method="post">
												<input type="hidden" name="_action" value="toggle" />
												<input type="hidden" name="return_to" value={`/listing/${event.slug}/`} />
												<button type="submit" class="btn btn-whites border rounded-pill fw-medium w-100"><i class="bi bi-suit-heart me-2"></i>Bookmark This Listing</button>
											</form>
										) : (
											<a href={`/login/?next=${encodeURIComponent(`/listing/${event.slug}/`)}`} class="btn btn-whites border rounded-pill fw-medium w-100"><i class="bi bi-suit-heart me-2"></i>Sign in to Bookmark</a>
										)}
								</div>
								<div class="form-group text-center mb-4">
									<p class="text-md">45 People Bookmark This Place</p>
								</div>
								<div class="form-group m-0">
									<div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
										<button type="button" class="btn btn-md btn-whites border rounded-pill color--facebook flex-fill"><i class="bi bi-suit-heart me-1"></i>Facebook</button>
										<button type="button" class="btn btn-md btn-whites border rounded-pill color--twitter flex-fill"><i class="bi bi-suit-heart me-1"></i>Twitter</button>
										<button type="button" class="btn btn-md btn-whites border rounded-pill color--instagram flex-fill"><i class="bi bi-suit-heart me-1"></i>Instagram</button>
									</div>
								</div>
							</div>
						</div>

					</div>
				</div>

			</div>

		</div>
	</div>
</section>
<!-- All Section Content -->

<!-- Call To Action Start -->

