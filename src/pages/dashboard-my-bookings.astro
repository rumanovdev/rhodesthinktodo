---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';
export const prerender = false;

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase;

const { data: bookingRows } = supabase
  ? await supabase
      .from('bookings')
      .select('id, start_date, end_date, guests, status, total, contact_name, contact_phone, created_at, listings(id, title, slug, city, hero_image, listing_images(url))')
      .eq('user_id', user.id)
      .order('created_at', { ascending: false })
  : { data: [] };

const bookings = (bookingRows ?? []).map((b: any) => ({
  id: b.id,
  title: b.listings?.title ?? 'Listing removed',
  slug: b.listings?.slug ?? null,
  img: b.listings?.hero_image || b.listings?.listing_images?.[0]?.url || '/assets/img/list-1.jpg',
  name: b.listings?.city ?? '',
  date: b.start_date ?? '—',
  info: `${b.guests} guest${b.guests === 1 ? '' : 's'}${b.end_date ? ` · until ${b.end_date}` : ''}`,
  client: b.contact_name ?? '',
  contact: b.contact_phone ?? '',
  price: b.total ? `$${b.total}` : '—',
  status: b.status ?? 'pending',
}));
---
<Base title="My Bookings - ThinksToDo">
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <!-- Dashboard Start -->
  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0">

        <!-- Dashboard Sidebar -->
        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="my-bookings" />
        </div>

        <!-- Dashboard Content -->
        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">

            <!-- Dashboard Title -->
            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0">
              <h2 class="fw-medium mb-0">Recent Bookings</h2>
            </div>

            <!-- Dashboard Details -->
            <div class="dashCaption p-xl-5 p-3 p-md-4">

              <!-- Row Start -->
              <div class="row align-items-start g-4 mb-lg-5 mb-4">
                <div class="col-xl-12 col-lg-12 col-md-12">
                  <div class="card rounded-3 shadow-sm">
                    <div class="card-header px-4 py-3">
                      <h4 class="m-0">Recent Bookings</h4>
                    </div>
                    <div class="card-body p-0">
                      {bookings.length === 0 ? (
                        <div class="p-4 text-center">
                          <p class="text-muted mb-3">You haven't booked any listings yet.</p>
                          <a href="/listings/" class="btn btn-primary rounded-pill fw-medium">Browse Listings</a>
                        </div>
                      ) : (
                        <ul class="dashboardListgroup">
                          {bookings.map((item) => (
                            <li>
                              <div class="bookingActivities">
                                <div class="d-flex align-items-start justify-content-start gap-3 flex-wrap">
                                  <div class="bookingAvatar">
                                    <figure class="m-0"><img src={item.img} class="img-fluid circle avatar-xl" alt={item.title} /></figure>
                                  </div>
                                  <div class="bookingInfo">
                                    <div class="bookingTitle">
                                      <h5 class="titlesName">
                                        {item.slug ? <a href={`/listing/${item.slug}/`}>{item.title}</a> : item.title}
                                        {item.name && <span class="Bookscats">{item.name}</span>}
                                      </h5>
                                      <div class="d-flex align-items-center justify-content-start gap-2">
                                        {item.status === 'pending' && <span class="badge badge-xs pending rounded-pill">Pending</span>}
                                        {item.status === 'confirmed' && <span class="badge badge-xs approved rounded-pill">Confirmed</span>}
                                        {item.status === 'cancelled' && <span class="badge badge-xs cancelled rounded-pill">Cancelled</span>}
                                        {item.status === 'completed' && <span class="badge badge-xs approved rounded-pill">Completed</span>}
                                      </div>
                                    </div>
                                    <div class="bookingDetails">
                                      <div class="singledetailInfo"><span class="listTitle">Date</span>{item.date}</div>
                                      <div class="singledetailInfo"><span class="listTitle">Info</span>{item.info}</div>
                                      <div class="singledetailInfo"><span class="listTitle">Name</span>{item.client || '—'}</div>
                                      <div class="singledetailInfo"><span class="listTitle">Contact</span>{item.contact || '—'}</div>
                                      <div class="singledetailInfo"><span class="listTitle">Total</span>{item.price}</div>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  </div>
                </div>

              </div>
              <!-- Row End -->

              <!-- Row Start -->
              <div class="row align-items-start g-4">
                <div class="col-xl-12 col-lg-12 col-md-12">
                  <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> ThinksToDo.</p>
                </div>
              </div>

            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- Dashboard End -->


  <!-- Components/Home/index/cart.html -->
  <!-- Components/Listings/Single-Listings/single-listing-01/message.html -->
  <!-- Message Modal -->
  <div class="modal modal-lg fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-light border-0 px-md-5">
          <h4 class="modal-title fw-medium" id="messageModalLabel">Send Message</h4>
          <a href="#" data-bs-dismiss="modal" aria-label="Close" class="square--40 circle bg-light-danger text-danger"><i class="bi bi-x"></i></a>
        </div>
        <div class="modal-body p-md-5">
          <div class="messageForm">
            <div class="form-group">
              <textarea class="form-control" placeholder="Type your Message To Dan"></textarea>
            </div>
            <button type="button" class="btn btn-primary fw-medium px-md-5">Send message<i class="bi bi-arrow-right ms-2"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Components/Home/index/search.html -->
  <SearchOffcanvas />


  <!-- Components/Home/index/log.html -->
  <LoginModal />


  <Footer />
</Base>
</content>
</invoke>