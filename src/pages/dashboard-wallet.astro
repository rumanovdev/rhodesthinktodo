---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';
import { rows2, earnings } from '../lib/data/context';
export const prerender = false;
---
<Base title="Wallet - ThinksToDo">
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <!-- Dashboard Start -->
  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0 pt-lg-0 pt-5">

        <!-- Dashboard Sidebar -->
        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="wallet" />
        </div>

        <!-- Dashboard Content -->
        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">

            <!-- Dashboard Title -->
            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0">
              <h2 class="fw-medium mb-0">Wallet</h2>
            </div>

            <!-- Dashboard Details -->
            <div class="dashCaption p-xl-5 p-3 p-md-4">

              <!-- Row Start -->
              <div class="row align-items-start g-4 mb-4">
                <div class="col-xl-12 col-lg-12 col-md-12 col-sm-12">
                  <div class="alert alert-success alert-dismissible fade show" role="alert">
                    Your last payout <strong>$450 USD</strong> has been withdrawa!.
                    <button type="button" class="btn-close text-sm text-primary" data-bs-dismiss="alert" aria-label="Close"></button>
                  </div>
                </div>
              </div>
              <!-- Row End -->

              <!-- Row Start -->
              <div class="row align-items-start g-4 mb-lg-5 mb-4">

                <!-- Components/User-Dashboard/dashboard-wallet/row2.html -->
                {rows2.map((item: any) => (
                  <div class="col-xl-4 col-lg-4 col-md-6 col-sm-12">
                    <div class="card rounded-3 position-relative p-4">
                      <div class={`position-absolute w-30 h-100 ${item.style} start-0 top-0 rounded-end-pill`}><div class="position-absolute top-50 start-50 translate-middle"><i class={`${item.icon} text-white fs-2`}></i></div></div>
                      <div class="d-flex flex-column align-items-end justify-content-end ht-80">
                        <h2 class="mb-0"><span class="ctr counter-value" data-target={item.number}>{item.price}</span></h2>
                        <p class="text-muted-2 fw-medium mb-0">{item.title}</p>
                      </div>
                    </div>
                  </div>
                ))}

              </div>
              <!-- Row End -->

              <!-- Row Start -->
              <div class="row align-items-start g-4 mb-lg-5 mb-4">
                <div class="col-xl-12 col-lg-12 col-md-12">
                  <div class="card rounded-3 shadow-sm">
                    <div class="card-header flex-wrap gap-3 px-4">
                      <div class="cardTitle"><h4>Your Earning</h4></div>

                      <div class="headerInformations">
                        <div class="d-flex align-items-center justify-content-start justify-content-md-between flex-wrap gap-3">
                          <div class="singleCaps">
                            <div class="form-group position-relative m-0">
                              <input type="text" class="form-control form-control-md bg-light border-0 ps-5" placeholder="Search any parameters..." />
                              <span class="position-absolute top-50 start-0 translate-middle-y ms-3"><i class="fa-solid fa-magnifying-glass"></i></span>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div class="card-body p-3">
                      <table class="table">
                        <thead>
                          <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Order ID</th>
                            <th scope="col">Date</th>
                            <th scope="col">Amount</th>
                            <th scope="col">Fee</th>
                          </tr>
                        </thead>

                        <tbody>

                          <!-- Components/User-Dashboard/dashboard-wallet/earning.html -->
                          {earnings.map((item: any) => (
                            <tr>
                              <td data-label="Name">{item.title}</td>
                              <td data-label="Order ID">{item.id}</td>
                              <td data-label="Date"><span class="text-normal">{item.date}</span></td>
                              <td data-label="Amount"><span class="fw-medium text-dark">{item.amount}</span></td>
                              <td data-label="View"><span class="fw-medium text-danger">{item.fee}</span></td>
                            </tr>
                          ))}

                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
              <!-- Row End -->

              <!-- Row Start -->
              <div class="row align-items-start g-4">
                <div class="col-xl-12 col-lg-12 col-md-12">
                  <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> ThinksToDo.</p>
                </div>
              </div>

            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- Dashboard End -->

  <!-- Components/Home/index/cart.html -->
  <!-- Components/Home/index/search.html -->
  <SearchOffcanvas />


  <!-- Components/Home/index/log.html -->
  <LoginModal />


  <Footer />
</Base>
</content>
</invoke>