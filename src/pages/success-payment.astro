---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const user = Astro.locals.user;
const bookingId = Astro.url.searchParams.get('booking');

let booking: any = null;
if (supabase && user && bookingId) {
  const { data } = await supabase
    .from('bookings')
    .select('id, start_date, end_date, guests, status, created_at, listings(title, slug)')
    .eq('id', bookingId)
    .eq('user_id', user.id)
    .maybeSingle();
  booking = data;
}
---
<Base noindex title="Booking Received - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Payment Info Start -->
<section class="bg-cover" style="background: #ffe8ee url(/assets/img/auth-bg.png) no-repeat;">
	<div class="container">
		<div class="row align-items-center justify-content-center pt-lg-0 pt-5">
			<div class="col-xl-5 col-lg-7 col-md-9">
				<div class="confirmsWrap">

					<div class="confirmsbody d-black mb-4">
						<div class="card rounded-4 p-sm-5 p-4">
							<div class="card-body p-0">


								<!-- Title -->
								<div class="checkBox">
									<span class="check"><i class="bi bi-patch-check-fill"></i></span>
								</div>

								<div class="confirmsHeads">
									<h3 class="successTitle">Booking Received!</h3>
									<p class="successSubtitle">{booking?.listings?.title
										? `We've sent your request to ${booking.listings.title}. The host will confirm shortly.`
										: 'Your booking request has been received.'}</p>
								</div>

								{booking ? (
									<div class="confirmsInfo">
										<ul>
											<li>
												<span class="headTitle">Booking ID</span>
												<span class="headCaps">{booking.id.slice(0, 8)}…</span>
											</li>
											<li>
												<span class="headTitle">Status</span>
												<span class="headCaps"><i class="bi bi-clock-history text-warning me-1"></i>{booking.status}</span>
											</li>
											<li>
												<span class="headTitle">Date</span>
												<span class="headCaps">{booking.start_date ?? '—'}</span>
											</li>
											<li>
												<span class="headTitle">Guests</span>
												<span class="headCaps">{booking.guests}</span>
											</li>
										</ul>
										<div class="d-flex gap-2 mt-3 justify-content-center flex-wrap">
											{booking.listings?.slug && <a href={`/listing/${booking.listings.slug}/`} class="btn btn-light rounded-pill btn-sm">View Listing</a>}
											<a href="/dashboard-my-bookings/" class="btn btn-primary rounded-pill btn-sm">My Bookings</a>
										</div>
									</div>
								) : (
									<div class="text-center mt-4">
										<a href="/listings/" class="btn btn-primary rounded-pill">Browse Listings</a>
									</div>
								)}

							</div>

						</div>
					</div>

				</div>

			</div>
		</div>
	</div>
</section>
<!-- Payment Info End -->


<!-- Call To Action Start -->

<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<Footer />
</Base>
