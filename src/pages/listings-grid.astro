---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { slistings, categories3, amenities } from '../lib/data/context';
import { getPublishedListings, slugify } from '../lib/supabase/listings';
export const prerender = false;

const listings = await getPublishedListings(Astro.locals.supabase);
---
<Base
  title="Browse Listings in Rhodes — Restaurants, Hotels & Activities | Rhodes Things To Do"
  description="Browse all listings in Rhodes, Greece — restaurants, hotels, tours, activities, bars, shopping and wellness. Filter by category and find top-rated places."
  canonical="/listings-grid/"
>
  <Navbar headerClass="header header-light" />

<Preloader />

<div class="clearfix"></div>

<!-- Hero Search Form Start -->
<div class="image-cover hero-banner overflow-hidden py-5" style="background:#ffe8ee url(/assets/img/title-bg.png)no-repeat;">
	<div class="container">

	<!-- Banner Title -->
	<div class="row justify-content-start align-items-start pt-lg-0 pt-5">
		<div class="col-xl-8 col-lg-10 col-md-12 col-sm-12">
		<div class="position-relative text-start py-4">
			<h2>Get Your Dream Places</h2>
			<div class="heroSearch rounded-search style-01 mt-4">
				<div class="row gx-lg-2 gx-md-2 gx-3 gy-sm-2 gy-2">
					<div class="col-xl-10 col-lg-9 col-md-12">
						<div class="row gx-lg-2 gx-md-2 gx-3 gy-sm-2 gy-2">
							<div class="col-xl-6 col-lg-6 col-md-12 col-sm-12">
								<div class="form-group">
									<div class="mobSearch d-flex align-items-center justify-content-start">
										<div class="flexStart ps-2"><span class="fw-semibold text-dark">Find</span></div>
										<input type="text" class="form-control fs-6 fw-medium border-0" placeholder="What are you looking for?">
									</div>
								</div>
							</div>
							<div class="col-xl-6 col-lg-6 col-md-12 col-sm-12 single-border">
								<div class="form-group">
									<div class="mobSearch d-flex align-items-center justify-content-start">
										<div class="flexStart ps-2"><span class="fw-semibold text-dark">Where</span></div>
										<input type="text" class="form-control fs-6 fw-medium border-0" placeholder="Location">
									</div>
								</div>
							</div>
						</div>
					</div>
					<div class="col-xl-2 col-lg-3 col-md-12 col-sm-12">
						<div class="form-group">
							<button type="button" class="btn btn-primary rounded-pill full-width fw-medium"><i class="bi bi-search me-2"></i>Search</button>
						</div>
					</div>
				</div>
			</div>
		</div>
		</div>
	</div>
	<!-- Banner Title -->

	</div>
</div>
<!-- Hero Search Form End -->

<!-- Search List Start -->
<section class="py-5">
	<div class="container">
		<div class="row align-items-start justify-content-between g-4">

			<!-- Components/Listings/Grid-Layouts/listings-grid/sidebar.html -->
			<!-- Search Sidebar -->
			<div class="col-xl-4 col-lg-4 col-md-12 col-sm-12">

			    <div class="searchingSidebar pe-xl-5">

			        <div class="offcanvas offcanvas-start largeshow" data-bs-scroll="true" tabindex="-1" id="filterSlider" aria-labelledby="filterSliderLabel">
			            <div class="offcanvas-header border-bottom py-3">
			                <h3 class="h5">Filters</h3>
			                <button type="button" class="btn-close text-sm d-lg-none" data-bs-dismiss="offcanvas" data-bs-target="#filterSidebar" aria-label="Close"></button>
			            </div>
			            <div class="offcanvas-body overflow-x-hidden p-4 p-lg-0" id="filterSliderLabel">

			                <!-- Options -->
			                <div class="searchInner">

			                    <div class="search-inner">

			                        <div class="filter-search-box mb-4">
			                            <div class="form-group">
			                                <input type="text" class="form-control" placeholder="Search listing..">
			                            </div>
			                        </div>

			                        <div class="prtsTypes mb-4">
			                            <div class="filterButton">

			                                <div class="filterFlex">
			                                    <input type="radio" class="btn-check" name="ratingsfilter" id="all" checked>
			                                    <label class="btn" for="all"><i class="bi bi-star-fill me-1"></i>All</label>
			                                </div>

			                                <div class="filterFlex">
			                                    <input type="radio" class="btn-check" name="ratingsfilter" id="threeplus">
			                                    <label class="btn" for="threeplus"><i class="bi bi-star-fill me-1"></i>3.0+</label>
			                                </div>

			                                <div class="filterFlex">
			                                    <input type="radio" class="btn-check" name="ratingsfilter" id="fourplus">
			                                    <label class="btn" for="fourplus"><i class="bi bi-star-fill me-1"></i>4.0+</label>
			                                </div>

			                                <div class="filterFlex">
			                                    <input type="radio" class="btn-check" name="ratingsfilter" id="fiveplus">
			                                    <label class="btn" for="fiveplus"><i class="bi bi-star-fill me-1"></i>5.0</label>
			                                </div>

			                            </div>
			                        </div>

			                        <!-- Categories -->
			                        <div class="filter-search-box mb-4">
			                            <div class="filtersearch-title"><h6 class="mb-2 lh-base text-sm text-uppercase fw-medium">Categories</h6></div>
			                            <div class="row align-items-center justify-content-between gy-2">
			                                <div class="col-xl-12 col-lg-12 col-md-12">
			                                    <div class="d-flex align-items-center justify-content-center flex-wrap gap-2 mb-3">

			                                        <!-- Components/Listings/Grid-Layouts/grid-layout-01/categories.html -->
			                                        {categories3.map((item) => (
			                                        <div class="form-checks flex-fill">
			                                            <input type="checkbox" class="btn-check" id={item.id} checked={item.check === 'checked'}>
			                                            <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for={item.id}>{item.title}</label>
			                                        </div>
			                                        ))}

			                                    </div>
			                                </div>
			                            </div>
			                        </div>

			                        <!-- Price Range -->
			                        <div class="filter-search-box mb-4">
			                            <div class="filtersearch-title"><h6 class="mb-2 lh-base text-sm text-uppercase fw-medium">Price Range in USD</h6></div>
			                            <div class="row align-items-center justify-content-between">
			                                <div class="col-12">
			                                    <div class="searchBar-single-wrap mt-2">
			                                        <input type="text" class="pricefilter" name="my_range" value="" data-skin="round"
			                                            data-type="double" data-min="0" data-max="500" data-grid="false">
			                                    </div>
			                                </div>
			                            </div>
			                        </div>

			                        <!-- Price Range -->
			                        <div class="filter-search-box mb-4">
			                            <div class="filtersearch-title"><h6 class="mb-2 lh-base text-sm text-uppercase fw-medium">Distance Filter in Km</h6></div>
			                            <div class="row align-items-center justify-content-between">
			                                <div class="col-12">
			                                    <div class="searchBar-single-wrap mt-2">
			                                        <input type="text" class="distancefilter" name="my_range" value="" data-skin="round"
			                                        data-type="single" data-grid="false">
			                                    </div>
			                                </div>
			                            </div>
			                        </div>

			                        <!-- More Filter -->
			                        <div class="filter-search-box mb-4">
			                        <div class="filtersearch-title"><h6 class="mb-2 lh-base text-sm text-uppercase fw-medium">Amenities</h6></div>
			                            <div class="row align-items-center justify-content-between gy-2">

			                                <!-- Components/Listings/Grid-Layouts/grid-layout-01/amenities.html -->
			                                {amenities.map((item) => (
			                                <div class="col-6">
			                                    <div class="form-check">
			                                        <input class="form-check-input" type="checkbox" id={item.id}>
			                                        <label class="form-check-label" for={item.id}>{item.title}</label>
			                                    </div>
			                                </div>
			                                ))}

			                            </div>
			                        </div>

			                        <div class="form-group filter_button mb-0">
			                            <button type="submit" class="btn btn-primary fw-medium full-width">Save & Update</button>
			                        </div>
			                    </div>
			                </div>
			            </div>

			        </div>
			    </div>

			</div>
			<!-- Sidebar End -->

			<div class="col-xl-8 col-lg-8 col-md-12 col-sm-12">

				<div class="row align-items-center justify-content-between mb-4">
					<div class="col-xl- 5 col-lg-5 col-md-5 col-sm-6 col-6">
						<div class="viewOptions">
							<ul class="nav nav-pills nav-fill gap-2 small d-inline-flex primary-soft rounded-2">
								<li class="nav-item" role="presentation">
								<a href="/listings/" class="nav-link rounded-2" id="listViews" role="tab" aria-selected="false"><i class="bi bi-list me-2"></i>List</a>
								</li>
								<li class="nav-item" role="presentation">
								<a href="/listings-grid/" class="nav-link rounded-2 active" id="gridViews" role="tab" aria-selected="true"><i class="bi bi-ui-radios-grid me-2"></i>Grid</a>
								</li>
								<li class="nav-item" role="presentation">
								<a href="/listings-map/" class="nav-link rounded-2" id="mapViews" role="tab" aria-selected="false"><i class="bi bi-geo-alt me-2"></i>Map</a>
								</li>
							</ul>
						</div>
					</div>

					<div class="col-xl- 5 col-lg-5 col-md-5 col-sm-6 col-6">
						<div class="text-end">
							<!-- Rating Filter -->
							<div class="dropdown d-inline-flex p-0">
								<a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="shortfilter" data-bs-toggle="dropdown" aria-expanded="false">
									Short Listings
								</a>
								<div class="dropdown-menu border shadow-sm">
									<ul class="card rounded-0 p-0">

										<!-- Components/Listings/Grid-Layouts/grid-layout-01/short-listings.html -->
										{slistings.map((item) => (
										<li><a class={`${item.class} dropdown-item`} href="#">{item.title}</a></li>
										))}

									</ul>
								</div>
							</div>
						</div>
					</div>
				</div>

				<div class="row align-items-center justify-content-center g-xl-4 g-3">

					<!-- Components/Listings/Grid-Layouts/grid-layout-01/listings4.html -->
					{listings.map((item) => (
					<div class="col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
					    <div class="listingitem-container">
					        <div class="singlelisting-item">
					            <div class="listing-top-item">
					                <a href="#" class="topLink">
					                    <div class="position-absolute start-0 top-0 ms-3 mt-3 z-2">
					                        <div class="d-flex align-items-center justify-content-start gap-2">
					                            <span class={`badge badge-xs text-uppercase ${item.color}`}>{item.btn}</span>
					                            <span class="badge badge-xs badge-transparent">{item.dollar}</span>

					                            {item.tag === 'true' && (
					                                <span class="badge badge-xs badge-transparent"><i class="bi bi-star mb-0 me-1"></i>{item.btn1}</span>
					                            )}

					                        </div>
					                    </div>
					                    <img src={item.img} class="img-fluid" alt="Listing Image">
					                </a>
					                <div class="position-absolute end-0 bottom-0 me-3 mb-3 z-2">
					                    <a href="#" class="bookmarkList" data-bs-toggle="tooltip" data-bs-title="Save Listing"><i class="bi bi-suit-heart m-0"></i></a>
					                </div>
					            </div>
					            <div class="listing-middle-item">
					                <div class="listing-avatar">
					                    <a href="#" class="avatarImg"><img src={item.img1} class="img-fluid circle" alt="Avatar"></a>
					                </div>
					                <div class="listing-details">
					                    <h4 class="listingTitle"><a href={`/listing/${slugify(item.title)}/`} class="titleLink">{item.title}<span class="verified"><i class="bi bi-patch-check-fill m-0"></i></span></a></h4>
					                    <p>{item.desc}</p>
					                </div>
					                <div class="listing-info-details">
					                    <div class="d-flex align-items-center justify-content-start gap-4">
					                        <div class="list-calls"><i class="bi bi-telephone mb-0 me-2"></i>{item.number}</div>
					                        <div class="list-distance"><i class="bi bi-geo-alt mb-0 me-2"></i>{item.miles}</div>
					                    </div>
					                </div>
					            </div>
					            <div class="listing-footer-item">
					                <div class="d-flex align-items-center justify-content-between gap-2">
					                    <div class="catdWraps">
					                        <div class="flex-start">
					                            <a href="#" class="d-flex align-items-center justify-content-start gap-2">
					                                <span class={item.span}><i class={item.icon}></i></span>
					                                <span class="catTitle">{item.name}</span>
					                            </a>
					                        </div>
					                        <div class="flex-end"><span class="moreCatcounter">{item.plus}</span></div>
					                    </div>
					                    <div class="listing-rates">
					                        <div class="d-flex align-items-center justify-content-start gap-1">
					                            <span class={`ratingAvarage ${item.avarage}`}>{item.rating}</span>
					                            <span class="overallrates">{item.reviews}</span>
					                        </div>
					                    </div>
					                </div>
					            </div>
					        </div>
					    </div>
					</div>
					))}

				</div>

				<!-- Components/Listings/Grid-Layouts/grid-layout-01/pagination.html -->
				<!-- Pagination Start -->
				<div class="row align-items-center justify-content-center mt-5">
				    <div class="col-xl-12 col-lg-12 col-md-12">
				        <nav aria-label="Page navigation example">
				          <ul class="pagination justify-content-center">
				            <li class="page-item">
				              <a class="page-link"><i class="fa-solid fa-arrow-left"></i></a>
				            </li>
				            <li class="page-item"><a class="page-link" href="#">1</a></li>
				            <li class="page-item active"><a class="page-link" href="#">2</a></li>
				            <li class="page-item"><a class="page-link" href="#">3</a></li>
				            <li class="page-item"><a class="page-link" href="#">4</a></li>
				            <li class="page-item"><a class="page-link" href="#">5</a></li>
				            <li class="page-item">
				              <a class="page-link" href="#"><i class="fa-solid fa-arrow-right"></i></a>
				            </li>
				          </ul>
				        </nav>
				    </div>
				</div>
				<!-- Pagination END -->

			</div>

		</div>
	</div>
</section>
<!-- Search List End -->

<!-- Call To Action Start -->

<!-- Call To Action Start -->

	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />

	<a href="#filterSlider" data-bs-toggle="offcanvas" data-bs-target="#filterSlider" aria-controls="filterSlider" class="fixed-bottom z-sticky d-lg-none filterButtons"><i class="bi bi-funnel"></i>Filter Options</a>

  <Footer />
</Base>
