---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';
import { getMyProfile } from '../lib/supabase/profiles';
export const prerender = false;

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;
const profile = await getMyProfile(supabase, user.id);

const social = (profile?.social_links as Record<string, string | null> | null) ?? {};

const p = Astro.url.searchParams;
const error = p.get('error');
const notice = p.get('notice');
const pwError = p.get('pwerror');
const pwNotice = p.get('pwnotice');
const emailError = p.get('emailerror');
const emailNotice = p.get('emailnotice');
const delError = p.get('delerror');
---
<Base noindex title="My Profile - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />
  <Preloader />

  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0 pt-lg-0 pt-5">

        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="my-profile" />
        </div>

        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">
            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0">
              <h2 class="fw-medium mb-0">My Profile</h2>
              <p class="text-muted mt-2 mb-0">Update your personal details, change your email or password, or close your account.</p>
            </div>

            <div class="dashCaption p-xl-5 p-3 p-md-4">

              {notice && <div class="alert alert-success">{notice}</div>}
              {error && <div class="alert alert-danger">{error}</div>}

              <form action="/api/profile" method="post" enctype="multipart/form-data" class="row align-items-start g-4 mb-lg-5 mb-4">
                <div class="col-xl-9 col-lg-8">

                  <div class="card rounded-3 shadow-sm">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Profile</h4></div>
                    <div class="card-body">
                      <div class="row g-3">
                        <div class="col-md-6">
                          <label class="lableTitle">Full name</label>
                          <input type="text" name="full_name" value={profile?.full_name ?? ''} maxlength="120" class="form-control" />
                        </div>
                        <div class="col-md-6">
                          <label class="lableTitle">Phone</label>
                          <input type="tel" name="phone" value={profile?.phone ?? ''} maxlength="40" class="form-control" placeholder="+1 555 555 0100" />
                        </div>
                        <div class="col-12">
                          <label class="lableTitle">About me</label>
                          <textarea name="bio" rows="4" maxlength="2000" class="form-control" placeholder="Tell people a bit about yourself…">{profile?.bio ?? ''}</textarea>
                        </div>
                        <div class="col-md-6">
                          <label class="lableTitle">Website</label>
                          <input type="url" name="website" value={profile?.website ?? ''} maxlength="400" class="form-control" placeholder="https://…" />
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="card rounded-3 shadow-sm mt-4">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Address</h4></div>
                    <div class="card-body">
                      <div class="row g-3">
                        <div class="col-12">
                          <label class="lableTitle">Street address</label>
                          <input type="text" name="address" value={profile?.address ?? ''} maxlength="200" class="form-control" />
                        </div>
                        <div class="col-md-4"><label class="lableTitle">City</label><input type="text" name="city" value={profile?.city ?? ''} maxlength="100" class="form-control" /></div>
                        <div class="col-md-4"><label class="lableTitle">State / Region</label><input type="text" name="state" value={profile?.state ?? ''} maxlength="100" class="form-control" /></div>
                        <div class="col-md-4"><label class="lableTitle">Zip / Postal</label><input type="text" name="zip" value={profile?.zip ?? ''} maxlength="20" class="form-control" /></div>
                        <div class="col-md-4"><label class="lableTitle">Country</label><input type="text" name="country" value={profile?.country ?? ''} maxlength="100" class="form-control" /></div>
                        <div class="col-md-4"><label class="lableTitle">Latitude</label><input type="number" step="0.0000001" min="-90" max="90" name="lat" value={profile?.lat ?? ''} class="form-control" /></div>
                        <div class="col-md-4"><label class="lableTitle">Longitude</label><input type="number" step="0.0000001" min="-180" max="180" name="lng" value={profile?.lng ?? ''} class="form-control" /></div>
                      </div>
                    </div>
                  </div>

                  <div class="card rounded-3 shadow-sm mt-4">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Social links</h4></div>
                    <div class="card-body">
                      <div class="row g-3">
                        <div class="col-md-6"><label class="lableTitle"><i class="fa-brands fa-facebook me-2"></i>Facebook</label><input type="url" name="facebook" value={social.facebook ?? ''} maxlength="400" class="form-control" placeholder="https://facebook.com/…" /></div>
                        <div class="col-md-6"><label class="lableTitle"><i class="fa-brands fa-twitter me-2"></i>Twitter / X</label><input type="url" name="twitter" value={social.twitter ?? ''} maxlength="400" class="form-control" /></div>
                        <div class="col-md-6"><label class="lableTitle"><i class="fa-brands fa-linkedin me-2"></i>LinkedIn</label><input type="url" name="linkedin" value={social.linkedin ?? ''} maxlength="400" class="form-control" /></div>
                        <div class="col-md-6"><label class="lableTitle"><i class="fa-brands fa-instagram me-2"></i>Instagram</label><input type="url" name="instagram" value={social.instagram ?? ''} maxlength="400" class="form-control" /></div>
                        <div class="col-md-6"><label class="lableTitle"><i class="fa-brands fa-youtube me-2"></i>YouTube</label><input type="url" name="youtube" value={social.youtube ?? ''} maxlength="400" class="form-control" /></div>
                      </div>
                    </div>
                  </div>

                  <div class="mt-4 d-flex gap-2 flex-wrap">
                    <button type="submit" class="btn btn-primary rounded-pill fw-medium"><i class="bi bi-check-circle me-2"></i>Save Profile</button>
                    <a href="/dashboard-my-profile/" class="btn btn-light rounded-pill fw-medium">Reset</a>
                  </div>
                </div>

                <div class="col-xl-3 col-lg-4">
                  <div class="card rounded-3 shadow-sm">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Avatar</h4></div>
                    <div class="card-body text-center">
                      <img src={profile?.avatar_url ?? '/assets/img/team-2.jpg'} class="img-fluid rounded-circle mb-3" style="width: 140px; height: 140px; object-fit: cover;" alt="Avatar" />
                      <label class="form-label d-block text-start">Replace avatar</label>
                      <input type="file" name="avatar" accept="image/jpeg,image/png,image/webp,image/gif" class="form-control form-control-sm" />
                      <p class="text-muted text-md mt-2 mb-0">JPG / PNG / WebP / GIF, ≤ 1 MB.</p>
                    </div>
                  </div>
                </div>
              </form>

              <div class="row g-4 mb-lg-5 mb-4">
                <div class="col-xl-6 col-lg-6">
                  <div class="card rounded-3 shadow-sm h-100">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Email</h4></div>
                    <div class="card-body">
                      {emailNotice && <div class="alert alert-success">{emailNotice}</div>}
                      {emailError && <div class="alert alert-danger">{emailError}</div>}
                      <form action="/api/profile/email" method="post">
                        <label class="lableTitle">Email address</label>
                        <input type="email" name="email" value={user.email ?? ''} required autocomplete="email" class="form-control mb-3" />
                        <button type="submit" class="btn btn-primary rounded-pill fw-medium">Update Email</button>
                      </form>
                    </div>
                  </div>
                </div>

                <div class="col-xl-6 col-lg-6">
                  <div class="card rounded-3 shadow-sm h-100">
                    <div class="card-header py-3 px-4"><h4 class="m-0">Password</h4></div>
                    <div class="card-body">
                      {pwNotice && <div class="alert alert-success">{pwNotice}</div>}
                      {pwError && <div class="alert alert-danger">{pwError}</div>}
                      <form action="/api/profile/password" method="post">
                        <label class="lableTitle">New password</label>
                        <input type="password" name="new_password" minlength="8" required autocomplete="new-password" class="form-control mb-3" />
                        <label class="lableTitle">Confirm new password</label>
                        <input type="password" name="confirm_password" minlength="8" required autocomplete="new-password" class="form-control mb-3" />
                        <button type="submit" class="btn btn-primary rounded-pill fw-medium">Update Password</button>
                      </form>
                    </div>
                  </div>
                </div>
              </div>

              <div class="card rounded-3 shadow-sm border border-danger-subtle mb-4">
                <div class="card-header py-3 px-4"><h4 class="m-0 text-danger">Danger zone</h4></div>
                <div class="card-body">
                  {delError && <div class="alert alert-danger">{delError}</div>}
                  <p class="text-muted">Deleting your account is permanent. Your listings, bookings, and reviews will also be removed.</p>
                  <form action="/api/profile/delete" method="post" onsubmit="return confirm('This cannot be undone. Really delete your account?')">
                    <label class="lableTitle">Type <code>DELETE</code> to confirm</label>
                    <input type="text" name="confirm" required pattern="DELETE" class="form-control mb-3" style="max-width: 240px;" />
                    <button type="submit" class="btn btn-outline-danger rounded-pill fw-medium"><i class="bi bi-trash me-2"></i>Delete my account</button>
                  </form>
                </div>
              </div>

              <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> Rhodes Things To Do.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SearchOffcanvas />
  <LoginModal />
  <Footer />
</Base>
