---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';
import { getListingsByOwner } from '../lib/supabase/listings';
export const prerender = false;

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase;
const myListings = await getListingsByOwner(supabase, user.id);

// Fetch current statuses in parallel so we know which are drafts vs published.
const { data: statusRows } = supabase
  ? await supabase.from('listings').select('id, status').eq('owner_id', user.id)
  : { data: [] };
const statusById = new Map((statusRows ?? []).map((r: any) => [r.id, r.status]));

const error = Astro.url.searchParams.get('error');
const notice = Astro.url.searchParams.get('notice');
---
<Base noindex title="My Listings - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <!-- Dashboard Start -->
  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0 pt-lg-0 pt-5">

        <!-- Dashboard Sidebar -->
        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="my-listings" />
        </div>

        <!-- Dashboard Content -->
        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">

            <!-- Dashboard Title -->
            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0 d-flex align-items-center justify-content-between flex-wrap gap-3">
              <h2 class="fw-medium mb-0">My Listings</h2>
              <a href="/dashboard-add-listing/" class="btn btn-primary rounded-pill fw-medium"><i class="bi bi-plus-circle me-1"></i>Add Listing</a>
            </div>

            <!-- Dashboard Details -->
            <div class="dashCaption p-xl-5 p-3 p-md-4">

              {error && (
                <div class="alert alert-danger">{error}</div>
              )}
              {notice && (
                <div class="alert alert-success">{notice}</div>
              )}

              <div class="row align-items-start g-4 mb-lg-5 mb-4">
                <div class="col-12">
                  <div class="card rounded-3 shadow-sm">
                    <div class="card-header px-4 py-3">
                      <h4 class="m-0">Manage Listings <span class="text-muted fs-6">({myListings.length})</span></h4>
                    </div>
                    <div class="card-body p-0">
                      {myListings.length === 0 ? (
                        <div class="p-4 text-center">
                          <p class="text-muted mb-3">You haven't created any listings yet.</p>
                          <a href="/dashboard-add-listing/" class="btn btn-primary rounded-pill fw-medium">Create your first listing</a>
                        </div>
                      ) : (
                        <ul class="dashboardListgroup">
                          {myListings.map((item) => {
                            const status = statusById.get(item.id) ?? 'draft';
                            return (
                              <li>
                                <div class="mngListings">
                                  <div class="d-flex align-items-center justify-content-start gap-3 flex-wrap">
                                    <div class="mngListinfirst">
                                      <div class="d-flex align-items-center justify-content-start gap-3 flex-wrap">
                                        <div class="mngListings-thumb">
                                          <figure class="m-0"><img src={item.img} class="img-fluid rounded" alt={item.title} /></figure>
                                        </div>
                                        <div class="mngListings-caps">
                                          <div class="d-flex align-items-center justify-content-start mb-1 gap-2">
                                            {status === 'draft' && <span class="badge badge-xs bg-warning">Draft</span>}
                                            {status === 'published' && <span class="badge badge-xs bg-success">Published</span>}
                                            {status === 'archived' && <span class="badge badge-xs bg-secondary">Archived</span>}
                                          </div>
                                          <h5 class="mnglstTitle"><a href={`/listing/${item.slug}/`}>{item.title}</a></h5>
                                          <span>{item.desc.slice(0, 140)}{item.desc.length > 140 ? '…' : ''}</span>
                                          <div class="d-flex align-items-center justify-content-start gap-2 mt-3">
                                            <div class="text-md text-muted">{item.city || 'No location'} · {item.reviews}</div>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                    <div class="mngListinlast">
                                      <div class="d-flex align-items-center justify-content-start gap-2 flex-wrap">
                                        <a href={`/listing/${item.slug}/`} class="btn btn-sm btn-light rounded-pill"><i class="bi bi-eye me-1"></i>View</a>
                                        <form action={`/api/listings/${item.id}`} method="post" style="display:inline;">
                                          <input type="hidden" name="_action" value={status === 'published' ? 'unpublish' : 'publish'} />
                                          <button type="submit" class="btn btn-sm btn-light-success fw-medium rounded-pill">
                                            <i class="bi bi-check2-circle me-1"></i>{status === 'published' ? 'Unpublish' : 'Publish'}
                                          </button>
                                        </form>
                                        <form action={`/api/listings/${item.id}`} method="post" style="display:inline;" onsubmit="return confirm('Delete this listing permanently?')">
                                          <input type="hidden" name="_action" value="delete" />
                                          <button type="submit" class="btn btn-sm btn-light-danger fw-medium rounded-pill"><i class="bi bi-x me-1"></i>Delete</button>
                                        </form>
                                      </div>
                                    </div>
                                  </div>
                                </div>
                              </li>
                            );
                          })}
                        </ul>
                      )}
                    </div>
                  </div>
                </div>
              </div>

              <!-- Row Start -->
              <div class="row align-items-start g-4">
                <div class="col-xl-12 col-lg-12 col-md-12">
                  <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> Rhodes Things To Do.</p>
                </div>
              </div>

            </div>

          </div>
        </div>

      </div>
    </div>
  </section>
  <!-- Dashboard End -->


  <!-- Components/Home/index/cart.html -->
  <!-- Components/Listings/Single-Listings/single-listing-01/message.html -->
  <!-- Message Modal -->
  <div class="modal modal-lg fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header bg-light border-0 px-md-5">
          <h4 class="modal-title fw-medium" id="messageModalLabel">Send Message</h4>
          <a href="#" data-bs-dismiss="modal" aria-label="Close" class="square--40 circle bg-light-danger text-danger"><i class="bi bi-x"></i></a>
        </div>
        <div class="modal-body p-md-5">
          <div class="messageForm">
            <div class="form-group">
              <textarea class="form-control" placeholder="Type your Message To Dan"></textarea>
            </div>
            <button type="button" class="btn btn-primary fw-medium px-md-5">Send message<i class="bi bi-arrow-right ms-2"></i></button>
          </div>
        </div>
      </div>
    </div>
  </div>


  <!-- Components/Home/index/search.html -->
  <SearchOffcanvas />


  <!-- Components/Home/index/log.html -->
  <LoginModal />


  <Footer />
</Base>
</content>
</invoke>