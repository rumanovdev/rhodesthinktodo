---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { blogs } from '../lib/data/context';

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}
---
<Base
  title="Rhodes Travel Blog — Tips, Guides & Stories | Rhodes Things To Do"
  description="Travel tips, local guides and stories from across Rhodes, Greece — from Lindos and the Old Town to hidden beaches and the best places to eat and stay."
  canonical="/blog/"
>
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <div class="clearfix"></div>

  <!-- Page Title Start -->
  <section class="bg-cover position-relative" style="background:url(/assets/img/title-banner.jpg)no-repeat;" data-overlay="6">
    <div class="container">

      <!-- Search Form -->
      <div class="row justify-content-center align-items-center pt-lg-0 pt-5">
        <div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
          <div class="position-relative text-center mb-5">
            <h1 class="text-light xl-heading">Latest Updates</h1>
            <nav id="breadcrumbs" class="breadcrumbs light">
              <ul>
                <li><a href="/">Home</a></li>
                <li><a href="#">Pages</a></li>
                <li>Blog</li>
              </ul>
            </nav>
          </div>
        </div>
      </div>
      <!-- </row> -->

    </div>
  </section>
  <!-- Page Title End -->

  <!-- Blogs Start -->
  <section class="bg-light">
    <div class="container">

      <div class="row justify-content-center g-4">

        <!-- Components/Pages/blog/single.html -->
        <!-- Single Item -->
        <div class="col-xl-12 col-lg-12 col-md-12">
          <div class="card rounded-4 border">
            <div class="row align-items-center justify-content-start">

              <div class="col-xl-4 col-lg-4 col-md-4">
                <a href="/blog-detail/" class="d-block p-3">
                  <img class="img-fluid rounded" src="/assets/img/blog-5.jpg" alt="blog image" />
                </a>
              </div>

              <div class="col-xl-8 col-lg-8 col-md-8">
                <div class="card-body">
                  <div class="d-flex align-items-center justify-content-start gap-2 mb-3">
                    <span class="badge badge-xs badge-success rounded-pill">Featured</span>
                    <span class="badge badge-xs badge-danger rounded-pill">Web Design</span>
                  </div>
                  <a href="/blog-detail/"><h4 class="fw-semibold fs-5 lh-base mb-2">Boost Your Website's Performance with These Bootstrap Optimization Tips</h4></a>
                  <p>Cicero famously orated against his political opponent Lucius Sergius Catilina. Occasionally the first Oration against Catiline is taken for type specimens: Quo usque tandem abutere, Catilina, patientia nostra.</p>
                  <div class="d-flex align-items-center justify-content-start mt-4">
                    <a href="#" class="badge badge-primary rounded-pill">Continue Reading</a>
                  </div>
                </div>
              </div>

            </div>
          </div>
        </div>

        <!-- Components/Pages/blog/blogs.html -->
        {blogs.map((item: any) => (
          <div class="col-xl-4 col-lg-4 col-md-6">
            <div class="card rounded-4 shadow-sm h-100">
              <a href={`/blog-detail/${item.slug || slugify(item.title)}/`} class="d-block bg-gradient rounded-top">
                <img class="card-img-top hover-fade-out" src={item.img} alt="blog image" />
              </a>
              <div class="card-body">
                <a href={`/blog-detail/${item.slug || slugify(item.title)}/`}><h4 class="fw-semibold fs-5 lh-base mb-3">{item.title}</h4></a>
                <p>{item.desc}</p>
                <div class="d-flex align-items-center justify-content-start mt-4">
                  <a href={`/blog-detail/${item.slug || slugify(item.title)}/`} class="badge badge-primary rounded-pill">Continue Reading</a>
                </div>
              </div>
            </div>
          </div>
        ))}

      </div>

      <!-- Components/Listings/Grid-Layouts/grid-layout-01/pagination.html -->
      <!-- Pagination Start -->
      <div class="row align-items-center justify-content-center mt-5">
        <div class="col-xl-12 col-lg-12 col-md-12">
          <nav aria-label="Page navigation example">
            <ul class="pagination justify-content-center">
              <li class="page-item">
                <a class="page-link"><i class="fa-solid fa-arrow-left"></i></a>
              </li>
              <li class="page-item"><a class="page-link" href="#">1</a></li>
              <li class="page-item active"><a class="page-link" href="#">2</a></li>
              <li class="page-item"><a class="page-link" href="#">3</a></li>
              <li class="page-item"><a class="page-link" href="#">4</a></li>
              <li class="page-item"><a class="page-link" href="#">5</a></li>
              <li class="page-item">
                <a class="page-link" href="#"><i class="fa-solid fa-arrow-right"></i></a>
              </li>
            </ul>
          </nav>
        </div>
      </div>
      <!-- Pagination END -->

    </div>
  </section>
  <!-- Blogs END -->


  <!-- Call To Action Start -->
  <section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
    <div class="container">

      <!-- Components/Home/index/subscribe.html -->
      <Subscribe />

    </div>
  </section>
  <!-- Call To Action Start -->


  <!-- Components/Home/index/log.html -->
  <LoginModal />


  <!-- Components/Home/index/cart.html -->
  <!-- Components/Home/index/search.html -->
  <SearchOffcanvas />

  <Footer />
</Base>
