---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { blogs } from '../lib/data/context';

function slugify(s: string): string {
  return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
}
---
<Base
  title="Rhodes Travel Blog — Tips, Guides & Stories | Rhodes Things To Do"
  description="Travel tips, local guides and stories from across Rhodes, Greece — from Lindos and the Old Town to hidden beaches and the best places to eat and stay."
  canonical="/blog/"
>
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <div class="clearfix"></div>

  <!-- Page Title Start -->
  <section class="bg-cover position-relative" style="background:url(/assets/img/title-banner.jpg)no-repeat;" data-overlay="6">
    <div class="container">

      <!-- Search Form -->
      <div class="row justify-content-center align-items-center pt-lg-0 pt-5">
        <div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
          <div class="position-relative text-center mb-5">
            <h1 class="text-light xl-heading">Latest Updates</h1>

</div>
        </div>
      </div>
      <!-- </row> -->

    </div>
  </section>
  <!-- Page Title End -->

  <!-- Blogs Start -->
  <section class="bg-light">
    <div class="container">

      <div class="row justify-content-center g-4">

        <!-- Components/Pages/blog/blogs.html -->
        {blogs.map((item: any) => (
          <div class="col-xl-4 col-lg-4 col-md-6">
            <div class="card rounded-4 shadow-sm h-100">
              <a href={`/blog-detail/${item.slug || slugify(item.title)}/`} class="d-block bg-gradient rounded-top">
                <img class="card-img-top hover-fade-out" src={item.img} alt="blog image" />
              </a>
              <div class="card-body">
                <a href={`/blog-detail/${item.slug || slugify(item.title)}/`}><h4 class="fw-semibold fs-5 lh-base mb-3">{item.title}</h4></a>
                <p>{item.desc}</p>
                <div class="d-flex align-items-center justify-content-start mt-4">
                  <a href={`/blog-detail/${item.slug || slugify(item.title)}/`} class="badge badge-primary rounded-pill">Continue Reading</a>
                </div>
              </div>
            </div>
          </div>
        ))}

      </div>

    </div>
  </section>
  <!-- Blogs END -->


  <!-- Call To Action Start -->

<!-- Call To Action Start -->


  <!-- Components/Home/index/log.html -->
  <LoginModal />


  <!-- Components/Home/index/cart.html -->
  <!-- Components/Home/index/search.html -->
  <SearchOffcanvas />

  <Footer />
</Base>
