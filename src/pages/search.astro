---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { searchListings, slugify } from '../lib/supabase/listings';

export const prerender = false;

const supabase = Astro.locals.supabase;
const q = Astro.url.searchParams.get('q') ?? '';
const category = Astro.url.searchParams.get('category') ?? '';
const city = Astro.url.searchParams.get('city') ?? '';

const { data: categories } = (await supabase?.from('categories').select('slug, name').order('sort_order')) ?? { data: [] };
const results = await searchListings(supabase, { q, categorySlug: category || undefined, city: city || undefined });

const title = q ? `Search results for "${q}"` : category ? `Listings in ${category}` : 'Search Listings';
---
<Base title={`${title} - ThinksToDo`}>
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <section class="pt-5 pb-4 gray-simple">
    <div class="container">
      <div class="row">
        <div class="col-12">
          <h1 class="fs-2 fw-medium mb-3">{title}</h1>
          <form class="card p-3 mb-4" action="/search" method="get">
            <div class="row g-3 align-items-end">
              <div class="col-md-6">
                <label class="form-label text-md">Keywords</label>
                <input type="search" name="q" value={q} class="form-control" placeholder="e.g. gym, brunch, coworking" />
              </div>
              <div class="col-md-3">
                <label class="form-label text-md">Category</label>
                <select name="category" class="form-control">
                  <option value="">All categories</option>
                  {(categories ?? []).map((c: any) => (
                    <option value={c.slug} selected={c.slug === category}>{c.name}</option>
                  ))}
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label text-md">Location</label>
                <input type="text" name="city" value={city} class="form-control" placeholder="Any" />
              </div>
              <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Go</button>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="pt-0 pb-5">
    <div class="container">
      {results.length === 0 ? (
        <div class="text-center py-5">
          <p class="text-muted mb-2">No listings matched your search.</p>
          <a href="/listings/" class="btn btn-light rounded-pill">Browse all listings</a>
        </div>
      ) : (
        <div class="row g-4">
          {results.map((item) => (
            <div class="col-xl-4 col-lg-6 col-md-6">
              <div class="fr-listing-cards listing-card5 lightshadow rounded-4 pb-0">
                <div class="fr-list-thumbs rounded-top-4">
                  <a href={`/listing/${item.slug}/`}><img src={item.img} class="img-fluid rounded-top-4" alt={item.title} /></a>
                  {item.tag && (
                    <div class="lis-wishlist"><a href="#" class="badge badge-xs bg-warning">Featured</a></div>
                  )}
                </div>
                <div class="fr-listing-content p-3">
                  <div class="listingCats mb-1"><span class="text-md text-primary fw-medium">{item.name}</span></div>
                  <h4 class="listingTitle"><a href={`/listing/${item.slug}/`} class="titleLink">{item.title}</a></h4>
                  <div class="text-md text-muted mt-1">{item.location || '—'}</div>
                  <div class="d-flex align-items-center justify-content-between mt-3">
                    <div class="text-sm"><i class="bi bi-star-fill text-warning me-1"></i>{item.rating} · {item.reviews}</div>
                    <div class="text-sm text-muted">{item.dollar}</div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <Subscribe />
  <Footer />
  <LoginModal />
  <SearchOffcanvas />
</Base>
