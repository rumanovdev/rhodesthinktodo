---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const error = Astro.url.searchParams.get('error');
const notice = Astro.url.searchParams.get('notice');

// Load categories and amenities from DB for the selects / checkboxes.
const { data: categories } = (await supabase?.from('categories').select('id, slug, name').order('sort_order')) ?? { data: [] };
const { data: amenityRows } = (await supabase?.from('amenities').select('id, key, name, icon').order('name')) ?? { data: [] };
---
<Base noindex title="Add Listing - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0 pt-lg-0 pt-5">

        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="add-listing" />
        </div>

        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">

            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0">
              <h2 class="fw-medium mb-0">Add a Listing</h2>
              <p class="text-muted mt-2 mb-0">Fill in the details below. Your listing starts as a draft — publish it from the My Listings page when ready.</p>
            </div>

            <div class="dashCaption p-xl-5 p-3 p-md-4">

              {error && (
                <div class="alert alert-danger" role="alert">{error}</div>
              )}
              {notice && (
                <div class="alert alert-success" role="alert">{notice}</div>
              )}

              <form action="/api/listings" method="post" enctype="multipart/form-data">

                <!-- Basic info -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="fa fa-file text-primary me-2"></i>Basic Information</h4>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-12">
                            <div class="form-group">
                              <label class="lableTitle">Title <span class="text-danger">*</span></label>
                              <input type="text" name="title" required maxlength="140" class="form-control rounded" placeholder="e.g. The Big Bumble Gym" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Category <span class="text-danger">*</span></label>
                              <select name="category_slug" required class="form-control">
                                <option value="">Choose a category…</option>
                                {(categories ?? []).map((c: any) => (
                                  <option value={c.slug}>{c.name}</option>
                                ))}
                              </select>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Phone</label>
                              <input type="tel" name="phone" class="form-control rounded" placeholder="+1 555 555 0100" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Price tier</label>
                              <select name="price_tier" class="form-control">
                                <option value="1">$ — Inexpensive</option>
                                <option value="2" selected>$$ — Moderate</option>
                                <option value="3">$$$ — Pricey</option>
                                <option value="4">$$$$ — Premium</option>
                              </select>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Status</label>
                              <select name="status" class="form-control">
                                <option value="draft" selected>Draft (only visible to you)</option>
                                <option value="published">Published</option>
                              </select>
                            </div>
                          </div>
                          <div class="col-12">
                            <div class="form-group">
                              <label class="lableTitle">Description</label>
                              <textarea name="description" rows="5" class="form-control rounded" placeholder="What makes this place special?"></textarea>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Location -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-geo-alt text-primary me-2"></i>Location</h4>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-12">
                            <div class="form-group">
                              <label class="lableTitle">Street address</label>
                              <input type="text" name="address" class="form-control rounded" placeholder="202 Market Street" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">City</label>
                              <input type="text" name="city" class="form-control rounded" placeholder="Los Angeles" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Country</label>
                              <input type="text" name="country" class="form-control rounded" placeholder="United States" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Latitude</label>
                              <input type="number" step="0.0000001" name="lat" class="form-control rounded" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Longitude</label>
                              <input type="number" step="0.0000001" name="lng" class="form-control rounded" />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Images -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-images text-primary me-2"></i>Photos</h4>
                        <p class="text-muted text-md mb-0 mt-1">The first image becomes the hero. Up to 5 JPEG/PNG/WebP, 5 MB each.</p>
                      </div>
                      <div class="card-body">
                        <div class="form-group">
                          <input type="file" name="images" multiple accept="image/jpeg,image/png,image/webp,image/gif" class="form-control" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Amenities -->
                {(amenityRows ?? []).length > 0 && (
                  <div class="row align-items-start g-4 mb-lg-5 mb-4">
                    <div class="col-12">
                      <div class="card rounded-3 shadow-sm">
                        <div class="card-header py-4 px-4">
                          <h4 class="fs-5 fw-medium"><i class="bi bi-feather text-primary me-2"></i>Amenities</h4>
                        </div>
                        <div class="card-body">
                          <ul class="p-0 row align-items-start justify-content-start g-4 list-unstyled mb-0">
                            {(amenityRows ?? []).map((a: any) => (
                              <li class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
                                <div class="form-check">
                                  <input id={`amn-${a.id}`} class="form-check-input" name="amenities" value={a.id} type="checkbox" />
                                  <label for={`amn-${a.id}`} class="form-check-label">{a.icon && <i class={`fa-solid ${a.icon} me-2 text-primary`}></i>}{a.name}</label>
                                </div>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12 d-flex gap-3">
                    <button type="submit" class="btn btn-primary rounded-pill fw-medium">Save Listing<i class="bi bi-arrow-right-circle ms-2"></i></button>
                    <a href="/dashboard-my-listings/" class="btn btn-light rounded-pill fw-medium">Cancel</a>
                  </div>
                </div>

              </form>

              <div class="row align-items-start g-4">
                <div class="col-12">
                  <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> Rhodes Things To Do.</p>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
  <LoginModal />
  <SearchOffcanvas />
</Base>
