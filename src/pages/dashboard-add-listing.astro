---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import DashboardSidebar from '../components/dashboard/DashboardSidebar.astro';

export const prerender = false;

const supabase = Astro.locals.supabase;
const error = Astro.url.searchParams.get('error');
const notice = Astro.url.searchParams.get('notice');

// Load the taxonomy (categories tree, areas, tags) + amenities for the form.
const { data: catRows } = (await supabase?.from('categories').select('id, slug, name, parent_id').eq('is_active', true).order('sort_order')) ?? { data: [] };
const cats = catRows ?? [];
const motherCats = cats.filter((c: any) => c.parent_id == null);
const subsByMother: Record<number, any[]> = {};
for (const s of cats.filter((c: any) => c.parent_id != null)) (subsByMother[(s as any).parent_id] ??= []).push(s);
const { data: areaRows } = (await supabase?.from('areas').select('id, name, slug, parent_id').eq('is_active', true).order('sort_order')) ?? { data: [] };
const areas = areaRows ?? [];
const { data: tagRows } = (await supabase?.from('tags').select('id, name').eq('is_active', true).order('sort_order')) ?? { data: [] };
const tags = tagRows ?? [];
const { data: amenityRows } = (await supabase?.from('amenities').select('id, key, name, icon').order('name')) ?? { data: [] };
---
<Base noindex title="Add Listing - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

  <Preloader />

  <section class="p-0">
    <div class="container-fluid p-0">
      <div class="row user-dashboard g-0 pt-lg-0 pt-5">

        <div class="col-xl-2 col-lg-3 col-md-12">
          <DashboardSidebar current="add-listing" />
        </div>

        <div class="col-xl-10 col-lg-9 col-md-12">
          <div class="user-dashboard-box bg-light">

            <div class="dashHeader p-xl-5 p-4 pb-xl-0 pb-0">
              <h2 class="fw-medium mb-0">Add a Listing</h2>
              <p class="text-muted mt-2 mb-0">Fill in the details below. Your listing starts as a draft — publish it from the My Listings page when ready. Fields marked <span class="text-danger">*</span> are required.</p>
            </div>

            <div class="dashCaption p-xl-5 p-3 p-md-4">

              {error && (
                <div class="alert alert-danger" role="alert">{error}</div>
              )}
              {notice && (
                <div class="alert alert-success" role="alert">{notice}</div>
              )}

              <form action="/api/listings" method="post" enctype="multipart/form-data" id="addListingForm">

                <!-- Basic info -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-info-circle text-primary me-2"></i>Basic Information</h4>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-12">
                            <div class="form-group">
                              <label for="title" class="lableTitle">Title <span class="text-danger">*</span></label>
                              <input type="text" id="title" name="title" required maxlength="140" class="form-control rounded" placeholder="e.g. Meltemi Beach Taverna" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="category_slug" class="lableTitle">Category <span class="text-danger">*</span></label>
                              <select id="category_slug" name="category_slug" required class="form-control">
                                <option value="">Choose a category…</option>
                                {motherCats.map((c: any) => (
                                  <option value={c.slug}>{c.name}</option>
                                ))}
                              </select>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="phone" class="lableTitle">Phone</label>
                              <input type="tel" id="phone" name="phone" class="form-control rounded" placeholder="698 000 0000" inputmode="tel" autocomplete="tel" />
                              <div class="invalid-feedback">Please enter a Greek phone number, e.g. 698 000 0000 or +30 22410 12345.</div>
                              <small class="text-muted">Greek number — mobile (69…) or landline (2…), with or without +30.</small>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="price_tier" class="lableTitle">Price tier</label>
                              <select id="price_tier" name="price_tier" class="form-control">
                                <option value="1">$ — Inexpensive</option>
                                <option value="2" selected>$$ — Moderate</option>
                                <option value="3">$$$ — Pricey</option>
                                <option value="4">$$$$ — Premium</option>
                              </select>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="status" class="lableTitle">Status</label>
                              <select id="status" name="status" class="form-control">
                                <option value="draft" selected>Draft (only visible to you)</option>
                                <option value="published">Published</option>
                              </select>
                            </div>
                          </div>
                          <div class="col-12">
                            <div class="form-group">
                              <label for="description" class="lableTitle">Description</label>
                              <textarea id="description" name="description" rows="5" class="form-control rounded" placeholder="What makes this place special?"></textarea>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Classification -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-tags text-primary me-2"></i>Subcategories &amp; Tags</h4>
                        <p class="text-muted text-md mb-0 mt-1">Tick the specific types this place fits (e.g. Meat Restaurant) and any tags (e.g. Sea View). These drive the "Best … in …" pages.</p>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Subcategories</label>
                              <div id="subcatGroups">
                                {motherCats.map((m: any) => (
                                  (subsByMother[m.id] ?? []).length > 0 && (
                                    <div class="mb-3" data-subcat-group={m.slug}>
                                      <h6 class="text-muted text-uppercase small fw-semibold mb-2">{m.name}</h6>
                                      <ul class="p-0 row g-2 list-unstyled mb-0">
                                        {(subsByMother[m.id] ?? []).map((s: any) => (
                                          <li class="col-6">
                                            <div class="form-check">
                                              <input id={`sub-${s.id}`} class="form-check-input" name="subcategory_ids" value={s.id} type="checkbox" />
                                              <label for={`sub-${s.id}`} class="form-check-label">{s.name}</label>
                                            </div>
                                          </li>
                                        ))}
                                      </ul>
                                    </div>
                                  )
                                ))}
                              </div>
                              <small class="text-muted">Choose a category above to narrow this list to the relevant types.</small>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Tags</label>
                              <ul class="p-0 row g-2 list-unstyled mb-0">
                                {tags.map((t: any) => (
                                  <li class="col-6">
                                    <div class="form-check">
                                      <input id={`tag-${t.id}`} class="form-check-input" name="tag_ids" value={t.id} type="checkbox" />
                                      <label for={`tag-${t.id}`} class="form-check-label">{t.name}</label>
                                    </div>
                                  </li>
                                ))}
                              </ul>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Location -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-geo-alt text-primary me-2"></i>Location</h4>
                      </div>
                      <div class="card-body">
                        <div class="row">
                          <div class="col-12">
                            <div class="form-group">
                              <label for="address" class="lableTitle">Street address</label>
                              <input type="text" id="address" name="address" class="form-control rounded" placeholder="e.g. Sokratous 45, Rhodes Old Town" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="area_id" class="lableTitle">Main area</label>
                              <select id="area_id" name="area_id" class="form-control">
                                <option value="">Choose an area…</option>
                                {areas.map((a: any) => (
                                  <option value={a.id}>{a.name}</option>
                                ))}
                              </select>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label class="lableTitle">Service areas</label>
                              <ul class="p-0 row g-2 list-unstyled mb-1">
                                {areas.map((a: any) => (
                                  <li class="col-6">
                                    <div class="form-check">
                                      <input id={`sa-${a.id}`} class="form-check-input" name="service_area_ids" value={a.id} type="checkbox" />
                                      <label for={`sa-${a.id}`} class="form-check-label">{a.name}</label>
                                    </div>
                                  </li>
                                ))}
                              </ul>
                              <small class="text-muted">Extra areas this business serves (optional).</small>
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="city" class="lableTitle">City</label>
                              <input type="text" id="city" name="city" class="form-control rounded" placeholder="e.g. Lindos" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="country" class="lableTitle">Country</label>
                              <input type="text" id="country" name="country" value="Greece" class="form-control rounded" placeholder="Greece" />
                            </div>
                          </div>
                          <div class="col-12">
                            <p class="text-muted text-sm mb-2"><i class="bi bi-info-circle me-1"></i>Tip: open Google Maps, right-click the exact spot, and click the coordinates to copy them (e.g. <code>36.0917, 28.0867</code>) — paste latitude and longitude below.</p>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="lat" class="lableTitle">Latitude <span class="text-danger">*</span></label>
                              <input type="number" step="0.0000001" min="-90" max="90" id="lat" name="lat" required class="form-control rounded" placeholder="36.0917" />
                            </div>
                          </div>
                          <div class="col-md-6">
                            <div class="form-group">
                              <label for="lng" class="lableTitle">Longitude <span class="text-danger">*</span></label>
                              <input type="number" step="0.0000001" min="-180" max="180" id="lng" name="lng" required class="form-control rounded" placeholder="28.0867" />
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Images -->
                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12">
                    <div class="card rounded-3 shadow-sm">
                      <div class="card-header py-4 px-4">
                        <h4 class="fs-5 fw-medium"><i class="bi bi-images text-primary me-2"></i>Photos</h4>
                        <p class="text-muted text-md mb-0 mt-1">The first image becomes the hero. Up to 5 JPEG/PNG/WebP, 5 MB each.</p>
                      </div>
                      <div class="card-body">
                        <div class="form-group">
                          <label for="images" class="lableTitle visually-hidden">Photos</label>
                          <input type="file" id="images" name="images" multiple accept="image/jpeg,image/png,image/webp,image/gif" class="form-control" />
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Amenities -->
                {(amenityRows ?? []).length > 0 && (
                  <div class="row align-items-start g-4 mb-lg-5 mb-4">
                    <div class="col-12">
                      <div class="card rounded-3 shadow-sm">
                        <div class="card-header py-4 px-4">
                          <h4 class="fs-5 fw-medium"><i class="bi bi-feather text-primary me-2"></i>Amenities</h4>
                        </div>
                        <div class="card-body">
                          <ul class="p-0 row align-items-start justify-content-start g-4 list-unstyled mb-0">
                            {(amenityRows ?? []).map((a: any) => (
                              <li class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
                                <div class="form-check">
                                  <input id={`amn-${a.id}`} class="form-check-input" name="amenities" value={a.id} type="checkbox" />
                                  <label for={`amn-${a.id}`} class="form-check-label">{a.icon && <i class={`fa-solid ${a.icon} me-2 text-primary`}></i>}{a.name}</label>
                                </div>
                              </li>
                            ))}
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                <div class="row align-items-start g-4 mb-lg-5 mb-4">
                  <div class="col-12 d-flex gap-3">
                    <button type="submit" id="saveListingBtn" class="btn btn-primary rounded-pill fw-medium">Save Listing<i class="bi bi-arrow-right-circle ms-2"></i></button>
                    <a href="/dashboard-my-listings/" class="btn btn-light rounded-pill fw-medium">Cancel</a>
                  </div>
                </div>

              </form>

              <div class="row align-items-start g-4">
                <div class="col-12">
                  <p class="text-muted m-0">&copy; <script is:inline>document.write(new Date().getFullYear())</script> Rhodes Things To Do.</p>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer />
  <LoginModal />
  <SearchOffcanvas />

  <script>
    // Greek phone validation: mobile (69XXXXXXXX) or landline (2XXXXXXXXX),
    // optionally prefixed with +30 / 0030; spaces, dashes and dots tolerated.
    const phone = document.getElementById('phone') as HTMLInputElement | null;
    function checkPhone() {
      if (!phone) return true;
      const digits = phone.value.replace(/[\s\-().]/g, '');
      const ok = !digits || /^(\+30|0030)?(69\d{8}|2\d{9})$/.test(digits);
      phone.setCustomValidity(ok ? '' : 'Please enter a Greek phone number, e.g. 698 000 0000');
      phone.classList.toggle('is-invalid', !ok);
      return ok;
    }
    phone?.addEventListener('blur', checkPhone);
    phone?.addEventListener('input', () => {
      if (phone.classList.contains('is-invalid')) checkPhone();
    });

    // Show only the subcategory group matching the chosen category
    // (groups that already have ticked boxes stay visible so nothing is lost).
    const catSelect = document.getElementById('category_slug') as HTMLSelectElement | null;
    const groups = Array.from(document.querySelectorAll<HTMLElement>('[data-subcat-group]'));
    function syncSubcatGroups() {
      const slug = catSelect?.value ?? '';
      for (const g of groups) {
        const hasChecked = !!g.querySelector('input:checked');
        g.hidden = !!slug && g.dataset.subcatGroup !== slug && !hasChecked;
      }
    }
    catSelect?.addEventListener('change', syncSubcatGroups);
    for (const g of groups) {
      g.addEventListener('change', syncSubcatGroups);
    }
    syncSubcatGroups();

    // Disable the submit button while the form is posting so it can't be double-submitted.
    const form = document.getElementById('addListingForm') as HTMLFormElement | null;
    form?.addEventListener('submit', (e) => {
      if (!checkPhone()) {
        e.preventDefault();
        phone?.focus();
        return;
      }
      const btn = document.getElementById('saveListingBtn') as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving…';
      }
    });
  </script>
</Base>
