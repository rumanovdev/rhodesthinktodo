---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
---
<Base noindex title="Error - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Page Title Start -->
<section class="bg-light">
	<div class="container">

		<!-- Search Form -->
		<div class="row justify-content-start align-items-center pt-lg-0 pt-5">
			<div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
				<div class="position-relative">
					<h1 class="xl-heading">404 Not Found</h1>
					<nav id="breadcrumbs" class="breadcrumbs">
						<ul>
							<li><a href="/">Home</a></li>
							<li><a href="#">Pages</a></li>
							<li>Eroor</li>
						</ul>
					</nav>
				</div>
			</div>
		</div>
		<!-- </row> -->

	</div>
</section>
<!-- Page Title End -->

<!-- Error Content Start -->
<section class="position-relative">
	<div class="container">
		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-12">

				<div class="404-capstion text-center my-4">
					<div class="404-captions mb-5">
						<img src="/assets/img/error.svg" class="img-fluid mb-3" alt="">
						<h2>Ohhh ho, something went wrong!</h2>
						<p class="fs-6">Cicero famously orated against his political opponent.</p>
					</div>
					<div class="backHome">
						<a href="/" class="btn btn-lg btn-light-primary fw-medium rounded-pill">Back to Home</a>
					</div>
				</div>

			</div>
		</div>
	</div>
</section>
<!-- Error Content End -->

<!-- Call To Action Start -->

<!-- Call To Action Start -->

	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<Footer />
</Base>
