---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
---
<Base title="Privacy Policy - Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Page Title Start -->
<section class="bg-light">
	<div class="container">

		<!-- Search Form -->
		<div class="row justify-content-start align-items-center pt-lg-0 pt-5">
			<div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
				<div class="position-relative">
					<h1 class="xl-heading">Privacy Policy</h1>

</div>
			</div>
		</div>
		<!-- </row> -->

	</div>
</section>
<!-- Page Title End -->


<!-- Articles Section -->
<section>
	<div class="container">

		<div class="row justify-content-start g-4">
			<div class="col-xl-10 col-lg-12 col-md-12">
				<article class="article">
				<h2>Privacy Policy</h2>
					<p>This Privacy Policy explains how Rhodes Things To Do ("we", "us") collects, uses and protects your information when you use our website. By using the site you agree to the practices described here.</p>
					<h4 class="fs-4">Information we collect</h4>
					<p>When you register, submit a listing, leave a review or contact us, we may collect your name, email address and any details you choose to provide. When you simply browse the site, we collect limited technical data such as your IP address, browser type and the pages you visit, in order to keep the site secure and improve it.</p>
					<h4 class="fs-4">How we use your information</h4>
					<p>We use your information to provide and improve our services — to create and manage your account, publish your listings and reviews, respond to your enquiries, and analyse how the site is used so we can make it better.</p>
					<h4 class="fs-4">Cookies & Google Analytics</h4>
					<p>We use cookies and Google Analytics (GA4) to understand how visitors use the site. Analytics cookies are only set after you accept them in our cookie banner — you can decline at any time and we will not load analytics tracking. You can also control cookies through your browser settings.</p>
					<h4 class="fs-4">Who we share your data with</h4>
					<p>We do not sell your personal data. We only share information with trusted service providers that help us operate the site (such as our hosting and analytics providers), and only to the extent necessary to deliver our services or comply with the law.</p>
					<h4 class="fs-4">How long we retain your data</h4>
					<p>We keep account and listing information for as long as your account is active. Contact messages and analytics data are retained only for as long as needed for the purposes described above, after which they are deleted or anonymised.</p>
					<h4 class="fs-4">Your rights</h4>
					<p>You have the right to access, correct or delete your personal data, and to object to or restrict its processing. To exercise these rights, contact us at <a href="mailto:info@rhodesthingstodo.com">info@rhodesthingstodo.com</a>.</p>
					<h4 class="fs-4">Changes to this privacy policy</h4>
					<p>We may update this Privacy Policy from time to time. Any changes will be posted on this page with an updated revision. If you have any questions, please contact us at <a href="mailto:info@rhodesthingstodo.com">info@rhodesthingstodo.com</a>.</p>
				</article>
			</div>
		</div>

	</div>
</section>
<!-- Articles Section End -->


<!-- Call To Action Start -->

<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<Footer />
</Base>
