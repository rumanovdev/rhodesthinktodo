---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import { searchListings } from '../lib/supabase/listings';
import '../styles/listings-map.css';

export const prerender = false;

const supabase = Astro.locals.supabase;
const params = Astro.url.searchParams;
const q = params.get('q')?.trim() ?? '';
const category = params.get('category')?.trim() ?? '';
const city = params.get('city')?.trim() ?? '';
const hasFilter = Boolean(q || category || city);

// One query drives both the sidebar and the markers.
const allPublished = await searchListings(supabase, {
  q: q || undefined,
  categorySlug: category || undefined,
  city: city || undefined,
  limit: 200,
});
const mappable = allPublished.filter((l) => l.lat !== null && l.lng !== null);

const totalCount = allPublished.length;
const mappableCount = mappable.length;

// Load the category list so the inline search form's dropdown reflects reality.
const { data: categoryRows } =
  (await supabase?.from('categories').select('slug, name').order('sort_order')) ?? { data: [] };
const categories = categoryRows ?? [];

// Friendly label for the active filter (shown above the results list).
const filterParts: string[] = [];
if (q) filterParts.push(`“${q}”`);
if (category) {
  const catName = categories.find((c: any) => c.slug === category)?.name ?? category;
  filterParts.push(`in ${catName}`);
}
if (city) filterParts.push(`near ${city}`);
const filterLabel = filterParts.join(' ');

const markersPayload = mappable.map((l) => ({
  id: l.id,
  slug: l.slug,
  title: l.title,
  img: l.img,
  category: l.name,
  rating: l.rating,
  reviews: l.reviews,
  price: l.dollar,
  lat: l.lat,
  lng: l.lng,
}));
---
<Base
  title="Rhodes Map — Find Things to Do Near You | Rhodes Things To Do"
  description="Explore Rhodes on an interactive map. Find restaurants, hotels, tours, activities, bars and shops near you across the island of Rhodes, Greece."
  canonical="/listings-map/"
>
  <Navbar headerClass="header header-light head-shadow" />

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

  <section class="lm-layout">

    <aside class="lm-sidebar-col">
      <div class="mb-3">
        <h1 class="h4 fw-semibold mb-1">
          {hasFilter ? `Results for ${filterLabel}` : 'Explore listings on the map'}
        </h1>
        <p class="text-muted mb-0">
          {totalCount} {totalCount === 1 ? 'listing' : 'listings'} {hasFilter ? 'matching' : 'published'} · {mappableCount} on the map
          {hasFilter && (
            <> · <a href="/listings-map/" class="text-primary fw-medium">clear filters</a></>
          )}
        </p>
      </div>

      <form action="/listings-map/" method="get" class="card p-3 mb-3">
        <div class="row g-2 align-items-end">
          <div class="col-12 col-md-6">
            <label class="form-label text-md mb-1">Keywords</label>
            <input type="search" name="q" value={q} class="form-control form-control-sm" placeholder="e.g. gym, brunch" />
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label text-md mb-1">Category</label>
            <select name="category" class="form-control form-control-sm">
              <option value="">All</option>
              {categories.map((c: any) => (
                <option value={c.slug} selected={c.slug === category}>{c.name}</option>
              ))}
            </select>
          </div>
          <div class="col-6 col-md-3">
            <label class="form-label text-md mb-1">Location</label>
            <input type="text" name="city" value={city} class="form-control form-control-sm" placeholder="Any" />
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4"><i class="bi bi-search me-1"></i>Search</button>
          </div>
        </div>
      </form>

      {allPublished.length === 0 ? (
        <div class="lm-empty">
          <i class="bi bi-pin-map fs-1 text-muted"></i>
          <h5 class="mb-0">{hasFilter ? 'No matching listings' : 'No listings yet'}</h5>
          <p class="mb-0">
            {hasFilter
              ? <>Try <a href="/listings-map/" class="text-primary fw-medium">clearing your filters</a>.</>
              : <>Be the first — <a href="/dashboard-add-listing/" class="text-primary fw-medium">add your listing</a>.</>}
          </p>
        </div>
      ) : (
        <div class="row g-3">
          {allPublished.map((item) => (
            <div class="col-12">
              <article
                class="card lm-card rounded-3 overflow-hidden h-100"
                data-listing-id={item.id}
                data-has-coords={item.lat !== null && item.lng !== null ? 'true' : 'false'}
              >
                <div class="row g-0">
                  <div class="col-4">
                    <a href={`/listing/${item.slug}/`}>
                      <img src={item.img} alt={item.title} style="width:100%;height:100%;object-fit:cover;min-height:120px;" />
                    </a>
                  </div>
                  <div class="col-8">
                    <div class="card-body py-3 px-3">
                      <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                        <span class="text-primary text-md fw-medium">{item.name}</span>
                        <span class="text-muted text-md">{item.dollar}</span>
                      </div>
                      <h5 class="mb-1"><a href={`/listing/${item.slug}/`} class="text-decoration-none text-dark">{item.title}</a></h5>
                      <div class="text-md text-muted mb-2">
                        <i class="bi bi-geo-alt me-1"></i>{item.location || 'No location set'}
                      </div>
                      <div class="d-flex align-items-center justify-content-between">
                        <span class="text-sm"><i class="bi bi-star-fill text-warning me-1"></i>{item.rating} · {item.reviews}</span>
                        {item.lat !== null && item.lng !== null
                          ? <span class="badge bg-light-success text-success">On map</span>
                          : <span class="badge bg-light-secondary text-muted">No coords</span>}
                      </div>
                    </div>
                  </div>
                </div>
              </article>
            </div>
          ))}
        </div>
      )}
    </aside>

    <div class="lm-map-col">
      <div id="listingsMap" role="application" aria-label="Map of listings"></div>
    </div>
  </section>

  <LoginModal />
  <SearchOffcanvas />
  <Footer />

  <script type="application/json" id="listings-map-data" set:html={JSON.stringify(markersPayload)}></script>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>

  <script is:inline>
    (function () {
      const dataEl = document.getElementById('listings-map-data');
      const mapEl = document.getElementById('listingsMap');
      if (!dataEl || !mapEl || typeof L === 'undefined') return;

      let listings = [];
      try { listings = JSON.parse(dataEl.textContent || '[]'); } catch (e) { listings = []; }

      const map = L.map(mapEl, { zoomControl: true, scrollWheelZoom: true });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      }).addTo(map);

      const markers = {};
      const bounds = [];

      listings.forEach(function (l) {
        if (l.lat == null || l.lng == null) return;
        const marker = L.marker([l.lat, l.lng]).addTo(map);
        const popupHtml = [
          l.img ? '<img src="' + escapeHtml(l.img) + '" alt="" class="lm-popup-img" />' : '',
          '<a class="lm-popup-title" href="/listing/' + escapeHtml(l.slug) + '/">' + escapeHtml(l.title) + '</a>',
          '<div class="lm-popup-meta">' + escapeHtml(l.category || '') + ' · ' + escapeHtml(l.price || '') + '</div>',
          '<div class="lm-popup-meta">★ ' + escapeHtml(l.rating || '') + ' · ' + escapeHtml(l.reviews || '') + '</div>',
        ].join('');
        marker.bindPopup(popupHtml, { autoPan: false });
        marker.on('click', function () {
          focusMarker(marker, l.id);
        });
        markers[l.id] = marker;
        bounds.push([l.lat, l.lng]);
      });

      if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 14 });
      } else {
        map.setView([20, 0], 2);
      }

      document.querySelectorAll('.lm-card').forEach(function (card) {
        card.addEventListener('click', function (ev) {
          if (ev.target instanceof HTMLElement && ev.target.closest('a')) return;
          const id = card.getAttribute('data-listing-id');
          const m = id ? markers[id] : null;
          if (m) {
            focusMarker(m, id, { openPopup: true });
          }
        });
      });

      // Center the map on the target marker. On narrow viewports the popup
      // opens above the marker, so we nudge the map so the marker sits ~1/3
      // from the bottom — that keeps the popup fully inside the map area.
      function focusMarker(marker, id, opts) {
        const options = opts || {};
        const targetZoom = Math.max(map.getZoom(), 14);
        map.setView(marker.getLatLng(), targetZoom, { animate: true });
        if (window.innerWidth < 992) {
          const h = map.getSize().y;
          map.panBy([0, -h / 6], { animate: true });
        }
        if (options.openPopup) marker.openPopup();
        highlightCard(id);
      }

      function highlightCard(id) {
        document.querySelectorAll('.lm-card').forEach(function (c) {
          c.classList.toggle('is-active', c.getAttribute('data-listing-id') === id);
        });
        const active = document.querySelector('.lm-card.is-active');
        if (active && active.scrollIntoView) {
          active.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function escapeHtml(s) {
        return String(s == null ? '' : s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }
    })();
  </script>
</Base>
