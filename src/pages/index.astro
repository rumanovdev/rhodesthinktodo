---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { cities, blogs } from '../lib/data/context';
import { getPublishedListings, slugify } from '../lib/supabase/listings';
import { getCategoryTree } from '../lib/supabase/taxonomy';
import { useTranslations, DEFAULT_LOCALE, type Locale } from '../lib/i18n';
export const prerender = false;

const locale: Locale = (Astro.locals as any).locale ?? DEFAULT_LOCALE;
const t = useTranslations(locale);

// GEO/AEO: concise, factual answers AI engines and Google can cite directly.
const homeFaq = [
  {
    q: 'When is the best time to visit Rhodes?',
    a: 'The best time to visit Rhodes is from late April to June and in September to October, when the weather is warm, the sea is swimmable and the crowds are smaller. July and August are the hottest and busiest months, ideal for beach holidays and nightlife.',
  },
  {
    q: 'How many days do you need in Rhodes?',
    a: '3 to 4 days are enough to see the highlights of Rhodes — the medieval Old Town, Lindos and a few of the best beaches. With 5 to 7 days you can also add boat trips, the Valley of the Butterflies and day excursions to nearby islands like Symi.',
  },
  {
    q: 'Is Rhodes expensive?',
    a: 'Rhodes is moderately priced and generally cheaper than islands like Mykonos or Santorini. Traditional tavernas and local beaches are affordable, while prices for hotels and tours rise in peak season (July–August). Travelling in spring or autumn is the most budget-friendly.',
  },
  {
    q: 'Can you explore Rhodes without a car?',
    a: 'Yes. Rhodes Town and the Old Town are easily explored on foot, and regular buses and boats connect to Lindos, Faliraki and the main beaches. A rental car or scooter is only needed if you want to reach remote villages and quieter coves on your own schedule.',
  },
];
const homeFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Show the 8 most recent / featured listings on the home page. Falls back to an empty array
// if Supabase isn't reachable — the rest of the page still renders.
const listings3 = await getPublishedListings(Astro.locals.supabase, { limit: 6 });

// Live counts per category for the Hot & Trending tiles.
const categoryCounts: Record<string, number> = {};
if (Astro.locals.supabase) {
  const { data: countRows } = await Astro.locals.supabase
    .from('listings')
    .select('categories!listings_category_id_fkey(slug)')
    .eq('status', 'published');
  for (const r of countRows ?? []) {
    const slug = (r as any).categories?.slug;
    if (slug) categoryCounts[slug] = (categoryCounts[slug] ?? 0) + 1;
  }
}

// Category tree (mother categories + subcategories) drives the hero filter + tiles.
const catTree = await getCategoryTree(Astro.locals.supabase);
const motherCount = (m: any) =>
  (categoryCounts[m.slug] ?? 0) + m.subcategories.reduce((s: number, sc: any) => s + (categoryCounts[sc.slug] ?? 0), 0);
---
<Base
  title="Rhodes Things to Do | Tours, Hotels & Restaurants"
  description="Discover the best things to do in Rhodes, Greece — top-rated restaurants, hotels, tours, activities, bars & shopping, with real local reviews."
  canonical="/"
  preloadImage="/assets/img/Rhodes_Hero_Lindos.jpg"
  schema={homeFaqSchema}
>
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Hero Start -->
<div class="image-cover hero-header full-height position-relative" style="background:url(/assets/img/Rhodes_Hero_Lindos.jpg)no-repeat;">
	<div class="container">

		<!-- Heading Rwo -->
		<div class="row justify-content-center align-items-center mb-5 pt-lg-0 pt-5">
			<div class="col-12">
				<div class="position-relative text-center">
					<h1 class="hero-title">Rhodes Things To Do</h1>
					<p class="fs-5 fw-bold hero-sub">{t('hero.subtitle')}</p>
				</div>
			</div>
		</div>
		<!-- </row> -->

	</div>
</div>
<!-- Hero End -->


{/* Brand logos strip (Codrops / Shopify / Airbnb / PayPal / Hubspot) removed — was template filler, not real partners. */}


<!-- Trending Category Start -->
<section class="pb-0">
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Explore Rhodes <span class="text-primary">by Category</span></h3>
				</div>
			</div>
		</div>


		<div class="row align-items-center justify-content-center">
			<div class="col-xl-12 col-lg-12 col-md-12 col-sm-12">
				<div class="owl-carousel categorySlider">

					<!-- Components/Home/index/categories.html -->
					{catTree.map((item) => {
						const count = motherCount(item);
						const label = count === 1 ? '1 Listing' : `${count} Listings`;
						return (
							<div class="singleCategory">
								<div class="category-small-wrapper light">
									<a href={`/${item.slug}/`} class="categoryBox">
										<div class="categoryCapstions">
											<div class="catsIcons"><div class="icoBoxx"><i class={`fa-solid ${item.icon}`}></i></div></div>
											<div class="catsTitle"><h5>{item.name}</h5></div>
											<div class="CatsLists"><span class="categorycounter">{label}</span></div>
										</div>
									</a>
								</div>
							</div>
						);
					})}

				</div>
			</div>
		</div>

	</div>
</section>
<!-- Trending Category End -->


<!-- Trending Listing Start -->
<section>
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Explore Trending <span class="text-primary">Listings</span></h3>
				</div>
			</div>
		</div>


		<div class="row align-items-center justify-content-center g-4">

			<!-- Components/Home/home-4/listings3.html -->
			{listings3.map((item) => (
			<div class="col-xl-4 col-lg-4 col-md-6 col-sm-12 col-12">
			    <div class="listingitem-container">
			        <div class="singlelisting-item">
			            <div class="listing-top-item">
			                <a href={`/listing/${slugify(item.title)}/`} class="topLink" aria-label={item.title}>
			                    <div class="position-absolute start-0 top-0 ms-3 mt-3 z-2">
			                        <div class="d-flex align-items-center justify-content-start gap-2">
			                            <span class={`badge badge-xs text-uppercase ${item.color}`}>{item.btn}</span>
			                            <span class="badge badge-xs badge-transparent">{item.dollar}</span>

			                            {item.tag && (
			                                <span class="badge badge-xs badge-transparent"><i class="bi bi-star mb-0 me-1"></i>Featured</span>
			                            )}

			                        </div>
			                    </div>
			                    <img src={item.img} class="img-fluid" alt="Listing Image" loading="lazy">
			                </a>
			                <div class="position-absolute end-0 bottom-0 me-3 mb-3 z-2">
			                    <a href="#" class="bookmarkList" data-bs-toggle="tooltip" data-bs-title="Save Listing"><i class="bi bi-suit-heart m-0"></i></a>
			                </div>
			            </div>
			            <div class="listing-middle-item">
			                <div class="listing-details">
			                    <h4 class="listingTitle"><a href={`/listing/${slugify(item.title)}/`} class="titleLink">{item.title}<span class="verified"><i class="bi bi-patch-check-fill m-0"></i></span></a></h4>
			                    <p>{item.desc}</p>
			                </div>
			                <div class="listing-info-details">
			                    <div class="d-flex align-items-center justify-content-start gap-4">
			                        <div class="list-calls"><i class="bi bi-telephone mb-0 me-2"></i>{item.number}</div>
			                        <div class="list-location"><i class="bi bi-geo-alt mb-0 me-2"></i>{item.location}</div>
			                    </div>
			                </div>
			            </div>
			            <div class="listing-footer-item">
			                <div class="d-flex align-items-center justify-content-between gap-2">
			                    <div class="catdWraps">
			                        <div class="flex-start">
			                            <a href="#" class="d-flex align-items-center justify-content-start gap-2">
			                                <span class={item.span}><i class={item.icon}></i></span>
			                                <span class="catTitle">{item.name}</span>
			                            </a>
			                        </div>
			                        <div class="flex-end"><span class="moreCatcounter">{item.plus}</span></div>
			                    </div>
			                    <div class="listing-shares">
			                        <div class="d-flex align-items-center justify-content-start gap-2">
			                            <a href="#" class="smallLinks" data-bs-toggle="tooltip" data-bs-title="View Listing"><i class="bi bi-eye-fill m-0"></i></a>
			                            <a href="#" class="smallLinks" data-bs-toggle="tooltip" data-bs-title="Save Listing"><i class="bi bi-suit-heart m-0"></i></a>
			                            <a href="#" class="smallLinks" data-bs-toggle="tooltip" data-bs-title="Share Listing"><i class="bi bi-share-fill m-0"></i></a>
			                        </div>
			                    </div>
			                </div>
			            </div>
			        </div>
			    </div>
			</div>
			))}

		</div>

		<div class="row align-items-center justify-content-center mt-5">
			<div class="col-xl-12 col-lg-12 col-md-12 col-12">
				<div class="text-center"><a href="/listings-grid/" class="btn btn-light-primary fw-medium rounded-pill px-md-5">Explore More listings</a></div>
			</div>
		</div>

	</div>
</section>
<!-- Trending Listing End -->


<!-- Listing By Places Start -->
<section class="bg-light">
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Explore Things To Do in <span class="text-primary">Rhodes</span></h3>
				</div>
			</div>
		</div>


		<div class="row align-items-center justify-content-center g-4">

			<!-- Components/Home/home-2/cities.html -->
			{cities.map((item) => (
			<div class={item.style}>
			    <div class="card border-0 rounded-4 ht-300 position-relative">
			        <a href={item.href} class="h-100" aria-label={item.title}>
			            <div class="abx-thumb h-100" data-overlay="3">
			                <img src={item.img} class="w-100 h-100 object-fit" alt={item.title} loading="lazy">
			            </div>
			        </a>
			        <div class="position-absolute top-0 end-0 mt-3 me-3 z-1">
			            <span class="badge badge-xs bg-light text-dark rounded-pill">{item.lists}</span>
			        </div>
			        <div class="position-absolute bottom-0 start-0 mb-3 ms-3 z-1">
			            <div class="d-block w-100 position-relative">
			                <div class="cityTitle">
			                    <h4 class="text-light">{item.title}</h4>
			                </div>
			                <div class="d-flex align-items-center justify-content-start flex-wrap gap-2">
			                    {item.tags.map((tag) => (
			                        <span class="badge badge-xs badge-transparent rounded-pill">{tag}</span>
			                    ))}
			                </div>
			            </div>
			        </div>
			    </div>
			</div>
			))}

		</div>

	</div>
</section>
<!-- Listing By Places End -->


<!-- Why Choose Rhodes Things To Do Start -->
<section>
	<div class="container">
		<div class="row align-items-center justify-content-between g-4">

			<!-- Components/Home/home-4/platform.html -->
			<div class="col-xl-5 col-lg-6 col-md-5">
			    <div class="featuresImage">
			        <img src="/assets/img/search-engine-isometric.svg" class="img-fluid" alt="Features Image">
			    </div>
			</div>

			<div class="col-xl-5 col-lg-6 col-md-6">
			    <div class="featuresCaption">
			        <div class="fstsTitle mb-4">
			            <h3 class="fw-medium lh-base">Why People Love & Select Rhodes Things To Do Platform?</h3>
			        </div>
			        <div class="fstsFeatures mb-4">
			            <div class="d-flex flex-column gap-4">

			                <!-- Single Item -->
			                <div class="d-flex align-items-start justify-content-start gap-3">
			                    <div class="fstlsIcons"><i class="bi bi-piggy-bank text-primary fs-1"></i></div>
			                    <div class="fstlsPara">
			                        <h5 class="fw-medium">Everything in one place</h5>
			                        <p class="lead m-0">Restaurants, beaches, tours, bars and places to stay across Rhodes — organised by category and area so you find the right spot fast.</p>
			                    </div>
			                </div>
			                <!-- Single Item -->
			                <div class="d-flex align-items-start justify-content-start gap-3">
			                    <div class="fstlsIcons"><i class="bi bi-shield-check text-primary fs-1"></i></div>
			                    <div class="fstlsPara">
			                        <h5 class="fw-medium">Verified local listings</h5>
			                        <p class="lead m-0">Every business is checked before it goes live, with real contact details, locations and visitor ratings you can trust.</p>
			                    </div>
			                </div>

			            </div>
			        </div>
			        <div class="fstsButton">
			            <button class="btn btn-light-primary rounded-pill fw-medium" type="button">Submit Your Listing</button>
			        </div>
			    </div>
			</div>

		</div>
	</div>
</section>
<!-- Why Choose Rhodes Things To Do End -->


<!-- Latest Updates Start -->
<section>
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Latest Updates <span class="text-primary">News</span></h3>
				</div>
			</div>
		</div>


		<div class="row align-items-center justify-content-center g-4">

			<!-- Components/Home/index/blog.html -->
			{blogs.slice(0, 3).map((item) => (
			<div class="col-xl-4 col-lg-4 col-md-6">
			    <div class="card rounded-4 shadow-sm h-100">
			        <a href="#" class="d-block bg-gradient rounded-top">
			            <img class="card-img-top hover-fade-out" src={item.img} alt="blog image" loading="lazy">
			        </a>
			        <div class="card-body">
			            <a href={`/blog-detail/${(item as any).slug || slugify(item.title)}/`}><h4 class="fw-medium fs-5 lh-base mb-3">{item.title}</h4></a>
			            <p>{item.desc}</p>
			            <div class="d-flex align-items-center justify-content-start mt-4">
			                <a href="#" class="badge badge-primary rounded-pill">Continue Reading</a>
			            </div>
			        </div>
			    </div>
			</div>
			))}

		</div>

	</div>
</section>
<!-- Latest Updates End -->


<!-- Rhodes Travel FAQ (GEO/AEO) -->
<section class="bg-light">
	<div class="container">
		<div class="row justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center mb-4">
					<h2 class="sectionHeading">Rhodes Travel <span class="text-primary">Questions</span></h2>
				</div>
			</div>
		</div>
		<div class="row justify-content-center">
			<div class="col-xl-9 col-lg-10 col-md-12">
				<div class="accordion accordion-flush homeFaq" id="homeFaqAcc">
					{homeFaq.map((item, i) => (
					<div class="accordion-item border rounded-3 mb-3">
						<h3 class="accordion-header">
							<button class={`accordion-button ${i === 0 ? '' : 'collapsed'} fw-medium`} type="button" data-bs-toggle="collapse" data-bs-target={`#hfaq-${i}`} aria-expanded={i === 0 ? 'true' : 'false'} aria-controls={`hfaq-${i}`}>
								{item.q}
							</button>
						</h3>
						<div id={`hfaq-${i}`} class={`accordion-collapse collapse ${i === 0 ? 'show' : ''}`} data-bs-parent="#homeFaqAcc">
							<div class="accordion-body text-muted">{item.a}</div>
						</div>
					</div>
					))}
				</div>
				<div class="d-flex flex-wrap justify-content-center gap-2 mt-4">
					<a href="/things-to-do/boat-trips/" class="badge badge-primary rounded-pill px-3 py-2">Boat Trips & Cruises</a>
					<a href="/restaurants/" class="badge badge-primary rounded-pill px-3 py-2">Restaurants</a>
					<a href="/accommodation/" class="badge badge-primary rounded-pill px-3 py-2">Hotels & Stays</a>
					<a href="/beaches/" class="badge badge-primary rounded-pill px-3 py-2">Beaches</a>
					<a href="/things-to-do/" class="badge badge-primary rounded-pill px-3 py-2">Things to Do</a>
				</div>
			</div>
		</div>
	</div>
</section>
<!-- Rhodes Travel FAQ End -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />

  <Footer />

  <style is:global>
    /* Hero title — keyword-led, smaller on desktop, no dash */
    .hero-title {
      font-size: clamp(2rem, 4.2vw, 3rem);
      line-height: 1.15;
      font-weight: 600;
    }
    /* Hero text stays white over the photo (no dark overlay), with a shadow for readability. */
    .hero-header .hero-title,
    .hero-header .hero-sub {
      color: #fff !important;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.5), 0 1px 4px rgba(0, 0, 0, 0.55);
    }
    @media (max-width: 575px) {
      .hero-header .hero-sub { font-size: 0.95rem !important; line-height: 1.5; }
    }
    /* Keep the subtitle on a single full-width line on desktop */
    @media (min-width: 992px) {
      .hero-header .hero-sub { white-space: nowrap; }
    }
    /* Keep the hero photo centred and covering on small screens. */
    @media (max-width: 767px) {
      .hero-header {
        background-position: center center !important;
        background-size: cover !important;
      }
    }
  </style>
</Base>
