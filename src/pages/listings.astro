---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { alls, slistings } from '../lib/data/context';
import { getPublishedListings, slugify } from '../lib/supabase/listings';
export const prerender = false;

const listings6 = await getPublishedListings(Astro.locals.supabase);
---
<Base
  title="Rhodes Listings — Places to Eat, Stay & Explore | Rhodes Things To Do"
  description="Explore listings across Rhodes, Greece in a simple list view — restaurants, hotels, tours, activities and more, with ratings and local reviews."
  canonical="/listings/"
>
  <Navbar headerClass="header header-dark navdark position-relative" logo="/assets/img/rhodes-logo.svg" addListingLight={true} />

<Preloader />

<div class="clearfix"></div>

<!-- Filter Search Options Start -->
<div class="bg-white py-3 sticky-lg-top z-3">
	<div class="container">

		<!-- Components/Listings/Grid-Layouts/grid-layout-02/filter.html -->
		<!-- Banner Title -->
		<div class="row justify-content-between align-items-center g-3">
		    <div class="col">

		        <div class="filterOptions-wrap d-flex justify-content-between align-items-center gap-2">

		            <div class="filter-mobile d-lg-none">
		                <a href="#filterSlider" data-bs-toggle="offcanvas" data-bs-target="#filterSlider" aria-controls="filterSlider" class="btn btn-md btn-light-primary rounded-pill"><i class="bi bi-funnel me-2"></i>Filter Option</a>
		            </div>

		            <div class="filter-desktop d-none d-lg-block">
		                <!-- Rating Filter -->
		                <div class="dropdown d-inline-flex p-0">
		                    <a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="catsfilter" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
		                        Categories
		                    </a>
		                    <div class="dropdown-menu border shadow-sm">
		                        <div class="card rounded-3">
		                            <div class="card-body p-4">
		                                <div class="row align-items-start gy-2">

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="eatdrink1">
		                                          <label class="form-check-label" for="eatdrink1">Eat & Drink</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="apartments1">
		                                          <label class="form-check-label" for="apartments1">Apartments</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="classifieds1">
		                                          <label class="form-check-label" for="classifieds1">Classified</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="services1">
		                                          <label class="form-check-label" for="services1">Services</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="gymfitness1">
		                                          <label class="form-check-label" for="gymfitness1">Gym & Fitness</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="nightlife1">
		                                          <label class="form-check-label" for="nightlife1">Night Life</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="coachings1">
		                                          <label class="form-check-label" for="coachings1">Coaching</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="shoppings1">
		                                          <label class="form-check-label" for="shoppings1">Shopping</label>
		                                        </div>
		                                    </div>

		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>

		                <!-- Rating Filter -->
		                <div class="dropdown d-inline-flex p-0">
		                    <a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="ratingsfilter" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
		                        Rating Filter
		                    </a>
		                    <div class="dropdown-menu border shadow-sm">
		                        <div class="card rounded-3">
		                            <div class="card-body p-4">
		                                <div class="filterButton">

		                                    <!-- Components/Listings/Grid-Layouts/grid-layout-01/all.html -->
		                                    {alls.map((item) => (
		                                    <div class="filterFlex">
		                                        <input type="radio" class="btn-check" name="ratingsfilter" id={item.id} checked={item.check === 'checked'}>
		                                        <label class="btn" for={item.id}><i class="bi bi-star-fill me-1"></i>{item.title}</label>
		                                    </div>
		                                    ))}

		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>

		                <!-- Price Filter -->
		                <div class="dropdown d-inline-flex p-0">
		                    <a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="pricefilter" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
		                        Price Filter
		                    </a>
		                    <div class="dropdown-menu pt-2 border-0 shadow-sm">
		                        <div class="card rounded-3">
		                            <div class="card-body">
		                                <p class="fw-medium">Price Range in $ USD</p>
		                                <div class="searchBar-single-wrap mt-2">
		                                    <input type="text" class="pricefilter" name="my_range" value="" data-skin="round"
		                                        data-type="double" data-grid="false">
		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>

		                <!-- Distance -->
		                <div class="dropdown d-inline-flex p-0">
		                    <a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="distancefilter" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
		                        Distance
		                    </a>
		                    <div class="dropdown-menu pt-2 border-0 shadow-sm">
		                        <div class="card rounded-3">
		                            <div class="card-body">
		                                <p class="fw-medium">Distance Filter Show in Km</p>
		                                <div class="searchBar-single-wrap mt-2">
		                                    <input type="text" class="distancefilter" name="my_range" value="" data-skin="round"
		                                        data-type="single" data-grid="false">
		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>

		                <!-- More Filter -->
		                <div class="dropdown d-inline-flex p-0">
		                    <a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="morefilter" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
		                        More Filter
		                    </a>
		                    <div class="dropdown-menu pt-2 border-0 shadow-sm">
		                        <div class="card rounded-3">
		                            <div class="card-body p-4">
		                                <div class="row align-items-start gy-2">

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="goods1">
		                                          <label class="form-check-label" for="goods1">Good for Kids</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="dogs1">
		                                          <label class="form-check-label" for="dogs1">Dogs Allowed</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="seatings1">
		                                          <label class="form-check-label" for="seatings1">Outdoor Seating</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="alcohal1">
		                                          <label class="form-check-label" for="alcohal1">Alcohol</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="breakfast1">
		                                          <label class="form-check-label" for="breakfast1">Breakfast</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="books1">
		                                          <label class="form-check-label" for="books1">Instant Book</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="smokings1">
		                                          <label class="form-check-label" for="smokings1">Smoking Allowed</label>
		                                        </div>
		                                    </div>

		                                    <div class="col-xl-4 col-lg-4 col-md-4 col-sm-6">
		                                        <div class="form-check form-check-inline">
		                                          <input class="form-check-input" type="checkbox" id="wifi1">
		                                          <label class="form-check-label" for="wifi1">Free WiFi</label>
		                                        </div>
		                                    </div>

		                                </div>
		                            </div>
		                        </div>
		                    </div>
		                </div>
		            </div>

		        </div>

		    </div>

		    <div class="col">
		        <ul class="nav nav-pills nav-fill gap-2 small d-inline-flex lightprimary border rounded-pill p-1 float-end">
		          <li class="nav-item" role="presentation">
		            <a href="/listings/" class="nav-link rounded-pill active" id="buy1" aria-selected="true"><i class="bi bi-list me-2"></i>List</a>
		          </li>
		          <li class="nav-item" role="presentation">
		            <a href="/listings-grid/" class="nav-link rounded-pill" id="rent1" aria-selected="false"><i class="bi bi-ui-radios-grid me-2"></i>Grid</a>
		          </li>
		          <li class="nav-item" role="presentation">
		            <a href="/listings-map/" class="nav-link rounded-pill" id="mapv1" aria-selected="false"><i class="bi bi-geo-alt me-2"></i>Map</a>
		          </li>
		        </ul>
		    </div>
		</div>
		<!-- Banner Title -->

	</div>
</div>
<!-- Filter Search Options End -->


<!-- Search List Start -->
<section class="bg-light">
	<div class="container">

		<div class="row align-items-center justify-content-between mb-4">
			<div class="col-xl- 5 col-lg-5 col-md-5 col-sm-6 col-6">
				<div class="totalListingshow">
					<h6 class="fw-medium text-md mb-0">106 Listings Founds</h6>
				</div>
			</div>

			<div class="col-xl- 5 col-lg-5 col-md-5 col-sm-6 col-6">
				<div class="text-end">
					<!-- Rating Filter -->
					<div class="dropdown d-inline-flex p-0">
						<a href="#" class="py-2 px-3 dropdown-toggle toogleDrops" id="shortfilter" data-bs-toggle="dropdown" aria-expanded="false">
							Short Listings
						</a>
						<div class="dropdown-menu border shadow-sm">
							<ul class="card rounded-0 p-0">

								<!-- Components/Listings/Grid-Layouts/grid-layout-01/short-listings.html -->
								{slistings.map((item) => (
								<li><a class={`${item.class} dropdown-item`} href="#">{item.title}</a></li>
								))}

							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="row align-items-center justify-content-center g-xl-4 g-3">

			<!-- Components/Listings/List-Layouts/list-layout-02/listings9.html -->
			{listings6.map((item) => (
			<div class="col-xl-6 col-lg-12 col-md-12 col-sm-12">
			    <div class="listingCard listLayouts card rounded-3 border-0">

			        <div class="row align-items-center justify-content-start g-3">

			            <!-- Property Thumb -->
			            <div class="col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
			                <div class="listThumb overflow-hidden position-relative">
			                    <div class="position-absolute start-0 top-0 ms-3 mt-3"><span class={`badge badge-xs text-uppercase ${item.color} rounded-pill`}>{item.btn}</span></div>

			                    {item.tag === 'true' && (
			                        <div class="position-absolute end-0 bottom-0 me-3 mb-3"><span class="badge badge-xs featuredList rounded-pill"><i class="fa-solid fa-star me-1"></i>{item.btn1}</span></div>
			                    )}

			                    <a href="#" class="d-block"><img src={item.img} class="img-fluid list-thumb object-fit" alt="Listing Img"></a>
			                </div>
			            </div>

			            <!-- Property Info -->
			            <div class="col-xl-8 col-lg-8 col-md-8 col-sm-12 col-12">
			                <div class="listCaption px-3 py-4">
			                    <div class="listTitle d-block mb-4">
			                        <div class="d-flex align-items-start justify-content-between gap-2">
			                            <div class="flex-first">
			                                <div class="d-flex align-items-center justify-content-start gap-2 flex-wrap mb-3">
			                                    <div class="singleCaption">
			                                        <div class="bg-light border rounded-pill py-1 ps-1 pe-3">
			                                            <div class="d-inline-flex align-items-center justify-content-start gap-2">
			                                                <span class="square--25 circle bg-price text-light text-sm"><i class="bi bi-coin lh-1 h-auto"></i></span>
			                                                <span class="text-sm fw-medium">{item.price}</span>
			                                            </div>
			                                        </div>
			                                    </div>

			                                    {item.tag1 === 'true' && (
			                                        <div class="singleCaption">
			                                            <div class="bg-light border rounded-pill py-1 ps-1 pe-3">
			                                                <div class="d-inline-flex align-items-center justify-content-start gap-2">
			                                                    <span class="square--25 circle bg-booking text-light text-sm"><i class="bi bi-lightning-charge-fill lh-1 h-auto"></i></span>
			                                                    <span class="text-sm fw-medium">{item.btn2}</span>
			                                                </div>
			                                            </div>
			                                        </div>
			                                    )}

			                                </div>
			                                <h5 class="listItemtitle"><a href={`/listing/${slugify(item.title)}/`}>{item.title}<span class="verified"><i class="bi bi-patch-check-fill m-0"></i></span></a></h5>
			                                <div class="d-flex align-items-center justify-content-start flex-wrap gap-3">
			                                    <div class="flex-start"><div class="list-location text-muted"><span><i class="fa-solid fa-location-dot me-2"></i>{item.location}</span></div></div>
			                                    <div class="flex-last">
			                                        <div class="d-flex align-items-center justify-content-start">
			                                            <i class="fa-solid fa-star text-warning"></i><span class="mx-1 text-dark fw-bold">{item.rating}</span><span class="text-md text-muted">({item.reviews})</span>
			                                        </div>
			                                    </div>
			                                </div>
			                            </div>
			                            <div class="flex-last">
			                                <a href="#" class="bookmarkList"><i class="fa-regular fa-heart"></i></a>
			                            </div>
			                        </div>
			                    </div>
			                    <div class="list-features d-flex align-items-center justify-content-start row-gap-2 column-gap-3 text-dark">
			                        <div class="d-flex align-items-center fw-medium">
			                            <span class={`${item.span} me-2`}><i class={`${item.icon} text-md`}></i></span>{item.name}
			                        </div>
			                        <div class="d-flex align-items-center fw-medium">
			                            <span class="listCall me-2"><i class="bi bi-telephone"></i></span>{item.number}
			                        </div>
			                    </div>
			                </div>
			            </div>

			        </div>
			    </div>
			</div>
			))}

		</div>

		<!-- Components/Listings/Grid-Layouts/grid-layout-01/pagination.html -->
		<!-- Pagination Start -->
		<div class="row align-items-center justify-content-center mt-5">
		    <div class="col-xl-12 col-lg-12 col-md-12">
		        <nav aria-label="Page navigation example">
		          <ul class="pagination justify-content-center">
		            <li class="page-item">
		              <a class="page-link"><i class="fa-solid fa-arrow-left"></i></a>
		            </li>
		            <li class="page-item"><a class="page-link" href="#">1</a></li>
		            <li class="page-item active"><a class="page-link" href="#">2</a></li>
		            <li class="page-item"><a class="page-link" href="#">3</a></li>
		            <li class="page-item"><a class="page-link" href="#">4</a></li>
		            <li class="page-item"><a class="page-link" href="#">5</a></li>
		            <li class="page-item">
		              <a class="page-link" href="#"><i class="fa-solid fa-arrow-right"></i></a>
		            </li>
		          </ul>
		        </nav>
		    </div>
		</div>
		<!-- Pagination END -->

	</div>
</section>
<!-- Search List End -->



<!-- Call To Action Start -->
<section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
	<div class="container">

		<!-- Components/Home/index/subscribe.html -->
		<Subscribe />

	</div>
</section>
<!-- Call To Action Start -->

	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<!-- Components/Listings/Grid-Layouts/grid-layout-02/offcanvas.html -->
	<div class="offcanvas offcanvas-start" data-bs-scroll="true" tabindex="-1" id="filterSlider" aria-labelledby="filterSliderLabel">
	    <div class="offcanvas-header border-bottom py-3">
	        <h3 class="h5">Filters</h3>
	        <button type="button" class="btn-close text-sm d-lg-none" data-bs-dismiss="offcanvas" data-bs-target="#filterSidebar" aria-label="Close"></button>
	    </div>
	    <div class="offcanvas-body overflow-x-hidden p-4 p-lg-0" id="filterSliderLabel">

	        <!-- Options -->
	        <div class="searchInner">

	            <div class="search-inner">

	                <div class="filter-search-box mb-4">
	                    <div class="form-group">
	                        <input type="text" class="form-control" placeholder="Search listing..">
	                    </div>
	                </div>

	                <div class="prtsTypes mb-4">
	                    <div class="filterButton">

	                        <div class="filterFlex">
	                            <input type="radio" class="btn-check" name="ratingsfilter" id="alls" checked>
	                            <label class="btn" for="alls"><i class="bi bi-star-fill me-1"></i>All</label>
	                        </div>

	                        <div class="filterFlex">
	                            <input type="radio" class="btn-check" name="ratingsfilter" id="threepluss">
	                            <label class="btn" for="threepluss"><i class="bi bi-star-fill me-1"></i>3.0+</label>
	                        </div>

	                        <div class="filterFlex">
	                            <input type="radio" class="btn-check" name="ratingsfilter" id="fourpluss">
	                            <label class="btn" for="fourpluss"><i class="bi bi-star-fill me-1"></i>4.0+</label>
	                        </div>

	                        <div class="filterFlex">
	                            <input type="radio" class="btn-check" name="ratingsfilter" id="fivepluss">
	                            <label class="btn" for="fivepluss"><i class="bi bi-star-fill me-1"></i>5.0</label>
	                        </div>

	                    </div>
	                </div>

	                <!-- Categories -->
	                <div class="filter-search-box mb-4">
	                    <div class="filtersearch-title"><h6 class="mb-2 lh-base text-sm text-uppercase fw-medium">Categories</h6></div>
	                    <div class="row align-items-center justify-content-between gy-2">
	                        <div class="col-xl-12 col-lg-12 col-md-12">
	                            <div class="d-flex align-items-center justify-content-center flex-wrap gap-2 mb-3">

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="eatdrink1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="eatdrink1s">Eat & Drink</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="Apartmentss">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="Apartmentss">Apartments</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="classifieds1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="classifieds1s">Classified</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="services1s" checked>
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="services1s">Services</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="gymfitness1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="gymfitness1s">Gym & Fitness</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="nightlife1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="nightlife1s">Night Life</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="coachings1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="coachings1s">Coaching</label>
	                                </div>

	                                <!-- Item -->
	                                <div class="form-checks flex-fill">
	                                    <input type="checkbox" class="btn-check" id="shoppings1s">
	                                    <label class="btn btn-sm btn-secondary rounded-1 fw-medium full-width" for="shoppings1s">Shopping</label>
	                                </div>

	                            </div>
	                        </div>
	                    </div>
	                </div>

	                <!-- Price Range -->
	                <div class="filter-search-box mb-4">
