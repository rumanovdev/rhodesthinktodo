---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';

// Curated, accurate FAQs for rich-result / AI eligibility (kept separate from
// the template's placeholder accordion copy so the markup stays honest).
const faqSchemaItems = [
  {
    q: 'What is Rhodes Things To Do?',
    a: 'Rhodes Things To Do is a local directory and guide for the island of Rhodes, Greece, where you can discover restaurants and tavernas, hotels and stays, tours, activities, bars, shopping and wellness — with real listings and reviews.',
  },
  {
    q: 'How do I find things to do in Rhodes?',
    a: 'Use the search bar or browse by category (Restaurants, Hotels, Tours, Activities, Bars & Nightlife, Shopping, Spa & Wellness) and explore listings on the interactive map to find places near you.',
  },
  {
    q: 'Is it free to use Rhodes Things To Do?',
    a: 'Yes. Browsing listings, reading reviews and exploring the map is completely free for visitors.',
  },
  {
    q: 'How can I list my business on Rhodes Things To Do?',
    a: 'Create an account and submit your listing from the dashboard. Once approved, your business appears in the relevant category and on the map.',
  },
  {
    q: 'How do I contact Rhodes Things To Do?',
    a: 'You can reach us by phone at +30 690 791 7676 or by email at info@rhodesthingstodo.com.',
  },
];
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqSchemaItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Base
  title="FAQ — Frequently Asked Questions | Rhodes Things To Do"
  description="Answers to common questions about Rhodes Things To Do — how to find things to do in Rhodes, listing your business, reviews and how to contact us."
  canonical="/faq/"
  schema={faqSchema}
>
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Page Title Start -->
<section class="bg-light">
	<div class="container">

		<!-- Search Form -->
		<div class="row justify-content-start align-items-center pt-lg-0 pt-5">
			<div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
				<div class="position-relative">
					<h1 class="xl-heading">FAQ's</h1>

</div>
			</div>
		</div>
		<!-- </row> -->

	</div>
</section>
<!-- Page Title End -->


<!-- FAQ's Section -->
<section>
	<div class="container">
		<div class="row align-items-start justify-content-center">
			<div class="col-xl-9 col-lg-10 col-md-12">
				<div class="accordion accordion-flush faqAccordion" id="rttdFaq">
					{faqSchemaItems.map((item, i) => (
					<div class="accordion-item border rounded-3 mb-3">
						<h2 class="accordion-header">
							<button class={`accordion-button ${i === 0 ? '' : 'collapsed'} fw-medium`} type="button" data-bs-toggle="collapse" data-bs-target={`#faq-${i}`} aria-expanded={i === 0 ? 'true' : 'false'} aria-controls={`faq-${i}`}>
								{item.q}
							</button>
						</h2>
						<div id={`faq-${i}`} class={`accordion-collapse collapse ${i === 0 ? 'show' : ''}`} data-bs-parent="#rttdFaq">
							<div class="accordion-body text-muted">{item.a}</div>
						</div>
					</div>
					))}
				</div>
			</div>
		</div>
	</div>
</section>
<!-- FAQ's Section End -->


<!-- Call To Action Start -->

<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


	<Footer />
</Base>
