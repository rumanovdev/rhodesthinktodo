---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/nav/Navbar.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { getServiceClient } from '../../lib/supabase/admin';

export const prerender = false;
if (!Astro.locals.isAdmin) return Astro.redirect('/');

const admin = getServiceClient();
const notice = Astro.url.searchParams.get('notice');
const error = Astro.url.searchParams.get('error');

let areas: any[] = [];
let listingsByArea = new Map<number, number>();
if (admin) {
  const [{ data: a }, { data: l }] = await Promise.all([
    admin.from('areas').select('id, slug, name, parent_id, lat, lng, sort_order, is_active').order('sort_order'),
    admin.from('listings').select('area_id'),
  ]);
  areas = a ?? [];
  for (const row of (l ?? []) as any[]) if (row.area_id) listingsByArea.set(row.area_id, (listingsByArea.get(row.area_id) ?? 0) + 1);
}
const roots = areas.filter((a) => a.parent_id == null);
const childrenOf = (id: number) => areas.filter((a) => a.parent_id === id);
---
<Base noindex title="Admin — Areas | Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />
  <section class="gray-simple pt-4 pb-5 mt-5">
    <div class="container-fluid px-lg-5">
      <div class="row g-4">
        <div class="col-xl-2 col-lg-3"><AdminSidebar current="areas" /></div>
        <div class="col-xl-10 col-lg-9">
          <h1 class="fs-3 fw-semibold mb-1">Areas</h1>
          <p class="text-muted mb-4">Towns and neighbourhoods used across listings, filters, and the “Best … in …” pages. New areas appear in the add-listing form and area dropdowns instantly.</p>

          {notice && <div class="alert alert-success">{notice}</div>}
          {error && <div class="alert alert-danger">{error}</div>}

          <!-- Add area -->
          <div class="card rounded-4 shadow-sm p-3 mb-4">
            <form method="post" action="/api/admin/areas" class="row g-2 align-items-end">
              <input type="hidden" name="_action" value="add" />
              <div class="col-md-4">
                <label class="form-label text-sm text-muted mb-1">New area name</label>
                <input type="text" name="name" required maxlength="60" class="form-control" placeholder="e.g. Stegna" />
              </div>
              <div class="col-md-3">
                <label class="form-label text-sm text-muted mb-1">Parent</label>
                <select name="parent_id" class="form-select">
                  {roots.map((r) => <option value={r.id}>{r.name} (island)</option>)}
                  {roots.flatMap((r) => childrenOf(r.id)).map((t) => <option value={t.id}>{t.name}</option>)}
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label text-sm text-muted mb-1">Latitude</label>
                <input type="number" step="0.0000001" name="lat" class="form-control" placeholder="36.30" />
              </div>
              <div class="col-md-2">
                <label class="form-label text-sm text-muted mb-1">Longitude</label>
                <input type="number" step="0.0000001" name="lng" class="form-control" placeholder="28.10" />
              </div>
              <div class="col-md-1">
                <button type="submit" class="btn btn-primary rounded-pill"><i class="bi bi-plus-lg"></i></button>
              </div>
            </form>
          </div>

          <!-- Tree -->
          {roots.map((root) => (
            <div class="card rounded-4 shadow-sm p-3 mb-3">
              <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-geo-alt-fill text-primary"></i>
                <strong>{root.name}</strong>
                <span class="text-sm text-muted">island root</span>
              </div>
              <ul class="list-unstyled ps-4 mb-0 d-flex flex-column gap-2">
                {childrenOf(root.id).map((t: any) => (
                  <li class="border-bottom pb-2">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                      <span>
                        {t.name} <span class="text-sm text-muted">/{t.slug}/ · {listingsByArea.get(t.id) ?? 0} listings{t.lat != null ? '' : ' · no coords'}</span>
                        {!t.is_active && <span class="badge bg-secondary rounded-pill ms-1">inactive</span>}
                      </span>
                      <span class="d-flex gap-1">
                        <form method="post" action="/api/admin/areas" class="d-flex gap-1">
                          <input type="hidden" name="_action" value="rename" />
                          <input type="hidden" name="id" value={t.id} />
                          <input type="text" name="name" value={t.name} class="form-control form-control-sm" style="width:170px" />
                          <button type="submit" class="btn btn-sm btn-light border rounded-pill" title="Rename"><i class="bi bi-check2"></i></button>
                        </form>
                        <form method="post" action="/api/admin/areas">
                          <input type="hidden" name="_action" value="toggle" />
                          <input type="hidden" name="id" value={t.id} />
                          <button type="submit" class="btn btn-sm btn-light border rounded-pill" title={t.is_active ? 'Deactivate' : 'Activate'}>
                            <i class={`bi ${t.is_active ? 'bi-eye-slash' : 'bi-eye'}`}></i>
                          </button>
                        </form>
                      </span>
                    </div>
                    {childrenOf(t.id).length > 0 && (
                      <ul class="list-unstyled ps-4 mt-2 mb-0 d-flex flex-column gap-1">
                        {childrenOf(t.id).map((n: any) => (
                          <li class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <span class="text-sm">↳ {n.name} <span class="text-muted">/{n.slug}/ · {listingsByArea.get(n.id) ?? 0} listings</span>
                              {!n.is_active && <span class="badge bg-secondary rounded-pill ms-1">inactive</span>}</span>
                            <span class="d-flex gap-1">
                              <form method="post" action="/api/admin/areas">
                                <input type="hidden" name="_action" value="toggle" />
                                <input type="hidden" name="id" value={n.id} />
                                <button type="submit" class="btn btn-sm btn-light border rounded-pill" title={n.is_active ? 'Deactivate' : 'Activate'}>
                                  <i class={`bi ${n.is_active ? 'bi-eye-slash' : 'bi-eye'}`}></i>
                                </button>
                              </form>
                            </span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          ))}

        </div>
      </div>
    </div>
  </section>
</Base>
