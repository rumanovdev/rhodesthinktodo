---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/nav/Navbar.astro';
import Footer from '../../components/nav/Footer.astro';
import AdminSidebar from '../../components/admin/AdminSidebar.astro';
import { getServiceClient } from '../../lib/supabase/admin';

export const prerender = false;
if (!Astro.locals.isAdmin) return Astro.redirect('/');

const admin = getServiceClient();
const notice = Astro.url.searchParams.get('notice');
const error = Astro.url.searchParams.get('error');
const status = Astro.url.searchParams.get('status') ?? '';

let rows: any[] = [];
if (admin) {
  let q = admin
    .from('bookings')
    .select('id, start_date, end_date, guests, status, notes, contact_name, contact_email, contact_phone, created_at, listings(title, slug)')
    .order('created_at', { ascending: false })
    .limit(300);
  if (status) q = q.eq('status', status as any);
  const { data } = await q;
  rows = data ?? [];
}
const fmtDate = (iso: string | null) => (iso ? new Date(iso).toLocaleDateString('en-GB') : '—');
const badge = (s: string) =>
  s === 'confirmed' ? 'bg-success' : s === 'pending' ? 'bg-warning text-dark' : s === 'completed' ? 'bg-primary' : 'bg-secondary';
---
<Base noindex title="Admin — Bookings | Rhodes Things To Do">
  <Navbar headerClass="header header-light head-shadow" />
  <section class="gray-simple pt-4 pb-5 mt-5">
    <div class="container-fluid px-lg-5">
      <div class="row g-4">
        <div class="col-xl-2 col-lg-3"><AdminSidebar current="bookings" /></div>
        <div class="col-xl-10 col-lg-9">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
            <h1 class="fs-3 fw-semibold mb-0">Bookings <span class="text-muted fs-6 fw-normal">({rows.length})</span></h1>
            <div class="btn-group">
              <a href="/admin/bookings/" class={`btn btn-sm ${!status ? 'btn-primary' : 'btn-light border'}`}>All</a>
              {['pending', 'confirmed', 'completed', 'cancelled'].map((s) => (
                <a href={`/admin/bookings/?status=${s}`} class={`btn btn-sm ${status === s ? 'btn-primary' : 'btn-light border'}`}>{s}</a>
              ))}
            </div>
          </div>

          {notice && <div class="alert alert-success">{notice}</div>}
          {error && <div class="alert alert-danger">{error}</div>}

          <div class="card rounded-4 shadow-sm overflow-hidden">
            <div class="table-responsive">
              <table class="table align-middle mb-0">
                <thead class="bg-light">
                  <tr>
                    <th class="ps-4">Listing</th><th>Guest</th><th>Dates</th><th>Guests</th>
                    <th>Notes</th><th>Status</th><th>Requested</th><th class="text-end pe-4">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.length === 0 && <tr><td colspan="8" class="text-center text-muted py-5">No bookings{status ? ` with status "${status}"` : ' yet'}.</td></tr>}
                  {rows.map((b: any) => (
                    <tr>
                      <td class="ps-4">
                        {b.listings?.slug
                          ? <a href={`/listing/${b.listings.slug}/`} target="_blank" class="fw-medium text-dark text-decoration-none">{b.listings.title}</a>
                          : <span class="text-muted">(deleted listing)</span>}
                      </td>
                      <td class="text-sm">
                        <div class="fw-medium">{b.contact_name || '—'}</div>
                        <div class="text-muted">{b.contact_email || ''}</div>
                        <div class="text-muted">{b.contact_phone || ''}</div>
                      </td>
                      <td class="text-sm">{fmtDate(b.start_date)}{b.end_date ? ` → ${fmtDate(b.end_date)}` : ''}</td>
                      <td>{b.guests ?? 1}</td>
                      <td class="text-sm" style="max-width:220px"><span class="d-inline-block text-truncate" style="max-width:220px" title={b.notes ?? ''}>{b.notes || '—'}</span></td>
                      <td><span class={`badge rounded-pill ${badge(b.status)}`}>{b.status}</span></td>
                      <td class="text-sm">{fmtDate(b.created_at)}</td>
                      <td class="text-end pe-4">
                        <div class="d-inline-flex gap-1">
                          {b.status !== 'confirmed' && (
                            <form method="post" action="/api/admin/bookings">
                              <input type="hidden" name="booking_id" value={b.id} />
                              <input type="hidden" name="_action" value="confirm" />
                              <button type="submit" class="btn btn-sm btn-light border rounded-pill text-success" title="Confirm"><i class="bi bi-check2-circle"></i></button>
                            </form>
                          )}
                          {b.status !== 'completed' && (
                            <form method="post" action="/api/admin/bookings">
                              <input type="hidden" name="booking_id" value={b.id} />
                              <input type="hidden" name="_action" value="complete" />
                              <button type="submit" class="btn btn-sm btn-light border rounded-pill" title="Mark completed"><i class="bi bi-flag"></i></button>
                            </form>
                          )}
                          {b.status !== 'cancelled' && (
                            <form method="post" action="/api/admin/bookings">
                              <input type="hidden" name="booking_id" value={b.id} />
                              <input type="hidden" name="_action" value="cancel" />
                              <button type="submit" class="btn btn-sm btn-light border rounded-pill text-warning" title="Cancel"><i class="bi bi-x-circle"></i></button>
                            </form>
                          )}
                          <form method="post" action="/api/admin/bookings" onsubmit="return confirm('Delete this booking?');">
                            <input type="hidden" name="booking_id" value={b.id} />
                            <input type="hidden" name="_action" value="delete" />
                            <button type="submit" class="btn btn-sm btn-light border rounded-pill text-danger" title="Delete"><i class="bi bi-trash"></i></button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>
  <Footer />
</Base>
