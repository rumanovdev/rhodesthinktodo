---
import Base from '../../layouts/Base.astro';
import Navbar from '../../components/nav/Navbar.astro';
import Footer from '../../components/nav/Footer.astro';
import Subscribe from '../../components/shared/Subscribe.astro';
import LoginModal from '../../components/shared/LoginModal.astro';
import SearchOffcanvas from '../../components/shared/SearchOffcanvas.astro';
import Preloader from '../../components/shared/Preloader.astro';
import { articles, tags, blogs } from '../../lib/data/context';
import { absUrl } from '../../lib/data/site';

export async function getStaticPaths() {
  const { blogs } = await import('../../lib/data/context');
  const slugifyFn = (s: string) =>
    s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
  return blogs.map((blog) => ({
    params: { slug: (blog as any).slug || slugifyFn((blog as any).title) },
    props: { blog },
  }));
}

const { blog } = Astro.props as { blog: any };
const heroImg = blog.img || '/assets/img/gal-4.jpg';
const heroTitle = blog.title || 'Top 10 Free Bootstrap Templates for Your Next Project';
const heroDate = blog.date || '6 Sep 2025';

const slug = (blog as any).slug || heroTitle.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
const recentPosts = (blogs as any[]).filter((b) => b.slug !== slug).slice(0, 4);
const postUrl = absUrl(`/blog-detail/${slug}/`);
const seoDescription = (blog.desc || blog.excerpt || `${heroTitle} — a Rhodes travel story and guide from Rhodes Things To Do.`)
  .toString().replace(/\s+/g, ' ').trim().slice(0, 160);
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: heroTitle,
  image: absUrl(heroImg),
  url: postUrl,
  mainEntityOfPage: postUrl,
  ...(blog.author ? { author: { '@type': 'Person', name: blog.author } } : { author: { '@type': 'Organization', name: 'Rhodes Things To Do' } }),
  publisher: {
    '@type': 'Organization',
    name: 'Rhodes Things To Do',
    logo: { '@type': 'ImageObject', url: absUrl('/assets/img/logo.svg') },
  },
};
---
<Base
  title={`${heroTitle} | Rhodes Things To Do`}
  description={seoDescription}
  canonical={`/blog-detail/${slug}/`}
  ogImage={heroImg}
  ogType="article"
  schema={blogSchema}
>
  <Navbar headerClass="header header-light" />

  <div class="bg-light">

    <Preloader />

    <div class="clearfix"></div>

    <!-- Page Title Start -->
    <section>
      <div class="container">

        <!-- Search Form -->
        <div class="row justify-content-start align-items-center pt-lg-0 pt-5">
          <div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
            <div class="position-relative">
              <h2 class="xl-heading">Blog</h2>
              <nav id="breadcrumbs" class="breadcrumbs">
                <ul>
                  <li><a href="/">Home</a></li>
                  <li><a href="#">Blog</a></li>
                  <li>Blog Detail</li>
                </ul>
              </nav>
            </div>
          </div>
        </div>
        <!-- </row> -->

      </div>
    </section>
    <!-- Page Title End -->

    <!-- Articles Deatil Section -->
    <section class="pt-0">
      <div class="container">
        <div class="row g-4">

          <!-- Article content -->
          <div class="col-xl-8 col-lg-8 col-md-8 col-sm-12">
            <div class="blogDetails d-flex align-items-start gap-4 flex-column w-100">

              <!-- First Card -->
              <div class="card shadow-sm w-100">

                <div class="blogThumb">
                  <img src={heroImg} class="img-fluid" alt="Blog Thumb" />
                </div>

                <div class="card-body">

                  <!-- Badge -->
                  <div class="d-inline-flex mb-2"><span class="badge badge-xs badge-primary rounded-pill">{(blog as any).badge || 'Rhodes Guide'}</span></div>

                  <!-- Title -->
                  <h1 class="fs-3">{heroTitle}</h1>
                  <div class="d-flex align-items-center justify-content-start flex-wrap gap-3 mb-3">
                    <div>By <span class="link">Rhodes Things To Do</span></div>
                  </div>

                  <div class="article-body" set:html={blog.body}></div>

                </div>


              </div>
              <!-- First Card -->


            </div>

          </div>

          <!-- Blog Sidebar -->
          <div class="col-xl-4 col-lg-4 col-md-4 col-sm-12">
            <div class="blogSidebar d-flex flex-column align-items-start gap-4">

              <!-- Search -->
              <div class="card">
                <div class="card-header">
                  <h4>Search</h4>
                </div>
                <div class="card-body">
                  <div class="p-2 ps-3 rounded border d-flex align-items-center justify-content-between gap-2">
                    <div class="searchicons"><span><i class="bi bi-search fs-4 opacity-75"></i></span></div>
                    <div class="flex-fill"><input type="search" class="form-control border-0 ps-0" placeholder="What are you looking for?" /></div>
                  </div>
                </div>
              </div>

              <!-- Recent Articles -->
              <div class="card">
                <div class="card-header">
                  <h4>Recent Articles</h4>
                </div>
                <div class="card-body">
                  <div class="similarPosts">
                    <ul>

                      {recentPosts.map((item: any) => (
                        <li>
                          <div class="postThumb"><a href={`/blog-detail/${item.slug}/`} class="postImg"><figure><img src={item.img} class="img-fluid rounded" alt={item.title} /></figure></a></div>
                          <div class="postCaps">
                            <h6><a href={`/blog-detail/${item.slug}/`} class="link">{item.title}</a></h6>
                          </div>
                        </li>
                      ))}

                    </ul>
                  </div>
                </div>
              </div>

              <!-- Search -->
              <div class="card">
                <div class="card-header">
                  <h4>Popular Tags</h4>
                </div>
                <div class="card-body">
                  <div class="blogTags">
                    <ul>

                      <!-- Components/Pages/blog-detail/tags.html -->
                      {tags.map((item: any) => (
                        <li><a href="#">{item.title}</a></li>
                      ))}

                    </ul>
                  </div>
                </div>
              </div>

              <!-- Share Links -->
              <div class="card">
                <div class="card-header">
                  <h4>Social Share</h4>
                </div>
                <div class="card-body">
                  <div class="blogShare">
                    <ul>
                      <li><a href="#"><i class="bi bi-facebook"></i></a></li>
                      <li><a href="#"><i class="bi bi-twitter"></i></a></li>
                      <li><a href="#"><i class="bi bi-instagram"></i></a></li>
                      <li><a href="#"><i class="bi bi-pinterest"></i></a></li>
                      <li><a href="#"><i class="bi bi-linkedin"></i></a></li>
                    </ul>
                  </div>
                </div>
              </div>

            </div>
          </div>

        </div>
      </div>
    </section>
    <!-- Articles Detail Section End -->

    <!-- Call To Action Start -->
    <section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
      <div class="container">

        <!-- Components/Home/index/subscribe.html -->
        <Subscribe />

      </div>
    </section>
    <!-- Call To Action Start -->

    <!-- Components/Home/index/log.html -->
    <LoginModal />


    <!-- Components/Home/index/cart.html -->
    <!-- Components/Home/index/search.html -->
    <SearchOffcanvas />


    <!-- Components/Pages/blog-detail/drop.html -->
    <!-- Drop Comment Modal -->
    <div class="modal modal-lg fade" id="commentModal" tabindex="-1" aria-labelledby="commentModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header bg-light border-0 px-md-5">
            <h4 class="modal-title fw-medium" id="commentModalLabel">Drop your Comments</h4>
            <a href="#" data-bs-dismiss="modal" aria-label="Close" class="square--40 circle bg-light-danger text-danger"><i class="bi bi-x"></i></a>
          </div>
          <div class="modal-body p-md-5">
            <div class="messageForm">
              <div class="form-group">
                <textarea class="form-control" placeholder="Type your Message To Dan"></textarea>
              </div>
              <button type="button" class="btn btn-primary fw-medium px-md-5">Submit Comment<i class="bi bi-arrow-right ms-2"></i></button>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <Footer />
</Base>
