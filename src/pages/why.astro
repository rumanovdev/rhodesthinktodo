---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';

const bestOf = [
  'Εστιατόρια', 'Τοπικά προϊόντα & γεύσεις', 'Boat trips', 'Beaches',
  'Hotels', 'Travel agencies', 'Transfers', 'Rent a car & moto',
  'Water sports', 'Spa', 'Bars', 'Cafés', 'Χωριά', 'Κρυμμένα σημεία',
];
---
<Base
  title="Γιατί δημιουργήσαμε το Rhodes Things To Do"
  description="Η ιστορία και η φιλοσοφία πίσω από το Rhodes Things To Do — η ψηφιακή βιτρίνα των καλύτερων εμπειριών της Ρόδου, χωρίς προμήθειες και χωρίς μεσάζοντες."
  canonical="/why/"
>
  <Navbar headerClass="header header-light head-shadow" />

  <!-- Hero -->
  <section class="why-hero">
    <div class="container text-center">
      <span class="why-kicker">Η ιστορία μας</span>
      <h1 class="why-title">Γιατί δημιουργήσαμε το<br><span class="text-primary">Rhodes Things To Do</span></h1>
      <p class="why-tagline">Ο τουρισμός της Ρόδου αξίζει κάτι καλύτερο.</p>
    </div>
  </section>

  <!-- Body -->
  <section class="why-body">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9 col-md-11">

          <p class="why-lead">Δεν δημιουργούμε ακόμη ένα τουριστικό portal. Δημιουργούμε τη <strong>ψηφιακή βιτρίνα των καλύτερων εμπειριών της Ρόδου</strong>.</p>

          <p>Έναν χώρο αφιερωμένο στους ανθρώπους που αγαπούν πραγματικά αυτόν τον τόπο. Στους επαγγελματίες που εργάζονται καθημερινά με πάθος, ποιότητα και σεβασμό προς τον επισκέπτη, αλλά συχνά παραμένουν στη σκιά των μεγάλων διεθνών πλατφορμών.</p>

          <p>Σήμερα, για να προβληθεί μια τοπική επιχείρηση, χρειάζονται μεγάλα διαφημιστικά budgets, εξειδικευμένες γνώσεις, πολύπλοκα εργαλεία marketing και προμήθειες που πολλές φορές απορροφούν ένα σημαντικό μέρος του κέρδους της.</p>

          <blockquote class="why-quote">
            Πολλοί αξιόλογοι άνθρωποι δεν υστερούν στην ποιότητα.<br>
            <span class="text-primary">Υστερούν μόνο στην προβολή.</span>
          </blockquote>

          <p>Και αυτό ακριβώς θέλουμε να αλλάξουμε. Το Rhodes Things To Do δημιουργείται για να ενώσει σε ένα σημείο ό,τι καλύτερο έχει να προσφέρει η Ρόδος. Όχι τις περισσότερες επιχειρήσεις — <strong>τις καλύτερες</strong>. Εκείνες που ξεχωρίζουν για την ποιότητα, την αυθεντικότητα, τη φιλοξενία και την εμπειρία που προσφέρουν.</p>

          <p class="why-statement">Ο επισκέπτης δεν θα βρίσκει απλώς μια λίστα επιχειρήσεων. Θα ανακαλύπτει την πραγματική Ρόδο.</p>
        </div>
      </div>

      <!-- Best-of grid -->
      <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
          <div class="why-grid">
            {bestOf.map((x) => (
              <div class="why-grid-item"><span>Τα καλύτερα</span>{x}</div>
            ))}
          </div>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9 col-md-11">
          <p class="mt-5">…και τις εμπειρίες που δεν βρίσκονται εύκολα σε έναν συνηθισμένο ταξιδιωτικό οδηγό.</p>

          <blockquote class="why-quote">
            Θέλουμε κάθε επισκέπτης να μη νιώθει ότι βλέπει μια διαφήμιση,<br>
            <span class="text-primary">αλλά ότι τον ξεναγεί ένας ντόπιος φίλος που αγαπά τη Ρόδο.</span>
          </blockquote>

          <div class="why-pillars">
            <div class="why-pill">Δεν λειτουργούμε ως μεσάζοντας</div>
            <div class="why-pill">Δεν πουλάμε εμπειρίες</div>
            <div class="why-pill">Δεν κρατάμε προμήθειες</div>
            <div class="why-pill">Δεν ανεβάζουμε τις τιμές</div>
          </div>

          <p>Ο κάθε συνεργάτης παρουσιάζει την επιχείρησή του ακριβώς όπως ο ίδιος επιθυμεί — με τις δικές του φωτογραφίες, το δικό του περιεχόμενο, το δικό του website και τα δικά του στοιχεία επικοινωνίας. Ο επισκέπτης επικοινωνεί <strong>απευθείας</strong> με τον επαγγελματία: χωρίς ενδιάμεσους, χωρίς κρυφές χρεώσεις, χωρίς περιορισμούς.</p>

          <p>Το μόνο που ζητάμε είναι <strong>ποιότητα, συνέπεια και κοινό όραμα</strong>: να δημιουργήσουμε όλοι μαζί τον πιο αξιόπιστο, ανθρώπινο και ποιοτικό τουριστικό οδηγό της Ρόδου.</p>
        </div>
      </div>

      <!-- Finale -->
      <div class="row justify-content-center mt-5">
        <div class="col-xl-9 col-lg-10">
          <p class="text-center why-statement" style="margin-bottom:2.2rem !important;">Όταν αναδεικνύεται σωστά η τοπική επιχειρηματικότητα, κερδίζουν όλοι.</p>
          <div class="why-wins">
            <div class="why-win"><span>Κερδίζει</span><strong>ο επισκέπτης</strong></div>
            <div class="why-win"><span>Κερδίζει</span><strong>η επιχείρηση</strong></div>
            <div class="why-win"><span>Κερδίζει</span><strong>η Ρόδος</strong></div>
          </div>
          <div class="text-center mt-5">
            <a href="/contact-us/" class="btn btn-primary rounded-pill px-5 fw-medium">Γίνε συνεργάτης</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <LoginModal />
  <SearchOffcanvas />
  <Footer />

  <style is:global>
    .why-hero { padding: 70px 0 26px; }
    .why-kicker { color: var(--bs-primary); font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-size: .8rem; }
    .why-title { font-weight: 800; line-height: 1.15; font-size: clamp(2rem, 4.5vw, 3.1rem); color: #14233a; margin: 14px 0 18px; }
    .why-tagline { font-size: 1.35rem; color: #4a5568; font-weight: 500; }
    .why-body { padding: 14px 0 80px; }
    .why-body p { font-size: 1.12rem; line-height: 1.85; color: #33373d; margin-bottom: 1.5rem; }
    .why-body strong { color: #14233a; }
    .why-lead { font-size: 1.3rem !important; font-weight: 600; color: #14233a !important; }
    .why-statement { font-size: 1.3rem !important; font-weight: 700; color: #14233a !important; text-align: center; margin: 2.5rem 0 !important; }
    .why-quote { border: 0; text-align: center; font-size: clamp(1.4rem, 3vw, 1.9rem); font-weight: 800; line-height: 1.3; color: #14233a; margin: 3rem 0; }
    .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; margin: 1rem 0; }
    .why-grid-item { background: #fff; border: 1px solid #e7e3d8; border-radius: 12px; padding: 16px 18px; font-weight: 700; color: #14233a; box-shadow: 0 4px 14px rgba(0,0,0,.04); }
    .why-grid-item span { display: block; color: var(--bs-primary); font-size: .8rem; font-weight: 700; margin-bottom: 3px; }
    .why-pillars { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; margin: 2.5rem 0; }
    .why-pill { background: #fff; border: 1px solid #e7e3d8; border-left: 4px solid var(--bs-primary); border-radius: 12px; padding: 14px 22px; font-weight: 600; color: #14233a; font-size: 1.02rem; box-shadow: 0 4px 14px rgba(0,0,0,.04); }
    .why-wins { display: flex; flex-wrap: wrap; gap: 18px; }
    .why-win { flex: 1; min-width: 220px; text-align: center; background: #14233a; color: #fff; border-radius: 18px; padding: 34px 20px; }
    .why-win span { display: block; color: #cdd6e2; font-size: 1rem; margin-bottom: 6px; }
    .why-win strong { font-size: 1.5rem; color: #fff; }
    @media (max-width: 575px) {
      .why-body p { font-size: 1.05rem; }
      .why-pill { width: 100%; }
    }
  </style>
</Base>
