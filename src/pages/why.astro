---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import { DEFAULT_LOCALE, type Locale } from '../lib/i18n';

const locale: Locale = (Astro.locals as any).locale ?? DEFAULT_LOCALE;

const en = {
  meta: { title: 'Why we created Rhodes Things To Do', desc: 'The story and philosophy behind Rhodes Things To Do — the digital showcase of the best experiences in Rhodes, with no commissions and no middlemen.' },
  kicker: 'Our story',
  title: 'Why we created<br><span class="text-primary">Rhodes Things To Do</span>',
  tagline: 'Rhodes tourism deserves something better.',
  lead: 'We are not building yet another tourist portal. We are building the <strong>digital showcase of the best experiences in Rhodes</strong>.',
  p1: 'Local businesses have grown increasingly dependent on large international booking platforms that charge high commissions, limit their visibility and often turn the local professional into just another number among millions of listings.',
  p2: 'To get noticed today, a business needs big advertising budgets, specialised know-how, complex marketing tools and commissions that often absorb a large part of its profit.',
  quote1a: 'Many remarkable people do not fall short on quality.',
  quote1b: 'They only fall short on visibility.',
  p3: 'And that is exactly what we want to change. Rhodes Things To Do brings together in one place the very best the island has to offer — not the most businesses, <strong>the best ones</strong>. The ones that stand out for their quality, authenticity, hospitality and the experience they offer.',
  statement: 'Visitors will not just find a list of businesses. They will discover the real Rhodes.',
  bestOfLabel: 'Best of',
  bestOf: ['Restaurants', 'Local flavours', 'Boat trips', 'Beaches', 'Hotels', 'Travel agencies', 'Transfers', 'Rent a car & moto', 'Water sports', 'Spa', 'Bars & Cafés', 'Villages & hidden gems'],
  pAfterGrid: '…and the experiences you will not easily find in an ordinary travel guide.',
  quote2a: 'We want every visitor to feel not like they are seeing an advert,',
  quote2b: 'but like a local friend who truly loves Rhodes is showing them around.',
  pillars: ['No middlemen', 'We don’t sell experiences', 'No commissions', 'No price markups'],
  p4: 'Each partner presents their business exactly as they wish — with their own photos, their own content, their own website and their own contact details. Visitors reach the professional <strong>directly</strong>: no intermediaries, no hidden fees, no restrictions.',
  p5: 'All we ask for is <strong>quality, consistency and a shared vision</strong>: to build together the most trustworthy, human and high-quality travel guide for Rhodes.',
  finale: 'When local entrepreneurship is showcased properly, everyone wins.',
  winsLabel: 'Wins',
  wins: ['the visitor', 'the business', 'Rhodes'],
  cta: 'Become a partner',
};

const el = {
