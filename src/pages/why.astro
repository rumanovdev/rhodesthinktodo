const de = {
  meta: { title: 'Warum wir Rhodes Things To Do erschaffen haben', desc: 'Die Geschichte und Philosophie hinter Rhodes Things To Do — das digitale Schaufenster der besten Erlebnisse auf Rhodos, ohne Provisionen und ohne Mittelsmänner.' },
