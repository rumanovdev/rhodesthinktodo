const byLocale: Record<string, typeof en> = { en, el, de, fr, es, it, nl } as any;
const c = byLocale[locale] ?? en;
---
<Base title={c.meta.title} description={c.meta.desc} canonical="/why/">
  <Navbar headerClass="header header-light head-shadow" />

  <section class="why-hero">
    <div class="container text-center">
      <span class="why-kicker">{c.kicker}</span>
      <h1 class="why-title" set:html={c.title}></h1>
      <p class="why-tagline">{c.tagline}</p>
    </div>
  </section>

  <section class="why-body">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9 col-md-11">
          <p class="why-lead" set:html={c.lead}></p>
          <p set:html={c.p1}></p>
          <p set:html={c.p2}></p>
          <blockquote class="why-quote">{c.quote1a}<br><span class="text-primary">{c.quote1b}</span></blockquote>
          <p set:html={c.p3}></p>
          <p class="why-statement">{c.statement}</p>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-xl-9 col-lg-10">
          <p class="why-grid-label">{c.bestOfLabel}</p>
          <div class="why-grid">
            {c.bestOf.map((x) => (<div class="why-grid-item">{x}</div>))}
          </div>
        </div>
      </div>

      <div class="row justify-content-center">
        <div class="col-xl-8 col-lg-9 col-md-11">
          <p class="mt-4">{c.pAfterGrid}</p>
          <blockquote class="why-quote">{c.quote2a}<br><span class="text-primary">{c.quote2b}</span></blockquote>
          <div class="why-pillars">
            {c.pillars.map((x) => (<div class="why-pill">{x}</div>))}
          </div>
          <p set:html={c.p4}></p>
          <p set:html={c.p5}></p>
        </div>
      </div>

      <div class="row justify-content-center mt-5">
        <div class="col-xl-9 col-lg-10">
          <p class="text-center why-statement" style="margin-bottom:2.2rem !important;">{c.finale}</p>
          <div class="why-wins">
            {c.wins.map((w) => (<div class="why-win"><span>{c.winsLabel}</span><strong>{w}</strong></div>))}
          </div>
          <div class="text-center mt-5">
            <a href="/contact-us/" class="btn btn-primary rounded-pill px-5 fw-medium">{c.cta}</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <LoginModal />
  <SearchOffcanvas />
  <Footer />

  <style is:global>
    .why-hero { padding: 70px 0 26px; }
    .why-kicker { color: var(--bs-primary); font-weight: 700; letter-spacing: .14em; text-transform: uppercase; font-size: .8rem; }
