---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { helps, articles2 } from '../lib/data/context';
---
<Base title="Help Center - Rhodes Things To Do">
  <Navbar headerClass="header header-light" />

<Preloader />

<div class="clearfix"></div>

<!-- Page Title -->
<section class="bg-cover position-relative" style="background:#ffe8ee url(/assets/img/title-bg.png)no-repeat;">
	<div class="container">
		<div class="row align-items-center justify-content-center pt-lg-0 pt-5">
			<div class="col-xl-12 col-lg-12 col-md-12">

				<div class="fpc-capstion text-center my-4">
					<div class="fpc-captions">
						<h1 class="fs-1 lh-base">Help Center</h1>
						<form class="col-md-6 bg-body rounded-pill mx-auto p-2 mb-3">
							<div class="input-group">
								<input class="form-control border-0 fs-6 fw-medium me-1 rounded-pill" type="text" placeholder="Search question...">
								<button type="button" class="btn btn-primary fw-medium rounded-pill px-xl-5 mb-0">Search</button>
							</div>
						</form>
						<div class="row align-items-center mt-5 mb-2">
							<div class="col-xl-6 col-lg-8 col-md-9 mx-auto">
								<h6 class="text-primary mb-3">Popular questions</h6>
								<!-- Questions List START -->
								<div class="list-group hstack gap-3 justify-content-center flex-wrap mb-0">
									<a class="btn-link text-decoration-underline p-0 mb-0" href="#"> How can we help?</a>
									<a class="btn-link text-decoration-underline p-0 mb-0" href="#"> How to upload data to the system? </a>
									<a class="btn-link text-decoration-underline p-0 mb-0" href="#"> Installation Guide? </a>
									<a class="btn-link text-decoration-underline p-0 mb-0" href="#"> How to view expired tickets? </a>
									<a class="btn-link p-0 mb-0" href="#!">View all question</a>
								</div>
								<!-- Questions list END -->
							</div>
						</div>
					</div>
				</div>

			</div>
		</div>
	</div>
</section>
<!-- Page Title -->


<!-- Helps Categories Section -->
<section class="bg-light">
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">How can we <span class="text-primary">help?</span></h3>
					<p>Perceived end knowledge certainly day sweetness why cordially</p>
				</div>
			</div>
		</div>

		<div class="row align-items-start justify-content-center g-4">

			<!-- Components/Pages/help-center/help.html -->
			{helps.map((item) => (
			<div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
			    <div class="helpCategories">
			        <div class="iconlink">
			            <div class="icon"><i class={item.icon}></i></div>
			            <div class="link"><a href="/single-helps/" class="link"><i class="bi bi-box-arrow-in-right"></i></a></div>
			        </div>
			        <div class="details">
			            <div class="headers">
			                <h5 class="tltname">{item.title}</h5>
			                <p>{item.desc}</p>
			            </div>
			            <div class="subcategories">
			                <span>{item.name}</span>
			                <span>{item.name1}</span>
			                <span>{item.name2}</span>
			            </div>
			        </div>
			    </div>
			</div>
			))}

		</div>

	</div>
</section>
<!-- Helps Categories Section End -->


<!-- Popular Articles Section -->
<section>
	<div class="container">

		<div class="row align-items-center justify-content-center">
			<div class="col-xl-7 col-lg-8 col-md-11 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Explore Popular <span class="text-primary">Articles</span></h3>
					<p>Perceived end knowledge certainly day sweetness why cordially</p>
				</div>
			</div>
		</div>

		<div class="row align-items-center justify-content-center g-4">

			<!-- Components/Pages/help-center/articles2.html -->
			{articles2.map((item) => (
			<div class="col-xl-6 col-lg-6 col-md-12 col-sm-12">
			    <a href="/single-helps/" class="popularArticles">
			        <div class="descriptions">
			            <h5 class="title">{item.title}</h5>
			            <p class="sedc">{item.desc}</p>
			        </div>
			    </a>
			</div>
			))}

		</div>

	</div>
</section>
<!-- Popular Articles Section End -->


<!-- Call To Action Start -->
<section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
	<div class="container">

		<!-- Components/Home/index/subscribe.html -->
		<Subscribe />

	</div>
</section>
<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />


<Footer />
</Base>
