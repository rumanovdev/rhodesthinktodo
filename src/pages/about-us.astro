---
import Base from '../layouts/Base.astro';
import Navbar from '../components/nav/Navbar.astro';
import Footer from '../components/nav/Footer.astro';
import Subscribe from '../components/shared/Subscribe.astro';
import LoginModal from '../components/shared/LoginModal.astro';
import SearchOffcanvas from '../components/shared/SearchOffcanvas.astro';
import Preloader from '../components/shared/Preloader.astro';
import { process2 } from '../lib/data/context';
---
<Base
  title="About Us — Your Local Guide to Rhodes | Rhodes Things To Do"
  description="Learn about Rhodes Things To Do, the local directory helping visitors and residents discover the best restaurants, hotels, tours and activities across Rhodes, Greece."
  canonical="/about-us/"
>
  <Navbar headerClass="header header-light head-shadow" />

<Preloader />

<div class="clearfix"></div>

<!-- Page Title Start -->
<section class="bg-cover position-relative" style="background:url(/assets/img/title-banner.jpg)no-repeat;" data-overlay="6">
	<div class="container">

		<!-- Search Form -->
		<div class="row justify-content-center align-items-center pt-lg-0 pt-5">
			<div class="col-xl-7 col-lg-9 col-md-12 col-sm-12">
				<div class="position-relative text-center mb-5">
					<h1 class="text-light xl-heading">About Page</h1>
					<nav id="breadcrumbs" class="breadcrumbs light">
						<ul>
							<li><a href="/">Home</a></li>
							<li><a href="#">Pages</a></li>
							<li>About Us</li>
						</ul>
					</nav>
				</div>
			</div>
		</div>
		<!-- </row> -->

	</div>
</section>
<!-- Page Title End -->

<!-- Who We Are Start -->
<section class="pb-5">
	<div class="container">
		<div class="row">

			<!-- Mission Headings -->
			<div class="row justify-content-center align-items-center">
				<div class="col-xl-10 col-lg-11 col-md-12 col-sm-12">
					<div class="secHeading-wrap text-center">
						<h3 class="sectionHeading">How We Start <span class="text-primary">Work</span></h3>
						<p>Explore our work process step by step and our mission</p>
					</div>
				</div>
			</div>
			<!-- Mission Headings -->

			<!-- Our Mission -->
			<div class="row justify-content-between align-items-center g-4 mb-5">

				<!-- Components/Pages/about-us/our-mission.html -->
				<div class="col-xl-5 col-lg-5 col-md-6 col-sm-12">
				    <div class="missionImg">
				        <img src="/assets/img/hero-rhodes.jpg" class="img-fluid rounded-4" alt="Rhodes Old Town and the Palace of the Grand Master">
				    </div>
				</div>
				<div class="col-xl-6 col-lg-6 col-md-6 col-sm-12">
				    <div class="missioncaps">
				        <div class="d-block mb-4">
				            <h2>Explore Our Aim &amp; Mission</h2>
				        </div>
				        <p>Rhodes Things To Do is a local guide and directory built to help visitors and residents discover the very best of the island of Rhodes, Greece. From the medieval Old Town and the Acropolis of Lindos to hidden beaches, family tavernas, boat trips and wellness spots, we bring it all together in one easy place.</p>
				        <p>Our mission is simple: make it effortless to find great places to eat, stay and explore in Rhodes, and to connect travellers with trusted local businesses. Every listing is organised by category and shown on an interactive map, so you can plan your trip with confidence.</p>
				        <div class="d-flex align-items-start mt-4">
				            <a href="/listings-grid/" class="btn btn-light-primary rounded-pill px-5">Explore Listings</a>
				        </div>
				    </div>
				</div>

			</div>
			<!-- Our Mission -->

		</div>
	</div>
</section>
<!-- Who We Are End -->


<!-- Who We Are Start -->
<section class="bg-cover" style="background:#1a1a1a url(/assets/img/rhodes-about.jpg) center/cover no-repeat;" data-overlay="5">
	<div class="container">
		<div class="row">

			<div class="row justify-content-center align-items-center">
				<div class="col-xl-9 col-lg-10 col-md-12 col-sm-12">
				    <div class="position-relative text-center py-5 my-4">

				        <div class="promoTitle d-flex align-items-center justify-content-center">
				            <span class="badge badge-xs badge-transparent rounded-pill">The Island of Rhodes</span>
				        </div>

				        <div class="promoHeading mt-4">
				            <h2 class="text-light">Where ancient history meets the Aegean sea.</h2>
				            <p class="text-light fs-5 opacity-75 mt-3">Rhodes is the largest of the Dodecanese islands, famous for its UNESCO-listed medieval Old Town, the clifftop Acropolis of Lindos, golden beaches and crystal-clear water. From sunrise hikes and boat trips to traditional tavernas and lively nightlife, the island offers something for every kind of traveller — and Rhodes Things To Do helps you find the very best of it.</p>
				        </div>

				    </div>
				</div>
			</div>

		</div>
	</div>
</section>
<!-- Who We Are End -->


<!-- Working Process -->
<section>
	<div class="container">

		<!-- Mission Headings -->
		<div class="row justify-content-center align-items-center">
			<div class="col-xl-10 col-lg-11 col-md-12 col-sm-12">
				<div class="secHeading-wrap text-center">
					<h3 class="sectionHeading">Our Working <span class="text-primary">Process</span></h3>
					<p>Explore our work process step by step and our mission</p>
				</div>
			</div>
		</div>
		<!-- Mission Headings -->

		<div class="row justify-content-center g-md-5 g-4">

			<!-- Components/Pages/about-us/process2.html -->
			{process2.map((item) => (
			<div class="col-xl-4 col-lg-4 col-md-6">
			    <div class="processWrap px-xl-4">
			        <div class="text-center">
			            <div class="processIcons d-block">
			                <div class="Icons">
			                    <i class={item.icon}></i>
			                </div>
			            </div>
			            <div class="processCaps">
			                <h4 class="fw-medium">{item.title}</h4>
			                <p class="m-0">{item.desc}</p>
			            </div>
			        </div>
			    </div>
			</div>
			))}

			<div class="col-xl-12 col-lg-12 col-md-12">
				<div class="d-flex align-items-center justify-content-center mt-4">
					<a href="#" class="btn btn-light-primary rounded-pill px-5">View More Details<i class="bi bi-caret-right ms-2"></i></a>
				</div>
			</div>

		</div>

	</div>
</section>
<!-- Working Process END -->



<!-- Call To Action Start -->
<section class="bg-cover bg-primary-2 position-relative py-5" style="background:url(/assets/img/brand-section.png)no-repeat;">
	<div class="container">

		<!-- Components/Home/index/subscribe.html -->
		<Subscribe />

	</div>
</section>
<!-- Call To Action Start -->


	<!-- Components/Home/index/log.html -->
	<LoginModal />


	<!-- Components/Home/index/cart.html -->
	<!-- Components/Home/index/search.html -->
	<SearchOffcanvas />

  <Footer />
</Base>
