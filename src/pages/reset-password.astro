---
import NoHeader from '../layouts/NoHeader.astro';
export const prerender = false;

const error = Astro.url.searchParams.get('error');

if (Astro.request.method === 'POST') {
  const supabase = Astro.locals.supabase;
  const form = await Astro.request.formData();
  const password = String(form.get('password') ?? '');
  const confirm = String(form.get('confirm_password') ?? '');

  if (!supabase) {
    return Astro.redirect('/reset-password/?error=' + encodeURIComponent('Server misconfigured'));
  }
  if (password.length < 8) {
    return Astro.redirect('/reset-password/?error=' + encodeURIComponent('Password must be at least 8 characters'));
  }
  if (password !== confirm) {
    return Astro.redirect('/reset-password/?error=' + encodeURIComponent('Passwords do not match'));
  }

  const { error: updErr } = await supabase.auth.updateUser({ password });
  if (updErr) {
    return Astro.redirect('/reset-password/?error=' + encodeURIComponent(updErr.message));
  }
  return Astro.redirect('/dashboard-user/');
}

// User must arrive here via the recovery callback with an active session.
if (!Astro.locals.user) {
  return Astro.redirect('/forgot-password/?error=' + encodeURIComponent('Recovery link expired — request a new one.'));
}
---
<NoHeader title="Reset Password - Rhodes Things To Do">
	<div class="bg-cover" style="background: #ffe8ee url(/assets/img/auth-bg.png) no-repeat; height:100vh">
		<section>
			<div class="container">
				<div class="row align-items-center justify-content-center">
					<div class="col-xl-5 col-lg-7 col-md-9">
						<div class="authWrap">
							<div class="authhead">
								<div class="text-center mb-4"><a href="/"><img class="img-fluid" src="/assets/img/icon.png" width="55" alt="logo"></a></div>
							</div>
							<div class="authbody d-black mb-4">
								<div class="card rounded-4 p-sm-5 p-4">
									<div class="card-body p-0">
										<div class="text-center">
											<h1 class="mb-2 fs-2">Set a new password</h1>
											<p class="mb-0">Pick something you haven't used before.</p>
										</div>
										{error && (
											<div class="alert alert-danger mt-3 mb-0" role="alert">{error}</div>
										)}
										<form class="mt-4 text-start" method="post">
											<div class="form py-4">
												<div class="form-group mb-4">
													<label class="form-label">New password</label>
													<input type="password" name="password" class="form-control" placeholder="At least 8 characters" minlength="8" required autocomplete="new-password">
												</div>
												<div class="form-group mb-4">
													<label class="form-label">Confirm new password</label>
													<input type="password" name="confirm_password" class="form-control" placeholder="Repeat password" minlength="8" required autocomplete="new-password">
												</div>
												<div class="form-group">
													<button type="submit" class="btn btn-primary full-width fw-medium">Update Password</button>
												</div>
											</div>
										</form>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</NoHeader>
