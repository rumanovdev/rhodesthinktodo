# Supabase project URL — find at https://supabase.com/dashboard/project/_/settings/api
# Example: https://abcdefghijklmnop.supabase.co
PUBLIC_SUPABASE_URL=

# Supabase anon/public key — same settings page, "Project API keys" > "anon / public"
# Safe to expose in the browser bundle. Starts with "eyJ..."
PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SAME settings page, "service_role" key.
# NEVER expose in the browser. Only used server-side in Astro frontmatter / API routes.
# Starts with "eyJ..."
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email for booking-request notifications.
# Get the key at https://resend.com/api-keys (starts with "re_").
# Booking still works without it (emails are simply skipped until it's set).
RESEND_API_KEY=
# Optional "from" address. The domain must be verified in Resend.
# Defaults to "Rhodes Things To Do <bookings@rhodesthingstodo.com>".
RESEND_FROM=
